{% extends 'base.html.twig' %}

{% block title %}Politique de retour – Sports Bottles
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}

	{# ── HERO ── #}
	<section class="relative overflow-hidden text-center py-10 sm:py-12 px-8 mt-20" style="background: linear-gradient(135deg, #edf7f4 0%, #f5fbf9 100%);">
		<div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 70% 60% at 50% 120%, rgba(31,122,99,.12) 0%, transparent 70%);"></div>
		<div class="absolute top-0 left-0 right-0 h-px" style="background: linear-gradient(90deg, transparent, rgba(31,122,99,.2), transparent);"></div>
		<div class="relative">
			<span class="inline-block text-xs font-semibold tracking-widest uppercase border mb-4 px-3 py-1 rounded-full" style="background: rgba(31,122,99,.1); border-color: rgba(31,122,99,.3); color: #1F7A63;">Service client</span>
			<h1 class="text-3xl sm:text-4xl font-extrabold text-main leading-tight" style="font-family: 'Syne', sans-serif;">Politique de retour</h1>
			<p class="mt-3 text-[0.9rem] text-muted">Dernière mise à jour :
				{{ "now"|date("d F Y") }}</p>
		</div>
	</section>

	{# ── CONTENT ── #}
	<main
		class="max-w-[820px] mx-auto px-6 sm:px-8 py-14 pb-20">

		{# Guarantee banner #}
		<div class="flex items-center gap-4 bg-green-50 border border-green-200 rounded-xl px-7 py-5 mb-7">
			<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="shrink-0 text-green-700" viewbox="0 0 16 16">
				<path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1zm3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10h14V4H11.5zM8 7.993c1.664-1.711 5.825 1.283 0 5.132-5.825-3.85-1.664-6.843 0-5.132z"/>
			</svg>
			<p class="text-green-700 font-semibold text-[0.95rem] m-0">Satisfait ou remboursé — 30 jours pour changer d'avis, sans conditions.</p>
		</div>

		<p class="text-sm text-[#5a6a7e] text-center px-5 py-4 rounded-xl border mb-10" style="background: linear-gradient(135deg, rgba(27,143,228,.08), rgba(93,184,255,.06)); border-color: rgba(27,143,228,.2);">
			Conformément à la législation française et européenne en vigueur, notamment la
			<strong class="text-[#1b8fe4]">loi Hamon</strong>
			et la
			<strong class="text-[#1b8fe4]">directive 2011/83/UE</strong>, tout acheteur dispose
				        d'un droit de rétractation de 14 jours. Sports Bottles étend ce délai à
			<strong class="text-[#1b8fe4]">30 jours</strong>.
		</p>

		{# Étapes #}
		<div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
			<h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
				<span class="inline-flex items-center justify-center w-8 h-8 text-white text-xs font-bold rounded-lg shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">1</span>
				Comment effectuer un retour ?
			</h2>
			<p class="text-[#5a6a7e] text-[0.95rem] mb-4">La procédure de retour se déroule en 3 étapes simples :</p>
			<div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mt-4 mb-2">
				<div class="bg-[#f4f7fb] border border-[#dde4ed] rounded-xl p-5 flex flex-col gap-1.5">
					<span class="text-[#1b8fe4] text-3xl font-extrabold leading-none" style="font-family: 'Syne', sans-serif;">01</span>
					<span class="font-bold text-sm text-[#0d1b2a]">Contactez-nous</span>
					<span class="text-xs text-[#5a6a7e]">Envoyez un e-mail à retours@sportsbottles.fr avec votre numéro de commande.</span>
				</div>
				<div class="bg-[#f4f7fb] border border-[#dde4ed] rounded-xl p-5 flex flex-col gap-1.5">
					<span class="text-[#1b8fe4] text-3xl font-extrabold leading-none" style="font-family: 'Syne', sans-serif;">02</span>
					<span class="font-bold text-sm text-[#0d1b2a]">Renvoyez le colis</span>
					<span class="text-xs text-[#5a6a7e]">Emballez l'article soigneusement et déposez-le en point relais sous 7 jours.</span>
				</div>
				<div class="bg-[#f4f7fb] border border-[#dde4ed] rounded-xl p-5 flex flex-col gap-1.5">
					<span class="text-[#1b8fe4] text-3xl font-extrabold leading-none" style="font-family: 'Syne', sans-serif;">03</span>
					<span class="font-bold text-sm text-[#0d1b2a]">Remboursement</span>
					<span class="text-xs text-[#5a6a7e]">Votre remboursement est traité sous 5 à 10 jours ouvrés après réception.</span>
				</div>
			</div>
		</div>

		<div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
			<h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
				<span class="inline-flex items-center justify-center w-8 h-8 text-white text-xs font-bold rounded-lg shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">2</span>
				Délais de rétractation
			</h2>
			<p class="text-[#5a6a7e] text-[0.95rem] mb-3">Vous disposez d'un délai de
				<strong>30 jours calendaires</strong>
				à compter de la réception de
				        votre commande pour exercer votre droit de rétractation, sans avoir à justifier votre décision
				        ni à payer de pénalités.</p>
			<p class="text-[#5a6a7e] text-[0.95rem]">Au-delà de ce délai, aucun retour ne pourra être accepté sauf en cas de défaut de conformité
				        ou de vice caché.</p>
		</div>

		<div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
			<h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
				<span class="inline-flex items-center justify-center w-8 h-8 text-white text-xs font-bold rounded-lg shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">3</span>
				Conditions de retour
			</h2>
			<p class="text-[#5a6a7e] text-[0.95rem] mb-3">Pour être accepté, le produit retourné doit respecter les conditions suivantes :</p>
			<ul class="list-none p-0 mt-2 mb-3 space-y-1">
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Article dans son état d'origine, non utilisé et non endommagé.</li>
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Emballage d'origine intact avec toutes les étiquettes.</li>
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Accessoires, notices et cadeaux inclus dans la commande présents.</li>
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Accompagné du bon de retour fourni par notre service client.</li>
			</ul>
			<p class="text-[#5a6a7e] text-[0.95rem]">Les articles manifestement utilisés, abîmés ou incomplets ne pourront pas faire l'objet d'un
				        remboursement intégral.</p>
		</div>

		<div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
			<h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
				<span class="inline-flex items-center justify-center w-8 h-8 text-white text-xs font-bold rounded-lg shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">4</span>
				Articles non retournables
			</h2>
			<p class="text-[#5a6a7e] text-[0.95rem] mb-3">Certains articles sont exclus du droit de retour conformément à l'article L221-28 du Code de la
				        consommation :</p>
			<ul class="list-none p-0 mt-2 mb-0 space-y-1">
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Produits personnalisés ou fabriqués sur mesure.</li>
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Articles scellés descellés après livraison pour des raisons d'hygiène ou de protection de la santé.</li>
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Produits soldés ou en liquidation clairement indiqués comme non retournables.</li>
			</ul>
		</div>

		<div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
			<h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
				<span class="inline-flex items-center justify-center w-8 h-8 text-white text-xs font-bold rounded-lg shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">5</span>
				Frais de retour
			</h2>
			<p class="text-[#5a6a7e] text-[0.95rem] mb-3">Les frais de retour sont à votre charge, sauf dans les cas suivants :</p>
			<ul class="list-none p-0 mt-2 mb-3 space-y-1">
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Article défectueux ou non conforme à la description.</li>
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Erreur de notre part dans la préparation de la commande.</li>
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Article endommagé lors du transport.</li>
			</ul>
			<p class="text-[#5a6a7e] text-[0.95rem]">Dans ces cas, Sports Bottles prend en charge les frais de retour et vous envoie une étiquette
				        prépayée par e-mail.</p>
		</div>

		<div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
			<h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
				<span class="inline-flex items-center justify-center w-8 h-8 text-white text-xs font-bold rounded-lg shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">6</span>
				Modalités de remboursement
			</h2>
			<p class="text-[#5a6a7e] text-[0.95rem] mb-3">Le remboursement est effectué sur le même moyen de paiement que celui utilisé lors de l'achat,
				        dans un délai de
				<strong>5 à 10 jours ouvrés</strong>
				après réception et vérification du colis retourné.</p>
			<ul class="list-none p-0 mt-2 mb-3 space-y-1">
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Carte bancaire : remboursement sous 5–10 jours ouvrés.</li>
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>PayPal : remboursement sous 3–5 jours ouvrés.</li>
				<li class="relative pl-6 text-[#5a6a7e] text-[0.95rem] py-0.5">
					<span class="absolute left-0 text-[#1b8fe4] text-sm" aria-hidden="true">→</span>Avoir boutique : disponible immédiatement après validation du retour.</li>
			</ul>
			<p class="text-[#5a6a7e] text-[0.95rem]">Les frais de livraison initiaux ne sont remboursés qu'en cas de rétractation totale de la
				        commande dans le délai légal de 14 jours.</p>
		</div>

		<div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
			<h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
				<span class="inline-flex items-center justify-center w-8 h-8 text-white text-xs font-bold rounded-lg shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">7</span>
				Garantie légale de conformité
			</h2>
			<p class="text-[#5a6a7e] text-[0.95rem] mb-3">Indépendamment du droit de retour, tous nos produits bénéficient de la garantie légale de
				        conformité (2 ans) et de la garantie contre les vices cachés prévues par le Code civil.</p>
			<p class="text-[#5a6a7e] text-[0.95rem]">En cas de défaut constaté, contactez notre service client à
				<strong>garantie@sportsbottles.fr</strong>.
					        Nous vous proposerons un échange, une réparation ou un remboursement selon la nature du défaut.</p>
		</div>

		{# CTA #}
		<div class="relative overflow-hidden rounded-2xl px-10 py-10 text-center" style="background: linear-gradient(135deg, #0d1b2a, #163556);">
			<div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 50% at 50% 100%, rgba(27,143,228,.3) 0%, transparent 70%);"></div>
			<div class="relative">
				<h2 class="text-xl font-bold text-white mb-2" style="font-family: 'Syne', sans-serif;">Une question sur votre retour ?</h2>
				<p class="text-[0.92rem] mb-5" style="color: rgba(255,255,255,.6);">Notre équipe est disponible du lundi au vendredi, de 9h à 18h.</p>
				<a href="{{ path('app_contact') }}" class="inline-block bg-[#1b8fe4] text-white px-8 py-3 rounded-lg font-semibold text-[0.95rem] no-underline hover:bg-[#5db8ff] hover:-translate-y-0.5 transition-all">Contacter le service client</a>
			</div>
		</div>

	</main>

{% endblock %}
