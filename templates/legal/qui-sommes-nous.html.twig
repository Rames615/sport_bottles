{% extends 'base.html.twig' %}

{% block title %}Qui sommes-nous ? – Sports Bottles{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
{% endblock %}

{% block body %}

{# ── HERO ── #}
<section class="relative overflow-hidden text-center py-20 sm:py-24 px-8 mt-20" style="background: linear-gradient(135deg, #0d1b2a 0%, #163556 100%);">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 70% 60% at 50% 120%, rgba(27,143,228,.35) 0%, transparent 70%);"></div>
    <div class="relative">
        <span class="inline-block text-xs font-semibold tracking-widest uppercase border mb-5 px-3 py-1 rounded-full" style="background: rgba(27,143,228,.18); border-color: rgba(93,184,255,.35); color: #5db8ff;">À propos</span>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white leading-tight" style="font-family: 'Syne', sans-serif;">Qui sommes-nous ?</h1>
        <p class="mt-4 text-[1.05rem] max-w-xl mx-auto relative" style="color: rgba(255,255,255,.65);">
            Accompagner un mode de vie actif, sain et responsable — une bouteille à la fois.
        </p>
    </div>
</section>

{# ── CONTENT ── #}
<main class="max-w-[860px] mx-auto px-6 sm:px-8 py-14 pb-20">

    {# 1. Mission #}
    <div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
        <h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
            <span class="inline-flex items-center justify-center w-9 h-9 text-white rounded-xl shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                    <path d="M8 13A5 5 0 1 1 8 3a5 5 0 0 1 0 10zm0 1A6 6 0 1 0 8 2a6 6 0 0 0 0 12z"/>
                    <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/>
                    <path d="M9.5 8a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
                </svg>
            </span>
            Notre mission
        </h2>
        <p class="text-[#5a6a7e] text-[0.95rem] mb-3">
            Notre mission est simple : accompagner un mode de vie actif, sain et responsable en proposant
            des bouteilles de sport <strong>fiables, durables et adaptées aux usages du quotidien</strong>.
        </p>
        <p class="text-[#5a6a7e] text-[0.95rem]">
            Nous croyons que l'hydratation est un élément essentiel du bien-être et de la performance,
            que ce soit dans le sport, au travail ou dans la vie de tous les jours. C'est pourquoi nous
            concevons une plateforme spécialisée, claire et accessible, dédiée exclusivement aux bouteilles
            de sport de qualité.
        </p>
    </div>

    {# 2. Catalogue #}
    <div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
        <h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
            <span class="inline-flex items-center justify-center w-9 h-9 text-white rounded-xl shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M2.5 3.5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-11zm2-2a.5.5 0 0 1 0-1h7a.5.5 0 0 1 0 1h-7zM0 13a1.5 1.5 0 0 0 1.5 1.5h13A1.5 1.5 0 0 0 16 13V6a1.5 1.5 0 0 0-1.5-1.5h-13A1.5 1.5 0 0 0 0 6v7zm1.5.5A.5.5 0 0 1 1 13V6a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5h-13z"/>
                </svg>
            </span>
            Une sélection pensée pour tous les usages
        </h2>
        <p class="text-[#5a6a7e] text-[0.95rem] mb-4">
            Notre catalogue est structuré autour de quatre grandes catégories, afin de répondre à des
            besoins précis. Chaque produit est sélectionné selon des critères stricts : qualité des
            matériaux, durabilité, sécurité alimentaire et confort d'utilisation.
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-5">
            <div class="bg-[#f4f7fb] border border-[#dde4ed] rounded-xl p-5 flex flex-col gap-1.5 hover:border-[#5db8ff] hover:shadow-md transition-all">
                <span class="text-2xl leading-none">🧴</span>
                <span class="font-bold text-sm text-[#0d1b2a]">Plastique sans BPA</span>
                <span class="text-xs text-[#5a6a7e]">Légères et pratiques pour le quotidien</span>
            </div>
            <div class="bg-[#f4f7fb] border border-[#dde4ed] rounded-xl p-5 flex flex-col gap-1.5 hover:border-[#5db8ff] hover:shadow-md transition-all">
                <span class="text-2xl leading-none">⚙️</span>
                <span class="font-bold text-sm text-[#0d1b2a]">Acier inoxydable</span>
                <span class="text-xs text-[#5a6a7e]">Robustes et durables pour le sport intensif</span>
            </div>
            <div class="bg-[#f4f7fb] border border-[#dde4ed] rounded-xl p-5 flex flex-col gap-1.5 hover:border-[#5db8ff] hover:shadow-md transition-all">
                <span class="text-2xl leading-none">🌿</span>
                <span class="font-bold text-sm text-[#0d1b2a]">Verre</span>
                <span class="text-xs text-[#5a6a7e]">Saines et respectueuses de l'environnement</span>
            </div>
            <div class="bg-[#f4f7fb] border border-[#dde4ed] rounded-xl p-5 flex flex-col gap-1.5 hover:border-[#5db8ff] hover:shadow-md transition-all">
                <span class="text-2xl leading-none">🌡️</span>
                <span class="font-bold text-sm text-[#0d1b2a]">Thermos</span>
                <span class="text-xs text-[#5a6a7e]">Conservation optimale de la température</span>
            </div>
        </div>
    </div>

    {# 3. Approche durable #}
    <div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
        <h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
            <span class="inline-flex items-center justify-center w-9 h-9 text-white rounded-xl shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 16c3.314 0 6-2 6-5.5 0-1.5-.5-4-2.5-6 .25 1.5-1.25 2-1.25 2C11 4 9 .5 6 0c.357 2 .5 4-2 6-1.25 1-2 2.729-2 4.5C2 14 4.686 16 8 16zm0-1c-1.657 0-3-1-3-2.75 0-.75.25-2 1.25-3C6.125 10 7 10.5 7 10.5c-.375-1.25.5-3.25 2-3.5-.179 1-.25 2 1 3 .625.5 1 1.364 1 2.25C11 14 9.657 15 8 15z"/>
                </svg>
            </span>
            Une approche responsable et durable
        </h2>
        <div class="inline-flex items-center gap-2 text-green-700 border border-green-200 rounded-lg px-3 py-2 text-sm font-semibold mb-4 bg-green-50">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/>
            </svg>
            Engagement éco-responsable
        </div>
        <p class="text-[#5a6a7e] text-[0.95rem]">
            Nous nous engageons à promouvoir des <strong>alternatives réutilisables</strong> afin de réduire
            l'utilisation du plastique à usage unique. Notre démarche s'inscrit dans une vision à long terme,
            où la performance sportive et le respect de l'environnement vont de pair.
        </p>
    </div>

    {# 4. Expérience utilisateur #}
    <div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
        <h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
            <span class="inline-flex items-center justify-center w-9 h-9 text-white rounded-xl shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                </svg>
            </span>
            Une expérience utilisateur fiable et transparente
        </h2>
        <p class="text-[#5a6a7e] text-[0.95rem] mb-4">Notre plateforme e-commerce est conçue pour offrir :</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-4 mb-4">
            <div class="flex items-start gap-3 p-3 bg-[#f4f7fb] rounded-xl border border-[#dde4ed]">
                <span class="w-6 h-6 bg-gradient-to-br from-[#1b8fe4] to-[#5db8ff] rounded-md flex items-center justify-center shrink-0 mt-0.5"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" class="w-3 h-3 text-white"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                <span class="text-sm text-[#5a6a7e] font-medium">Navigation claire et intuitive</span>
            </div>
            <div class="flex items-start gap-3 p-3 bg-[#f4f7fb] rounded-xl border border-[#dde4ed]">
                <span class="w-6 h-6 bg-gradient-to-br from-[#1b8fe4] to-[#5db8ff] rounded-md flex items-center justify-center shrink-0 mt-0.5"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" class="w-3 h-3 text-white"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                <span class="text-sm text-[#5a6a7e] font-medium">Panier simple et sécurisé</span>
            </div>
            <div class="flex items-start gap-3 p-3 bg-[#f4f7fb] rounded-xl border border-[#dde4ed]">
                <span class="w-6 h-6 bg-gradient-to-br from-[#1b8fe4] to-[#5db8ff] rounded-md flex items-center justify-center shrink-0 mt-0.5"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" class="w-3 h-3 text-white"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                <span class="text-sm text-[#5a6a7e] font-medium">Processus de commande fluide</span>
            </div>
            <div class="flex items-start gap-3 p-3 bg-[#f4f7fb] rounded-xl border border-[#dde4ed]">
                <span class="w-6 h-6 bg-gradient-to-br from-[#1b8fe4] to-[#5db8ff] rounded-md flex items-center justify-center shrink-0 mt-0.5"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" class="w-3 h-3 text-white"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                <span class="text-sm text-[#5a6a7e] font-medium">Livraison rapide</span>
            </div>
            <div class="flex items-start gap-3 p-3 bg-[#f4f7fb] rounded-xl border border-[#dde4ed]">
                <span class="w-6 h-6 bg-gradient-to-br from-[#1b8fe4] to-[#5db8ff] rounded-md flex items-center justify-center shrink-0 mt-0.5"><svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" class="w-3 h-3 text-white"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg></span>
                <span class="text-sm text-[#5a6a7e] font-medium">Politique de retour facile</span>
            </div>
        </div>
        <p class="text-[#5a6a7e] text-[0.95rem]">Chaque fonctionnalité est pensée pour garantir <strong>confiance, simplicité et transparence</strong>.</p>
    </div>

    {# 5. Architecture technique #}
    <div class="bg-white rounded-2xl border border-[#dde4ed] px-8 sm:px-12 py-10 mb-7 shadow-sm hover:shadow-md transition-shadow">
        <h2 class="flex items-center gap-3 text-xl font-bold text-[#0d1b2a] mb-4" style="font-family: 'Syne', sans-serif;">
            <span class="inline-flex items-center justify-center w-9 h-9 text-white rounded-xl shrink-0" style="background: linear-gradient(135deg, #1b8fe4, #5db8ff);">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M5 0a.5.5 0 0 1 .5.5V2h1V.5a.5.5 0 0 1 1 0V2h1V.5a.5.5 0 0 1 1 0V2h1V.5a.5.5 0 0 1 1 0V2A2.5 2.5 0 0 1 14 4.5h1.5a.5.5 0 0 1 0 1H14v1h1.5a.5.5 0 0 1 0 1H14v1h1.5a.5.5 0 0 1 0 1H14v1h1.5a.5.5 0 0 1 0 1H14A2.5 2.5 0 0 1 11.5 14v1.5a.5.5 0 0 1-1 0V14h-1v1.5a.5.5 0 0 1-1 0V14h-1v1.5a.5.5 0 0 1-1 0V14h-1v1.5a.5.5 0 0 1-1 0V14A2.5 2.5 0 0 1 2 11.5H.5a.5.5 0 0 1 0-1H2v-1H.5a.5.5 0 0 1 0-1H2v-1H.5a.5.5 0 0 1 0-1H2v-1H.5a.5.5 0 0 1 0-1H2A2.5 2.5 0 0 1 4.5 2V.5A.5.5 0 0 1 5 0z"/>
                </svg>
            </span>
            Un projet construit sur des bases solides
        </h2>
        <p class="text-[#5a6a7e] text-[0.95rem] mb-4">
            Ce site repose sur une architecture technique robuste, basée sur <strong>Symfony</strong> et
            <strong>Doctrine</strong>, avec une attention particulière portée aux piliers suivants :
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 my-4">
            <div class="text-center p-5 bg-[#f4f7fb] border border-[#dde4ed] rounded-xl hover:border-[#5db8ff] transition-colors">
                <div class="text-3xl mb-2">🔒</div>
                <div class="font-bold text-sm text-[#0d1b2a]">Sécurité des données</div>
            </div>
            <div class="text-center p-5 bg-[#f4f7fb] border border-[#dde4ed] rounded-xl hover:border-[#5db8ff] transition-colors">
                <div class="text-3xl mb-2">♿</div>
                <div class="font-bold text-sm text-[#0d1b2a]">Accessibilité</div>
            </div>
            <div class="text-center p-5 bg-[#f4f7fb] border border-[#dde4ed] rounded-xl hover:border-[#5db8ff] transition-colors">
                <div class="text-3xl mb-2">⚡</div>
                <div class="font-bold text-sm text-[#0d1b2a]">Performance</div>
            </div>
            <div class="text-center p-5 bg-[#f4f7fb] border border-[#dde4ed] rounded-xl hover:border-[#5db8ff] transition-colors">
                <div class="text-3xl mb-2">🛠️</div>
                <div class="font-bold text-sm text-[#0d1b2a]">Maintenabilité</div>
            </div>
        </div>
        <p class="text-[#5a6a7e] text-[0.95rem]">
            Notre objectif est de proposer une plateforme évolutive, capable d'intégrer de nouvelles
            fonctionnalités tout en conservant une expérience fiable.
        </p>
    </div>

    {# 6. Vision — CTA banner #}
    <div class="relative overflow-hidden rounded-2xl px-10 py-10 text-center mb-7" style="background: linear-gradient(135deg, #0d1b2a, #163556);">
        <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 50% at 50% 100%, rgba(27,143,228,.3) 0%, transparent 70%);"></div>
        <div class="relative">
            <h2 class="text-2xl font-extrabold text-white mb-4" style="font-family: 'Syne', sans-serif;">Notre vision</h2>
            <p class="text-[0.97rem] max-w-lg mx-auto mb-6" style="color: rgba(255,255,255,.65);">
                À travers ce projet, nous souhaitons bâtir bien plus qu'une boutique en ligne : un espace
                de confiance dédié à l'hydratation, au sport et à un mode de vie responsable.
            </p>
            <a href="{{ path('app_contact') }}" class="inline-block bg-[#1b8fe4] text-white px-8 py-3 rounded-lg font-semibold text-[0.95rem] no-underline hover:bg-[#5db8ff] hover:-translate-y-0.5 transition-all">Nous contacter</a>
        </div>
    </div>

</main>

{% endblock %}
