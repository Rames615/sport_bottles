{% extends 'base.html.twig' %}

{% block title %}Mentions légales – Sports Bottles{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #0d1b2a;
            --accent: #1b8fe4;
            --accent-light: #5db8ff;
            --surface: #f4f7fb;
            --text: #1a2535;
            --muted: #5a6a7e;
            --white: #ffffff;
            --border: #dde4ed;
        }
        body { background: var(--surface); color: var(--text); line-height: 1.7; font-size: 1rem; }
        .page-hero { background: linear-gradient(135deg, var(--navy) 0%, #163556 100%); padding: 4rem 2rem 3.5rem; text-align: center; position: relative; overflow: hidden; }
        .page-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 60% at 50% 120%, rgba(27,143,228,.35) 0%, transparent 70%); }
        .page-hero .tag { display: inline-block; background: rgba(27,143,228,.18); border: 1px solid rgba(93,184,255,.35); color: var(--accent-light); font-size: .75rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; padding: .35rem .9rem; border-radius: 2rem; margin-bottom: 1.2rem; position: relative; }
        .page-hero h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(2rem, 5vw, 3rem); color: var(--white); position: relative; line-height: 1.15; }
        .page-hero p { color: rgba(255,255,255,.6); margin-top: .75rem; font-size: .95rem; position: relative; }
        .content-wrap { max-width: 820px; margin: 0 auto; padding: 3.5rem 2rem 5rem; }
        .legal-card { background: var(--white); border-radius: 16px; border: 1px solid var(--border); padding: 2.8rem 3rem; margin-bottom: 1.75rem; box-shadow: 0 2px 12px rgba(0,0,0,.05); transition: box-shadow .25s; }
        .legal-card:hover { box-shadow: 0 6px 28px rgba(0,0,0,.09); }
        .legal-card h2 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.25rem; color: var(--navy); margin-bottom: 1rem; display: flex; align-items: center; gap: .65rem; }
        .legal-card h2 .num { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; background: linear-gradient(135deg, var(--accent), var(--accent-light)); color: var(--white); border-radius: 8px; font-size: .8rem; font-weight: 700; flex-shrink: 0; }
        .legal-card p { color: var(--muted); font-size: .95rem; margin-bottom: .85rem; }
        .legal-card p:last-child { margin-bottom: 0; }
        .legal-card ul { list-style: none; padding: 0; margin: .5rem 0 .85rem; }
        .legal-card ul li { color: var(--muted); font-size: .95rem; padding: .3rem 0 .3rem 1.4rem; position: relative; }
        .legal-card ul li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: .85rem; }
        .update-notice { background: linear-gradient(135deg, rgba(27,143,228,.08), rgba(93,184,255,.06)); border: 1px solid rgba(27,143,228,.2); border-radius: 10px; padding: 1rem 1.4rem; font-size: .88rem; color: var(--muted); text-align: center; margin-bottom: 2.5rem; }
        .update-notice strong { color: var(--accent); }
        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem 2rem; margin: .75rem 0; }
        .info-label { font-size: .88rem; font-weight: 600; color: var(--navy); padding: .4rem 0; border-bottom: 1px solid var(--border); }
        .info-value { font-size: .88rem; color: var(--muted); padding: .4rem 0; border-bottom: 1px solid var(--border); }
        @media (max-width: 600px) { .legal-card { padding: 1.75rem 1.4rem; } .info-grid { grid-template-columns: 1fr; } .info-value, .info-label { border-bottom: none; } }
    </style>
{% endblock %}

{% block body %}

{# ── HERO ── #}
<section class="page-hero mt-5">
    <div class="tag">Légal</div>
    <h1>Mentions légales</h1>
    <p>Dernière mise à jour : {{ "now"|date("d F Y") }}</p>
</section>

{# ── CONTENT ── #}
<main class="content-wrap">
    <p class="update-notice">
        Conformément aux dispositions de la <strong>loi n° 2004-575 du 21 juin 2004</strong> pour la
        confiance en l'économie numérique (LCEN), les informations suivantes sont portées à la connaissance
        des utilisateurs du site www.sportsbottles.fr.
    </p>

    <div class="legal-card">
        <h2><span class="num">1</span>Éditeur du site</h2>
        <p>Le site www.sportsbottles.fr est édité par la société :</p>
        <div class="info-grid">
            <span class="info-label">Raison sociale</span>
            <span class="info-value">Sports Bottles SAS</span>
            <span class="info-label">Forme juridique</span>
            <span class="info-value">Société par actions simplifiée (SAS)</span>
            <span class="info-label">Capital social</span>
            <span class="info-value">10 000 €</span>
            <span class="info-label">Siège social</span>
            <span class="info-value">12 rue des Sportifs, 75001 Paris, France</span>
            <span class="info-label">SIREN</span>
            <span class="info-value">123 456 789</span>
            <span class="info-label">SIRET</span>
            <span class="info-value">123 456 789 00012</span>
            <span class="info-label">N° TVA intracommunautaire</span>
            <span class="info-value">FR 12 123456789</span>
            <span class="info-label">RCS</span>
            <span class="info-value">Paris B 123 456 789</span>
            <span class="info-label">Téléphone</span>
            <span class="info-value">+33 (0)1 23 45 67 89</span>
            <span class="info-label">E-mail</span>
            <span class="info-value">contact@sportsbottles.fr</span>
        </div>
        <p>Directeur de la publication : Jean Dupont, Président de Sports Bottles SAS.</p>
    </div>

    <div class="legal-card">
        <h2><span class="num">2</span>Hébergement</h2>
        <p>Le site www.sportsbottles.fr est hébergé par :</p>
        <div class="info-grid">
            <span class="info-label">Hébergeur</span>
            <span class="info-value">OVH SAS</span>
            <span class="info-label">Adresse</span>
            <span class="info-value">2 rue Kellermann, 59100 Roubaix, France</span>
            <span class="info-label">Téléphone</span>
            <span class="info-value">+33 (0)9 72 10 10 07</span>
            <span class="info-label">Site web</span>
            <span class="info-value">www.ovhcloud.com</span>
        </div>
    </div>

    <div class="legal-card">
        <h2><span class="num">3</span>Propriété intellectuelle</h2>
        <p>L'ensemble du contenu du site www.sportsbottles.fr (textes, images, graphismes, logo, icônes,
        sons, logiciels…) est la propriété exclusive de Sports Bottles SAS, à l'exception des éléments
