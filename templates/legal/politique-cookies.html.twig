{% extends 'base.html.twig' %}

{% block title %}Politique de cookies – Sports Bottles{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #0d1b2a;
            --accent: #1b8fe4;
            --accent-light: #5db8ff;
            --surface: #f4f7fb;
            --text: #1a2535;
            --muted: #5a6a7e;
            --white: #ffffff;
            --border: #dde4ed;
        }
        body { background: var(--surface); color: var(--text); line-height: 1.7; font-size: 1rem; }
        .page-hero { background: linear-gradient(135deg, var(--navy) 0%, #163556 100%); padding: 4rem 2rem 3.5rem; text-align: center; position: relative; overflow: hidden; }
        .page-hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 60% at 50% 120%, rgba(27,143,228,.35) 0%, transparent 70%); }
        .page-hero .tag { display: inline-block; background: rgba(27,143,228,.18); border: 1px solid rgba(93,184,255,.35); color: var(--accent-light); font-size: .75rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; padding: .35rem .9rem; border-radius: 2rem; margin-bottom: 1.2rem; position: relative; }
        .page-hero h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(2rem, 5vw, 3rem); color: var(--white); position: relative; line-height: 1.15; }
        .page-hero p { color: rgba(255,255,255,.6); margin-top: .75rem; font-size: .95rem; position: relative; }
        .content-wrap { max-width: 820px; margin: 0 auto; padding: 3.5rem 2rem 5rem; }
        .legal-card { background: var(--white); border-radius: 16px; border: 1px solid var(--border); padding: 2.8rem 3rem; margin-bottom: 1.75rem; box-shadow: 0 2px 12px rgba(0,0,0,.05); transition: box-shadow .25s; }
        .legal-card:hover { box-shadow: 0 6px 28px rgba(0,0,0,.09); }
        .legal-card h2 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1.25rem; color: var(--navy); margin-bottom: 1rem; display: flex; align-items: center; gap: .65rem; }
        .legal-card h2 .num { display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; background: linear-gradient(135deg, var(--accent), var(--accent-light)); color: var(--white); border-radius: 8px; font-size: .8rem; font-weight: 700; flex-shrink: 0; }
        .legal-card p { color: var(--muted); font-size: .95rem; margin-bottom: .85rem; }
        .legal-card p:last-child { margin-bottom: 0; }
        .legal-card ul { list-style: none; padding: 0; margin: .5rem 0 .85rem; }
        .legal-card ul li { color: var(--muted); font-size: .95rem; padding: .3rem 0 .3rem 1.4rem; position: relative; }
        .legal-card ul li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: .85rem; }
        .update-notice { background: linear-gradient(135deg, rgba(27,143,228,.08), rgba(93,184,255,.06)); border: 1px solid rgba(27,143,228,.2); border-radius: 10px; padding: 1rem 1.4rem; font-size: .88rem; color: var(--muted); text-align: center; margin-bottom: 2.5rem; }
        .update-notice strong { color: var(--accent); }
        .cookie-table { width: 100%; border-collapse: collapse; margin: 1rem 0 .5rem; font-size: .88rem; }
        .cookie-table th { background: var(--navy); color: var(--white); padding: .65rem 1rem; text-align: left; font-family: 'Syne', sans-serif; font-weight: 600; font-size: .82rem; letter-spacing: .05em; }
        .cookie-table th:first-child { border-radius: 8px 0 0 0; }
        .cookie-table th:last-child { border-radius: 0 8px 0 0; }
        .cookie-table td { padding: .6rem 1rem; border-bottom: 1px solid var(--border); color: var(--muted); vertical-align: top; }
        .cookie-table tr:last-child td { border-bottom: none; }
        .cookie-table tr:nth-child(even) td { background: var(--surface); }
        .badge { display: inline-block; padding: .2rem .6rem; border-radius: 4px; font-size: .75rem; font-weight: 600; }
        .badge-essential { background: rgba(34,197,94,.12); color: #16a34a; }
        .badge-analytics { background: rgba(245,158,11,.12); color: #d97706; }
        .badge-marketing { background: rgba(239,68,68,.1); color: #dc2626; }
        @media (max-width: 600px) { .legal-card { padding: 1.75rem 1.4rem; } .cookie-table { font-size: .8rem; } .cookie-table th, .cookie-table td { padding: .5rem .65rem; } }
    </style>
{% endblock %}

{% block body %}

{# ── HERO ── #}
<section class="page-hero mt-5">
    <div class="tag">Légal</div>
    <h1>Politique de cookies</h1>
    <p>Dernière mise à jour : {{ "now"|date("d F Y") }}</p>
</section>

{# ── CONTENT ── #}
<main class="content-wrap">
    <p class="update-notice">
        Cette page explique comment <strong>Sports Bottles</strong> utilise les cookies et technologies
        similaires, conformément au RGPD et aux recommandations de la CNIL.
    </p>

    <div class="legal-card">
        <h2><span class="num">1</span>Qu'est-ce qu'un cookie ?</h2>
        <p>Un cookie est un petit fichier texte déposé sur votre terminal (ordinateur, smartphone, tablette)
        lors de la visite d'un site internet. Il permet au site de mémoriser des informations sur votre visite,
        comme votre langue préférée et d'autres paramètres, afin de faciliter votre prochaine visite et de
        rendre le site plus utile.</p>
        <p>Les cookies ne peuvent pas endommager votre appareil et ne contiennent aucune information
        personnelle directement identifiable.</p>
    </div>

    <div class="legal-card">
        <h2><span class="num">2</span>Types de cookies utilisés</h2>
        <p>Nous utilisons les catégories de cookies suivantes sur notre site :</p>
        <table class="cookie-table">
            <thead>
                <tr>
                    <th>Nom du cookie</th>
                    <th>Type</th>
                    <th>Durée</th>
                    <th>Finalité</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><code>session_id</code></td>
                    <td><span class="badge badge-essential">Essentiel</span></td>
                    <td>Session</td>
                    <td>Maintien de la session utilisateur</td>
                </tr>
                <tr>
                    <td><code>cart_token</code></td>
                    <td><span class="badge badge-essential">Essentiel</span></td>
                    <td>7 jours</td>
                    <td>Sauvegarde du panier d'achat</td>
                </tr>
                <tr>
                    <td><code>consent_choice</code></td>
                    <td><span class="badge badge-essential">Essentiel</span></td>
                    <td>12 mois</td>
                    <td>Mémorisation de vos préférences cookies</td>
                </tr>
                <tr>
                    <td><code>_ga</code></td>
                    <td><span class="badge badge-analytics">Analytique</span></td>
                    <td>2 ans</td>
                    <td>Google Analytics – distinction des visiteurs</td>
                </tr>
                <tr>
                    <td><code>_gid</code></td>
                    <td><span class="badge badge-analytics">Analytique</span></td>
                    <td>24 h</td>
                    <td>Google Analytics – statistiques de session</td>
                </tr>
                <tr>
                    <td><code>_fbp</code></td>
                    <td><span class="badge badge-marketing">Marketing</span></td>
                    <td>90 jours</td>
                    <td>Meta Pixel – suivi des conversions publicitaires</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="legal-card">
        <h2><span class="num">3</span>Cookies essentiels</h2>
        <p>Ces cookies sont strictement nécessaires au fonctionnement du site. Ils ne peuvent pas être
        désactivés sans affecter les fonctionnalités de base, telles que la navigation, la connexion à votre
        compte ou la gestion du panier.</p>
        <p>Conformément à la réglementation, ces cookies ne nécessitent pas votre consentement préalable.</p>
    </div>

    <div class="legal-card">
        <h2><span class="num">4</span>Cookies analytiques</h2>
        <p>Ces cookies nous permettent de comprendre comment les visiteurs interagissent avec notre site en
        collectant et transmettant des informations de façon anonyme.</p>
        <ul>
            <li>Nombre de visiteurs et de pages vues.</li>
            <li>Source du trafic (moteur de recherche, réseaux sociaux…).</li>
            <li>Comportement de navigation (durée, parcours, taux de rebond).</li>
        </ul>
        <p>Ces cookies sont déposés uniquement avec votre consentement.</p>
    </div>

    <div class="legal-card">
        <h2><span class="num">5</span>Cookies marketing</h2>
        <p>Ces cookies sont utilisés pour vous proposer des publicités pertinentes sur nos sites partenaires.
        Ils permettent de mesurer l'efficacité de nos campagnes publicitaires et de limiter le nombre
        d'affichages d'une même annonce.</p>
        <p>Ils sont déposés uniquement avec votre consentement explicite et peuvent être retirés à tout moment
        depuis le bandeau de gestion des cookies.</p>
    </div>

    <div class="legal-card">
        <h2><span class="num">6</span>Gestion de vos préférences</h2>
        <p>Vous pouvez à tout moment modifier vos préférences en matière de cookies via :</p>
        <ul>
            <li>Le bandeau de consentement disponible en bas de page.</li>
            <li>Les paramètres de votre navigateur (Internet Explorer, Firefox, Chrome, Safari…).</li>
            <li>Les outils de désinscription proposés directement par les plateformes tierces.</li>
        </ul>
        <p>Attention : le refus de certains cookies peut affecter votre expérience de navigation et limiter
        l'accès à certaines fonctionnalités du site.</p>
    </div>
</main>

{% endblock %}
