{% extends 'base.html.twig' %}

{% block title %}Tableau de bord admin - Sports Bottles{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.admin-dashboard {
    margin-top: 70px;
    padding: 2rem 1rem;
}

.admin-cards .card {
    border: 0;
    border-radius: .75rem;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    height: 100%;
    transition: transform .15s ease, box-shadow .15s ease;
}

.admin-cards .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
}

.admin-cards .icon {
    font-size: 1.8rem;
    line-height: 1;
}

@media (max-width: 768px) {
    .admin-dashboard {
        margin-top: 60px;
    }
}
</style>

{% endblock %}

{% block body %}
<div class="container admin-dashboard">
    <h1 class="mb-4">Tableau de bord</h1>

     {# Composant réutilisable #}
     {% include 'components/_flash_messages.html.twig' %}

    <div class="row admin-cards g-3 mb-4">
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-primary"><i class="bi bi-people-fill" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Utilisateurs</div>
                        <div class="h4 mb-0">{{ userCount }}</div>
                    </div>
                </div>
                <a href="/admin/user" class="stretched-link"></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-success"><i class="bi bi-box-seam-fill" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Produits</div>
                        <div class="h4 mb-0">{{ productCount }}</div>
                    </div>
                </div>
                <a href="/admin/product" class="stretched-link"></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-warning"><i class="bi bi-tags-fill" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Categories</div>
                        <div class="h4 mb-0">{{ categoryCount }}</div>
                    </div>
                </div>
                <a href="/admin/category" class="stretched-link"></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-danger"><i class="bi bi-cart-fill" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Paniers</div>
                        <div class="h4 mb-0">{{ cartCount }}</div>
                    </div>
                </div>
                <a href="/admin/cart" class="stretched-link"></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-secondary"><i class="bi bi-receipt-cutoff" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Commandes</div>
                        <div class="h4 mb-0">{{ orderCount }}</div>
                    </div>
                </div>
                <a href="/admin/order" class="stretched-link"></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-info"><i class="bi bi-percent" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Promotions</div>
                        <div class="h4 mb-0">{{ promotionCount }}</div>
                    </div>
                </div>
                <a href="/admin/promotion" class="stretched-link"></a>
            </div>
        </div>
    </div>

    {# Ajouter la section pour les graphiques et statistiques détaillées #}
    <div class="row">
        <div class="col-12 col-lg-6 mb-4">
            <div class="card p-3 h-100">
                <h5>Ventes par catégorie</h5>
                <canvas id="salesByCategoryChart" height="200"></canvas> 

</div>
{% endblock %}
