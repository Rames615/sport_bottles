{% extends 'base.html.twig' %}

{% block title %}Tableau de bord admin - Sports Bottles{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.admin-dashboard {
    margin-top: 70px;
    padding: 2rem 1rem;
}

.admin-cards .card {
    border: 0;
    border-radius: .75rem;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    height: 100%;
    transition: transform .15s ease, box-shadow .15s ease;
}

.admin-cards .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.12);
}

.admin-cards .icon {
    font-size: 1.8rem;
    line-height: 1;
}

.admin-section-card {
    border: 0;
    border-radius: .9rem;
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.08);
}

.section-title {
    font-weight: 700;
    margin-bottom: .25rem;
}

.section-subtitle {
    color: #6c757d;
    margin-bottom: 1rem;
    font-size: .95rem;
}

.stats-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: .75rem;
}

.stat-item {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: .7rem;
    padding: .75rem .9rem;
    background: #fff;
}

.stat-label {
    display: block;
    color: #6c757d;
    font-size: .85rem;
}

.stat-value {
    display: block;
    font-size: 1.2rem;
    font-weight: 700;
}

.chart-wrapper {
    position: relative;
    min-height: 280px;
}

@media (max-width: 768px) {
    .admin-dashboard {
        margin-top: 60px;
    }

    .stats-list {
        grid-template-columns: 1fr;
    }

    .chart-wrapper {
        min-height: 240px;
    }
}
</style>

{% endblock %}

{% block body %}
<div class="container admin-dashboard" id="adminDashboardData"
    data-user-count="{{ userCount }}"
    data-product-count="{{ productCount }}"
    data-category-count="{{ categoryCount }}"
    data-cart-count="{{ cartCount }}"
    data-order-count="{{ orderCount }}"
    data-promotion-count="{{ promotionCount }}">
    <h1 class="mb-4">Tableau de bord</h1>

     {# Composant réutilisable #}
     {% include 'components/_flash_messages.html.twig' %}

    <div class="row admin-cards g-3 mb-4">
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-primary"><i class="bi bi-people-fill" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Utilisateurs</div>
                        <div class="h4 mb-0">{{ userCount }}</div>
                    </div>
                </div>
                <a href="/admin/user" class="stretched-link"></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-success"><i class="bi bi-box-seam-fill" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Produits</div>
                        <div class="h4 mb-0">{{ productCount }}</div>
                    </div>
                </div>
                <a href="/admin/product" class="stretched-link"></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-warning"><i class="bi bi-tags-fill" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Categories</div>
                        <div class="h4 mb-0">{{ categoryCount }}</div>
                    </div>
                </div>
                <a href="/admin/category" class="stretched-link"></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-danger"><i class="bi bi-cart-fill" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Paniers</div>
                        <div class="h4 mb-0">{{ cartCount }}</div>
                    </div>
                </div>
                <a href="/admin/cart" class="stretched-link"></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-secondary"><i class="bi bi-receipt-cutoff" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Commandes</div>
                        <div class="h4 mb-0">{{ orderCount }}</div>
                    </div>
                </div>
                <a href="/admin/order" class="stretched-link"></a>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card p-3 position-relative">
                <div class="d-flex align-items-center">
                    <div class="me-3 icon text-info"><i class="bi bi-percent" aria-hidden="true"></i></div>
                    <div>
                        <div class="text-muted">Promotions</div>
                        <div class="h4 mb-0">{{ promotionCount }}</div>
                    </div>
                </div>
                <a href="/admin/promotion" class="stretched-link"></a>
            </div>
        </div>
    </div>

    {% set totalEntities = userCount + productCount + categoryCount + cartCount + orderCount + promotionCount %}
    {% set conversionRate = cartCount > 0 ? ((orderCount / cartCount) * 100) : 0 %}
    {% set productPerCategory = categoryCount > 0 ? (productCount / categoryCount) : 0 %}

    <div class="row g-4">
        <div class="col-12 col-xl-7">
            <div class="card admin-section-card p-3 p-md-4 h-100">
                <h5 class="section-title">Repartition generale</h5>
                <p class="section-subtitle">Vue d'ensemble des entites de la plateforme.</p>
                <div class="chart-wrapper">
                    <canvas id="overviewChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="card admin-section-card p-3 p-md-4 h-100">
                <h5 class="section-title">Statistiques detaillees</h5>
                <p class="section-subtitle">Indicateurs operationnels rapides.</p>

                <div class="stats-list mb-4">
                    <div class="stat-item">
                        <span class="stat-label">Total entites</span>
                        <span class="stat-value">{{ totalEntities }}</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Ratio commandes/paniers</span>
                        <span class="stat-value">{{ conversionRate|number_format(1, ',', ' ') }} %</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Produits par categorie</span>
                        <span class="stat-value">{{ productPerCategory|number_format(1, ',', ' ') }}</span>
                    </div>
                    <div class="stat-item">
                        <span class="stat-label">Promotions actives (total)</span>
                        <span class="stat-value">{{ promotionCount }}</span>
                    </div>
                </div>

                <div class="chart-wrapper">
                    <canvas id="funnelChart"></canvas>
                </div>
            </div>
        </div>
    </div>
{% endblock %}


{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="{{ asset('scripts/dashboard.js') }}"></script>
{% endblock %}
