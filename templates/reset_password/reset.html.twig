{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - Sports Bottles{% endblock %}

{% block body %}
<div class="login-page">
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <h1 class="login-title">Nouveau mot de passe</h1>
                <p class="login-subtitle">Choisissez un nouveau mot de passe pour votre compte</p>
            </div>

            {% for message in app.flashes('danger') %}
                <div class="alert alert-danger" role="alert" aria-live="assertive">
                    <strong>Erreur :</strong> {{ message }}
                </div>
            {% endfor %}

            {{ form_start(resetPasswordForm, {attr: {class: 'login-form', novalidate: 'novalidate'}}) }}

                <div class="mb-3">
                    <label for="{{ resetPasswordForm.plainPassword.first.vars.id }}"
                           class="form-label required">
                        Nouveau mot de passe
                    </label>
                    {{ form_widget(resetPasswordForm.plainPassword.first, {
                        attr: {
                            class: 'form-control',
                            placeholder: '••••••••',
                            autofocus: true
                        }
                    }) }}
                    <span class="form-text text-muted">Minimum 6 caractères</span>
                    {{ form_errors(resetPasswordForm.plainPassword.first) }}
                </div>

                <div class="mb-3">
                    <label for="{{ resetPasswordForm.plainPassword.second.vars.id }}"
                           class="form-label required">
                        Confirmer le mot de passe
                    </label>
                    {{ form_widget(resetPasswordForm.plainPassword.second, {
                        attr: {
                            class: 'form-control',
                            placeholder: '••••••••'
                        }
                    }) }}
                    {{ form_errors(resetPasswordForm.plainPassword.second) }}
                </div>

                {{ form_errors(resetPasswordForm.plainPassword) }}

                <button type="submit" class="btn btn-primary w-100 py-2 mt-2"
                        aria-label="Réinitialiser le mot de passe">
                    Réinitialiser le mot de passe
                </button>

            {{ form_end(resetPasswordForm) }}

            <div class="register-section">
                <p class="register-text">Vous vous souvenez de votre mot de passe ?</p>
                <a href="{{ path('app_login') }}" class="btn btn-outline-primary w-100"
                   aria-label="Retour à la connexion">
                    Retour à la connexion
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
