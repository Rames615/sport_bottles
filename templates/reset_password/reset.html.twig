{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - Sports Bottles
{% endblock %}

{% block body %}
	<div class="min-h-[calc(100vh-12vh)] flex items-center justify-center px-5 py-10 mt-[70px]" style="background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%)">
		<div class="w-full max-w-[450px] mx-auto">
			<div class="bg-white rounded-2xl shadow-[0_10px_40px_rgba(0,0,0,.1)] px-10 py-10 w-full animate-slide-up">

				<div class="text-center mb-8">
					<h1 class="text-[2rem] font-semibold text-main m-0 mb-2">Nouveau mot de passe</h1>
					<p class="text-[0.95rem] text-muted m-0">Choisissez un nouveau mot de passe pour votre compte</p>
				</div>

				{% for message in app.flashes('danger') %}
					<div class="bg-red-50 border-2 border-red-400 rounded-lg px-4 py-3 text-red-700 mb-4 text-[0.95rem]" role="alert" aria-live="assertive">
						<strong>Erreur :</strong>
						{{ message }}
					</div>
				{% endfor %}

				{{ form_start(resetPasswordForm, {attr: {class: 'flex flex-col gap-5', novalidate: 'novalidate'}}) }}

				<div class="flex flex-col gap-1">
					<label for="{{ resetPasswordForm.plainPassword.first.vars.id }}" class="font-semibold text-[#333] text-[0.95rem]">
						Nouveau mot de passe
						<span class="text-[#e74c3c]">*</span>
					</label>
					{{ form_widget(resetPasswordForm.plainPassword.first, {
                        attr: {
                            class: 'w-full px-4 py-3 border-2 border-[#e0e0e0] rounded-lg text-base bg-white text-[#333] transition-all duration-300 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10',
                            placeholder: '••••••••',
                            autofocus: true
                        }
                    }) }}
					<span class="text-xs text-[#888]">Minimum 6 caractères</span>
					<div class="text-sm text-red-500 [&_ul]:list-none [&_ul]:p-0 [&_ul]:m-0">
						{{ form_errors(resetPasswordForm.plainPassword.first) }}
					</div>
				</div>

				<div class="flex flex-col gap-1">
					<label for="{{ resetPasswordForm.plainPassword.second.vars.id }}" class="font-semibold text-[#333] text-[0.95rem]">
						Confirmer le mot de passe
						<span class="text-[#e74c3c]">*</span>
					</label>
					{{ form_widget(resetPasswordForm.plainPassword.second, {
                        attr: {
                            class: 'w-full px-4 py-3 border-2 border-[#e0e0e0] rounded-lg text-base bg-white text-[#333] transition-all duration-300 focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10',
                            placeholder: '••••••••'
                        }
                    }) }}
					<div class="text-sm text-red-500 [&_ul]:list-none [&_ul]:p-0 [&_ul]:m-0">
						{{ form_errors(resetPasswordForm.plainPassword.second) }}
					</div>
				</div>

				<div class="text-sm text-red-500 [&_ul]:list-none [&_ul]:p-0 [&_ul]:m-0">
					{{ form_errors(resetPasswordForm.plainPassword) }}
				</div>

				<button type="submit" class="w-full py-3 mt-1 bg-primary text-white font-semibold rounded-lg border-0 cursor-pointer hover:bg-[#196350] transition-colors focus:outline-none focus:ring-2 focus:ring-primary/30" aria-label="Réinitialiser le mot de passe">
					Réinitialiser le mot de passe
				</button>

				{{ form_end(resetPasswordForm) }}

				<div class="text-center mt-8 pt-8 border-t border-[#E2E8F0]">
					<p class="text-muted text-[0.95rem] mb-4">Vous vous souvenez de votre mot de passe ?</p>
					<a href="{{ path('app_login') }}" class="block w-full px-4 py-3 text-center border-2 border-primary text-primary bg-transparent rounded-lg no-underline transition-colors hover:bg-primary hover:text-white font-semibold" aria-label="Retour à la connexion">
						Retour à la connexion
					</a>
				</div>

			</div>
		</div>
	</div>
{% endblock %}
