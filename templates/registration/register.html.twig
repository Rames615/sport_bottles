{% extends 'base.html.twig' %}

{% block title %}Inscription - Sports Bottles
{% endblock %}

{% block body %}
	<div class="min-h-[calc(100vh-12vh)] flex items-center justify-center px-5 py-10 mt-[70px]" style="background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%)">
		<div class="w-full max-w-[500px] mx-auto">
			<div class="bg-white rounded-xl shadow-[0_10px_40px_rgba(0,0,0,.1)] p-10 animate-slide-up">
				<div class="text-center mb-8">
					<h1 class="text-[2rem] font-bold text-[#333] m-0 mb-2 leading-[1.2]">Créer un compte</h1>
					<p class="text-base text-[#666] m-0">Rejoignez-nous pour accéder à nos services</p>
				</div>

				{% for flash_error in app.flashes('verify_email_error') %}
					<div class="bg-[#ffeeee] border-2 border-[#e74c3c] rounded-lg px-4 py-4 text-[#c0392b] mb-6 text-[0.95rem]" role="alert" aria-live="assertive">
						<strong>Erreur :</strong>
						{{ flash_error }}
					</div>
				{% endfor %}

				{% if app.user %}
					<div class="bg-green-50 border-2 border-green-400 rounded-lg px-4 py-3 text-green-700 mb-6 text-[0.95rem]" role="status">
						Vous êtes connecté en tant que
						<strong>{{ app.user.userIdentifier }}</strong>,
						<a href="{{ logout_path() }}" class="underline" aria-label="Se déconnecter">Se déconnecter</a>
					</div>
				{% endif %}

				<form method="post" class="flex flex-col gap-6 mb-8" novalidate>
					{% if registrationForm._token is defined %}
						<input type="hidden" name="{{ registrationForm._token.vars.full_name }}" value="{{ registrationForm._token.vars.value }}">
					{% endif %}

					<div class="flex flex-col gap-1">
						<label for="registration_form_email" class="font-semibold text-[#333] text-[0.95rem]">
							Email
							<span class="text-[#e74c3c]">*</span>
						</label>
						<input type="email" id="registration_form_email" name="{{ registrationForm.email.vars.full_name }}" value="{{ registrationForm.email.vars.value ?? '' }}" class="w-full px-4 py-3 text-base border-2 rounded-lg transition-all duration-300 bg-white text-[#333] focus:outline-none focus:border-[#667eea] focus:ring focus:ring-[#667eea]/10 {% if registrationForm.email.vars.errors is not empty %}border-[#e74c3c] bg-[#fff5f5]{% else %}border-[#e0e0e0]{% endif %}" autocomplete="email" required autofocus aria-required="true" aria-invalid="{% if registrationForm.email.vars.errors is not empty %}true{% else %}false{% endif %}" aria-describedby="{% if registrationForm.email.vars.errors is not empty %}email-error{% endif %}" placeholder="votre@email.com">
						{% if registrationForm.email.vars.errors is not empty %}
							<span id="email-error" class="text-sm text-[#e74c3c] block" role="alert">
								{% for error in registrationForm.email.vars.errors %}
									{{ error.message }}
								{% endfor %}
							</span>
						{% endif %}
					</div>

					<div class="flex flex-col gap-1">
						<label for="registration_form_plainPassword" class="font-semibold text-[#333] text-[0.95rem]">
							Mot de passe
							<span class="text-[#e74c3c]">*</span>
						</label>
						<input type="password" id="registration_form_plainPassword" name="{{ registrationForm.plainPassword.vars.full_name }}" class="w-full px-4 py-3 text-base border-2 rounded-lg transition-all duration-300 bg-white text-[#333] focus:outline-none focus:border-[#667eea] focus:ring focus:ring-[#667eea]/10 {% if registrationForm.plainPassword.vars.errors is not empty %}border-[#e74c3c] bg-[#fff5f5]{% else %}border-[#e0e0e0]{% endif %}" autocomplete="new-password" required aria-required="true" aria-invalid="{% if registrationForm.plainPassword.vars.errors is not empty %}true{% else %}false{% endif %}" aria-describedby="password-hint{% if registrationForm.plainPassword.vars.errors is not empty %} password-error{% endif %}" placeholder="••••••••">
						<span id="password-hint" class="text-xs text-[#888]">Minimum 6 caractères</span>
						{% if registrationForm.plainPassword.vars.errors is not empty %}
							<span id="password-error" class="text-sm text-[#e74c3c] block" role="alert">
								{% for error in registrationForm.plainPassword.vars.errors %}
									{{ error.message }}
								{% endfor %}
							</span>
						{% endif %}
					</div>

					<div class="flex flex-col gap-1">
						<div class="flex items-start gap-3">
							<input type="checkbox" id="registration_form_agreeTerms" name="{{ registrationForm.agreeTerms.vars.full_name }}" value="1" {% if registrationForm.agreeTerms.vars.value %} checked {% endif %} required aria-required="true" aria-invalid="{% if registrationForm.agreeTerms.vars.errors is not empty %}true{% else %}false{% endif %}" aria-describedby="{% if registrationForm.agreeTerms.vars.errors is not empty %}terms-error{% endif %}" class="mt-1 w-4 h-4 accent-primary cursor-pointer">
							<label for="registration_form_agreeTerms" class="text-[0.95rem] text-[#333] cursor-pointer">
								J'accepte les
								<a href="#" class="text-primary underline" aria-label="Conditions d'utilisation">conditions d'utilisation</a>
								et la
								<a href="#" class="text-primary underline" aria-label="Politique de confidentialité">politique de confidentialité</a>
								<span class="text-[#e74c3c]">*</span>
							</label>
						</div>
						{% if registrationForm.agreeTerms.vars.errors is not empty %}
							<span id="terms-error" class="text-sm text-[#e74c3c] block" role="alert">
								{% for error in registrationForm.agreeTerms.vars.errors %}
									{{ error.message }}
								{% endfor %}
							</span>
						{% endif %}
					</div>

					<button type="submit" class="w-full px-6 py-[0.875rem] text-base font-semibold rounded-lg cursor-pointer transition-all duration-300 border-2 border-primary text-primary bg-white hover:bg-primary hover:text-white focus:outline-none min-h-[48px] flex items-center justify-center" aria-label="Créer un compte">
						S'inscrire
					</button>
				</form>

				<div class="text-center pt-6 border-t border-[#e0e0e0]">
					<p class="text-[0.95rem] text-[#666] mb-4">Vous avez déjà un compte ?</p>
					<a href="{{ path('app_login') }}" class="w-full px-6 py-[0.875rem] text-base font-semibold rounded-lg transition-all bg-primary text-white no-underline flex items-center justify-center hover:bg-[#156a52] mt-4" aria-label="Se connecter">
						Se connecter
					</a>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
