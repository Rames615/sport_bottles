{# templates/registration/confirmation_email.html.twig #}
{% extends 'emails/layout.html.twig' %}

{% block header_title %}Confirmez votre adresse email
{% endblock %}

{% block body %}
	<p>Bonjour,</p>

	<p>
		Merci de vous être inscrit sur
		<strong>SportBottles</strong>
		!
		    Pour activer votre compte, veuillez confirmer votre adresse email
		    en cliquant sur le bouton ci-dessous :
	</p>

	<p style="text-align: center; margin: 28px 0;">
		<a href="{{ signedUrl|raw }}" class="btn">Confirmer mon email</a>
	</p>

	<p>
		Ce lien expirera dans
		{{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}.
	</p>

	<hr class="divider">

	<p style="font-size: 13px; color: #6b7280;">
		Si vous n'avez pas créé de compte sur SportBottles, vous pouvez ignorer cet email.
	</p>

	<p>À bientôt,<br><strong>L'équipe SportBottles</strong>
	</p>
{% endblock %}
