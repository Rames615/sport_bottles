{# Reassurance Card Component #}

<div class="group flex flex-col items-center text-center px-6 py-7 bg-white rounded-xl border border-[#e2ede9] shadow-[0_2px_8px_rgba(0,0,0,.04)] transition-all duration-[250ms] overflow-hidden relative hover:-translate-y-1 hover:shadow-[0_8px_20px_rgba(31,122,99,.12)] hover:border-primary/30">
    <span class="text-[2rem] leading-none mb-4 inline-flex items-center justify-center w-10 h-10 rounded-[10px] transition-all duration-[250ms] group-hover:scale-[1.08]" style="background: linear-gradient(135deg, #e8f5f1 0%, #f0f8f6 100%);">{{ icon }}</span>
    <div>
        <p class="text-base font-semibold text-main tracking-[-0.3px] leading-[1.4] transition-colors duration-[250ms] group-hover:text-primary m-0 font-display">{{ title }}</p>
        <p class="text-[.72rem] text-[#6b8c7d] leading-[1.4] m-0">{{ description }}</p>
    </div>
</div>
