{# templates/emails/order/confirmation.html.twig #}
{% extends 'emails/layout.html.twig' %}

{% block header_title %}Commande confirmée{% endblock %}

{% block body %}
  <p>Bonjour,</p>

  <p>
    Merci pour votre commande sur <strong>SportBottles</strong> !
    Votre paiement a été confirmé avec succès.
  </p>

  <table class="table">
    <tr>
      <td>Référence</td>
      <td><strong>{{ order.reference }}</strong></td>
    </tr>
    <tr>
      <td>Date</td>
      <td>{{ order.createdAt|date('d/m/Y à H:i') }}</td>
    </tr>
    <tr>
      <td>Statut</td>
      <td><span class="text-success fw-bold">Payée</span></td>
    </tr>
    {% if order.shippingAddress %}
    <tr>
      <td>Livraison</td>
      <td>{{ order.shippingAddress }}</td>
    </tr>
    {% endif %}
  </table>

  {% if items is defined and items|length > 0 %}
  <hr class="divider">
  <p><strong>Détail de votre commande :</strong></p>

  <table class="table">
    <thead>
      <tr>
        <th>Produit</th>
        <th style="text-align:center;">Qté</th>
        <th style="text-align:right;">Prix unit.</th>
        <th style="text-align:right;">Sous-total</th>
      </tr>
    </thead>
    <tbody>
      {% for item in items %}
      <tr>
        <td>{{ item.name }}</td>
        <td style="text-align:center;">{{ item.quantity }}</td>
        <td style="text-align:right;">{{ item.unitPrice|number_format(2, ',', ' ') }} EUR</td>
        <td style="text-align:right;">{{ item.subtotal|number_format(2, ',', ' ') }} EUR</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr>
        <td colspan="3" style="text-align:right;"><strong>Total</strong></td>
        <td style="text-align:right;"><strong>{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} EUR</strong></td>
      </tr>
    </tfoot>
  </table>
  {% else %}
  <hr class="divider">
  <table class="table">
    <tr>
      <td>Total</td>
      <td><strong>{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} EUR</strong></td>
    </tr>
  </table>
  {% endif %}

  <hr class="divider">

  <p>
    Si vous avez des questions concernant votre commande, n'hésitez pas à
    <a href="mailto:contact@sportsbottles.fr">nous contacter</a>.
  </p>

  <p>À très bientôt,<br><strong>L'équipe SportBottles</strong></p>
{% endblock %}
