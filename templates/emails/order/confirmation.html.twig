{# templates/emails/order/confirmation.html.twig #}
{% extends 'emails/layout.html.twig' %}

{% block header_title %}Commande confirmée{% endblock %}

{% block body %}
  <p>Bonjour,</p>

  <p>
    Merci pour votre commande sur <strong>SportBottles</strong> !
    Votre paiement a été confirmé avec succès.
  </p>

  <table class="meta">
    <tr>
      <td>Référence</td>
      <td><strong>{{ order.reference }}</strong></td>
    </tr>
    <tr>
      <td>Date</td>
      <td>{{ order.createdAt|date('d/m/Y à H:i') }}</td>
    </tr>
    <tr>
      <td>Statut</td>
      <td><span style="color:#16a34a;font-weight:600;">Payée</span></td>
    </tr>
    {% if order.shippingAddress %}
    <tr>
      <td>Livraison</td>
      <td>{{ order.shippingAddress }}</td>
    </tr>
    {% endif %}
  </table>

  {% if items is defined and items|length > 0 %}
  <hr class="divider">
  <p><strong>Détail de votre commande :</strong></p>

  <table style="width:100%;border-collapse:collapse;margin:16px 0;">
    <thead>
      <tr style="border-bottom:2px solid #e5e7eb;">
        <th style="text-align:left;padding:8px 4px;font-size:13px;color:#6b7280;">Produit</th>
        <th style="text-align:center;padding:8px 4px;font-size:13px;color:#6b7280;">Qté</th>
        <th style="text-align:right;padding:8px 4px;font-size:13px;color:#6b7280;">Prix unit.</th>
        <th style="text-align:right;padding:8px 4px;font-size:13px;color:#6b7280;">Sous-total</th>
      </tr>
    </thead>
    <tbody>
      {% for item in items %}
      <tr style="border-bottom:1px solid #f3f4f6;">
        <td style="padding:10px 4px;font-size:14px;color:#111827;">{{ item.name }}</td>
        <td style="padding:10px 4px;font-size:14px;color:#111827;text-align:center;">{{ item.quantity }}</td>
        <td style="padding:10px 4px;font-size:14px;color:#111827;text-align:right;">{{ item.unitPrice|number_format(2, ',', ' ') }} €</td>
        <td style="padding:10px 4px;font-size:14px;color:#111827;text-align:right;">{{ item.subtotal|number_format(2, ',', ' ') }} €</td>
      </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr style="border-top:2px solid #e5e7eb;">
        <td colspan="3" style="padding:12px 4px;font-size:15px;font-weight:700;text-align:right;">Total</td>
        <td style="padding:12px 4px;font-size:15px;font-weight:700;text-align:right;color:#0ea5e9;">{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €</td>
      </tr>
    </tfoot>
  </table>
  {% else %}
  <hr class="divider">
  <table class="meta">
    <tr>
      <td>Total</td>
      <td><strong style="color:#0ea5e9;">{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €</strong></td>
    </tr>
  </table>
  {% endif %}

  <hr class="divider">

  <p>
    Si vous avez des questions concernant votre commande, n'hésitez pas à
    <a href="mailto:contact@sportsbottles.fr">nous contacter</a>.
  </p>

  <p>À très bientôt,<br><strong>L'équipe SportBottles</strong></p>
{% endblock %}
