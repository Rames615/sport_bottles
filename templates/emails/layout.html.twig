{# templates/emails/layout.html.twig #}
<!DOCTYPE html>
<html lang="fr" xmlns:v="urn:schemas-microsoft-com:vml">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>{% block subject %}Email{% endblock %}</title>
  <style>
    *{box-sizing:border-box;margin:0;padding:0}
    body{background:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif}
    img{border:0;display:block;max-width:100%}
    a{color:#0ea5e9;text-decoration:none}
    a:hover{text-decoration:underline}

    .wrap{width:100%;background:#f4f4f5;padding:40px 16px}
    .container{max-width:600px;margin:0 auto}

    /* Header */
    .header{
      background:linear-gradient(135deg,#0ea5e9 0%,#0284c7 100%);
      border-radius:12px 12px 0 0;
      padding:36px 40px;
      text-align:center
    }
    .header h1{color:#fff;font-size:22px;font-weight:700;letter-spacing:-0.4px}
    .header .brand{display:inline-block;color:#fff;font-size:13px;font-weight:600;
      letter-spacing:2px;text-transform:uppercase;opacity:.75;margin-bottom:10px}

    /* Body */
    .body{background:#fff;padding:40px}
    .body p{font-size:15px;line-height:1.7;color:#374151;margin-bottom:16px}
    .body p:last-child{margin-bottom:0}

    /* Message box */
    .msg-box{
      background:#f0f9ff;
      border-left:4px solid #0ea5e9;
      border-radius:0 8px 8px 0;
      padding:20px 24px;
      margin:20px 0
    }
    .msg-box p{color:#0c4a6e;font-size:15px}

    /* Meta table */
    .meta{width:100%;border-collapse:collapse;margin:20px 0}
    .meta tr{border-bottom:1px solid #e5e7eb}
    .meta tr:last-child{border-bottom:none}
    .meta td{padding:9px 4px;font-size:14px;line-height:1.5;vertical-align:top}
    .meta td:first-child{color:#6b7280;font-weight:600;width:100px;white-space:nowrap}
    .meta td:last-child{color:#111827}

    /* Button */
    .btn{
      display:inline-block;
      background:linear-gradient(135deg,#0ea5e9,#0284c7);
      color:#fff !important;
      font-size:14px;font-weight:700;
      padding:13px 30px;
      border-radius:50px;
      text-decoration:none !important;
      margin:8px 0
    }

    .divider{border:none;border-top:1px solid #e5e7eb;margin:28px 0}

    /* Footer */
    .footer{
      background:#f9fafb;
      border-radius:0 0 12px 12px;
      border-top:1px solid #e5e7eb;
      padding:24px 40px;
      text-align:center
    }
    .footer p{font-size:12px;color:#9ca3af;line-height:1.6;margin-bottom:4px}
    .footer a{color:#9ca3af}

    @media(max-width:600px){
      .header,.body,.footer{padding:24px 20px}
      .header h1{font-size:18px}
    }
  </style>
</head>
<body>
<div class="wrap">
  <div class="container">

    <div class="header">
      <span class="brand">SportBottles</span>
      <h1>{% block header_title %}Message{% endblock %}</h1>
    </div>

    <div class="body">
      {% block body %}{% endblock %}
    </div>

    <div class="footer">
      <p>© {{ "now"|date("Y") }} SportBottles — Tous droits réservés</p>
      <p><a href="mailto:contact@sportsbottles.fr">contact@sportsbottles.fr</a></p>
    </div>

  </div>
</div>
</body>
</html>
