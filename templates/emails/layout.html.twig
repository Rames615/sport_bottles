{# templates/emails/layout.html.twig #}
<!DOCTYPE html>
<html lang="fr" xmlns:v="urn:schemas-microsoft-com:vml">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>{% block subject %}Email{% endblock %}</title>
  <style>
    *{box-sizing:border-box}
    body{margin:0;background:#f1f5f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;color:#0f172a}
    a{color:#0d6efd;text-decoration:none}
    a:hover{text-decoration:underline}
    img{border:0;display:block;max-width:100%}

    .container-fluid{width:100%;padding:32px 14px}
    .row{width:100%;margin:0 auto}
    .col-12{width:100%;max-width:680px;margin:0 auto}

    .card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;box-shadow:0 10px 30px rgba(15,23,42,.06)}
    .card-header{padding:30px 24px;background:linear-gradient(145deg, #bbf7d0 0%, #4ade80 100%);display:flex;flex-direction:column;align-items:center;justify-content:center}
    .card-body{padding:28px 24px}
    .card-footer{padding:20px 24px;text-align:center;background:#f8fafc;border-top:1px solid #e2e8f0}

    .brand{display:block;color:#e0f2fe;font-weight:700;letter-spacing:1.4px;font-size:12px;text-transform:uppercase;margin-bottom:8px}
    .title{margin:0;color:#fff;font-size:22px;line-height:1.25;font-weight:800}

    .lead, p{font-size:15px;line-height:1.7;color:#334155;margin:0 0 14px}

    .table{width:100%;border-collapse:collapse;margin:16px 0;border:1px solid #e2e8f0;border-radius:10px;overflow:hidden}
    .table td,.table th{padding:10px 12px;border-bottom:1px solid #e2e8f0;font-size:14px;vertical-align:top}
    .table tr:last-child td{border-bottom:none}
    .table th{background:#f8fafc;color:#64748b;font-weight:700;text-align:left}
    .table td:first-child{color:#64748b;font-weight:700;width:130px;white-space:nowrap}

    .alert{padding:14px 16px;border-radius:10px;border:1px solid #dbeafe;background:#eff6ff;color:#1e3a8a;margin:16px 0}
    .btn{display:inline-block;padding:10px 18px;border-radius:8px;font-weight:700;text-decoration:none !important}
    .btn-primary{background:#0d6efd;color:#fff !important}
    .divider{border:none;border-top:1px solid #e2e8f0;margin:22px 0}

    .text-center{text-align:center}
    .text-muted{color:#94a3b8}
    .text-success{color:#16a34a}
    .fw-bold{font-weight:700}

    @media (max-width:600px){
      .container-fluid{padding:18px 10px}
      .card-header,.card-body,.card-footer{padding:20px 16px}
      .title{font-size:18px}
      .table td,.table th{padding:8px 10px;font-size:13px}
      .table td:first-child{width:auto}
    }
  </style>
</head>
<body>
  <div class="container-fluid">
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-header" style="text-align: center; padding: 20px;">
  
            <img 
              src="{{ absolute_url(asset('logo_gold.png')) }}"
              alt="SportBottles"
              style="max-height: 70px; margin-bottom: 10px;"
            >
          
            <h1 class="title" style="margin: 0;">
              {% block header_title %}Message{% endblock %}
            </h1>
          
          </div>

          <div class="card-body">
            {% block body %}{% endblock %}
          </div>

          <div class="card-footer">
            <p class="text-muted">© {{ "now"|date("Y") }} SportBottles - Tous droits reserves</p>
            <p><a href="mailto:contact@sportsbottles.fr">contact@sportsbottles.fr</a></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
