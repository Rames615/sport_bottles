{# templates/contact/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Contactez-nous
{% endblock %}

{% block body %}
	<div class="max-w-2xl mx-auto px-4 sm:px-6 py-20 mt-20">

		<div class="text-center mb-6">
			<h1 class="text-3xl font-bold text-gray-900">Contactez-nous</h1>
			<p class="text-gray-500">Une question ? Écrivez-nous, nous répondons sous 24–48 h.</p>
		</div>

		{# ── Flash messages ───────────────────────────────── #}
		{% for label, messages in app.flashes %}
			{% for message in messages %}
				{% set cls = label == 'success' ? 'bg-green-50 border-green-200 text-green-700' : 'bg-red-50 border-red-200 text-red-700' %}
				<div class="flex items-center gap-2 p-4 mb-3 border rounded-lg {{ cls }}" role="alert">
					<i class="bi bi-{{ label == 'success' ? 'check-circle-fill' : 'exclamation-triangle-fill' }}"></i>
					<span class="flex-1 text-sm">{{ message }}</span>
					<button type="button" class="ml-auto opacity-60 hover:opacity-100 text-current leading-none" data-bs-dismiss="alert" aria-label="Close">✕</button>
				</div>
			{% endfor %}
		{% endfor %}

		<div class="bg-white rounded-2xl border border-gray-100 shadow-sm">
			<div class="p-6 md:p-8">

				{{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

				<div class="grid grid-cols-1 md:grid-cols-2 gap-4">

					<div>
						{{ form_label(form.name, null, {label_attr: {class: 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
						{{ form_widget(form.name, {attr: {
                class: 'w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-primary ' ~ (not form.name.vars.valid ? 'border-red-500 focus:ring-red-500' : 'border-gray-300'),
                placeholder: 'Jean Dupont'
              }}) }}
						{% if not form.name.vars.valid %}
							<div class="text-sm text-red-600 mt-1">
								{% for error in form.name.vars.errors %}
									{{ error.message }}
								{% endfor %}
							</div>
						{% endif %}
					</div>

					<div>
						{{ form_label(form.email, null, {label_attr: {class: 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
						{{ form_widget(form.email, {attr: {
                class: 'w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-primary ' ~ (not form.email.vars.valid ? 'border-red-500 focus:ring-red-500' : 'border-gray-300'),
                placeholder: 'jean@exemple.fr'
              }}) }}
						{% if not form.email.vars.valid %}
							<div class="text-sm text-red-600 mt-1">
								{% for error in form.email.vars.errors %}
									{{ error.message }}
								{% endfor %}
							</div>
						{% endif %}
					</div>

					<div class="md:col-span-2">
						{{ form_label(form.subject, null, {label_attr: {class: 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
						{{ form_widget(form.subject, {attr: {
                class: 'w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-primary ' ~ (not form.subject.vars.valid ? 'border-red-500 focus:ring-red-500' : 'border-gray-300'),
                placeholder: 'Objet de votre message'
              }}) }}
						{% if not form.subject.vars.valid %}
							<div class="text-sm text-red-600 mt-1">
								{% for error in form.subject.vars.errors %}
									{{ error.message }}
								{% endfor %}
							</div>
						{% endif %}
					</div>

					<div class="md:col-span-2">
						{{ form_label(form.message, null, {label_attr: {class: 'block text-sm font-semibold text-gray-700 mb-1'}}) }}
						{{ form_widget(form.message, {attr: {
                class: 'w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-primary ' ~ (not form.message.vars.valid ? 'border-red-500 focus:ring-red-500' : 'border-gray-300'),
                placeholder: 'Votre message…',
                rows: 6
              }}) }}
						{% if not form.message.vars.valid %}
							<div class="text-sm text-red-600 mt-1">
								{% for error in form.message.vars.errors %}
									{{ error.message }}
								{% endfor %}
							</div>
						{% endif %}
					</div>

					<div class="md:col-span-2 pt-1">
						<button type="submit" class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary text-white text-sm font-semibold rounded-md hover:bg-green-dark transition-colors">
							<i class="bi bi-send-fill"></i>Envoyer le message
						</button>
					</div>

				</div>

				{{ form_end(form) }}

			</div>
		</div>

	</div>
{% endblock %}
