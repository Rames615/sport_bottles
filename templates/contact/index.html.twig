{# templates/contact/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Contactez-nous{% endblock %}

{% block body %}
<div class="container py-5 mt-5">
  <div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">

      <div class="text-center mb-4">
        <h1 class="fw-bold">Contactez-nous</h1>
        <p class="text-muted">Une question ? Écrivez-nous, nous répondons sous 24–48 h.</p>
      </div>

      {# ── Flash messages ───────────────────────────────── #}
      {% for label, messages in app.flashes %}
        {% for message in messages %}
          <div class="alert alert-{{ label == 'error' ? 'danger' : 'success' }} alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-{{ label == 'success' ? 'check-circle-fill' : 'exclamation-triangle-fill' }}"></i>
            <span>{{ message }}</span>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
          </div>
        {% endfor %}
      {% endfor %}

      <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4 p-md-5">

          {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

          <div class="row g-3">

            <div class="col-md-6">
              {{ form_label(form.name, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
              {{ form_widget(form.name, {attr: {
                class: 'form-control' ~ (not form.name.vars.valid ? ' is-invalid' : ''),
                placeholder: 'Jean Dupont'
              }}) }}
              {% if not form.name.vars.valid %}
                <div class="invalid-feedback">
                  {% for error in form.name.vars.errors %}{{ error.message }}{% endfor %}
                </div>
              {% endif %}
            </div>

            <div class="col-md-6">
              {{ form_label(form.email, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
              {{ form_widget(form.email, {attr: {
                class: 'form-control' ~ (not form.email.vars.valid ? ' is-invalid' : ''),
                placeholder: 'jean@exemple.fr'
              }}) }}
              {% if not form.email.vars.valid %}
                <div class="invalid-feedback">
                  {% for error in form.email.vars.errors %}{{ error.message }}{% endfor %}
                </div>
              {% endif %}
            </div>

            <div class="col-12">
              {{ form_label(form.subject, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
              {{ form_widget(form.subject, {attr: {
                class: 'form-control' ~ (not form.subject.vars.valid ? ' is-invalid' : ''),
                placeholder: 'Objet de votre message'
              }}) }}
              {% if not form.subject.vars.valid %}
                <div class="invalid-feedback">
                  {% for error in form.subject.vars.errors %}{{ error.message }}{% endfor %}
                </div>
              {% endif %}
            </div>

            <div class="col-12">
              {{ form_label(form.message, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
              {{ form_widget(form.message, {attr: {
                class: 'form-control' ~ (not form.message.vars.valid ? ' is-invalid' : ''),
                placeholder: 'Votre message…',
                rows: 6
              }}) }}
              {% if not form.message.vars.valid %}
                <div class="invalid-feedback">
                  {% for error in form.message.vars.errors %}{{ error.message }}{% endfor %}
                </div>
              {% endif %}
            </div>

            <div class="col-12 pt-1">
              <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold">
                <i class="bi bi-send-fill me-2"></i>Envoyer le message
              </button>
            </div>

          </div>

          {{ form_end(form) }}

        </div>
      </div>

    </div>
  </div>
</div>
{% endblock %}
