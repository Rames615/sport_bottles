{% extends 'base.html.twig' %}

{% block title %}Méthode de paiement — Sports Bottles{% endblock %}

{% block body %}

<div class="pm-page">

    <!-- ═══ LEFT COLUMN ═══ -->
    <div class="pm-left">

        <h1 class="pm-section-title">
            Paiement sécurisé
            <small>Choisissez votre méthode de paiement</small>
        </h1>

        <!-- Method tabs -->
        <div class="method-tabs">
            <button class="method-tab active" data-method="card" onclick="switchMethod('card', this)">
                <span class="tab-icon"><i class="bi bi-credit-card-2-front-fill"></i></span>
                Carte bancaire
            </button>
            <button class="method-tab" data-method="wallet" onclick="switchMethod('wallet', this)">
                <span class="tab-icon"><i class="bi bi-phone-fill"></i></span>
                Wallet
            </button>
            <button class="method-tab" data-method="transfer" onclick="switchMethod('transfer', this)">
                <span class="tab-icon"><i class="bi bi-bank2"></i></span>
                Virement
            </button>
        </div>

        <!-- ══ CARD METHOD ══ -->
        {#
            No local card form here — Stripe Checkout handles all card collection securely.
            This panel simply redirects the user to Stripe via a single POST to /checkout/pay.
        #}
        <div id="method-card" class="alt-panel active">

            <!-- Accepted cards -->
            <div class="accepted-cards">
                <span class="card-logo visa">VISA</span>
                <span class="card-logo mc">MASTERCARD</span>
                <span class="card-logo amex">AMEX</span>
                <span class="card-logo cb">CB</span>
            </div>

            <!-- Stripe badge -->
            <div class="stripe-badge">
                <i class="bi bi-shield-lock-fill"></i>
                Paiement traité par Stripe — certifié PCI DSS niveau 1
            </div>

            <div class="pm-panel">

                <!-- Info: redirect to Stripe -->
                <div class="stripe-info-box">
                    <i class="bi bi-box-arrow-up-right"></i>
                    <p>
                        Vous serez redirigé vers la <strong>page de paiement sécurisée Stripe</strong>
                        pour saisir vos informations bancaires. Nous ne stockons aucune donnée de carte.
                    </p>
                </div>

                <!-- What to expect -->
                <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:8px;">
                    <div style="display:flex;align-items:center;gap:10px;font-size:.83rem;color:var(--muted);">
                        <i class="bi bi-1-circle-fill" style="color:var(--green);flex-shrink:0;"></i>
                        Cliquez sur le bouton ci-dessous
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;font-size:.83rem;color:var(--muted);">
                        <i class="bi bi-2-circle-fill" style="color:var(--green);flex-shrink:0;"></i>
                        Saisissez vos informations de carte sur la page Stripe
                    </div>
                    <div style="display:flex;align-items:center;gap:10px;font-size:.83rem;color:var(--muted);">
                        <i class="bi bi-3-circle-fill" style="color:var(--green);flex-shrink:0;"></i>
                        Vous êtes redirigé vers la confirmation de commande
                    </div>
                </div>

                <form action="{{ path('checkout_pay') }}" method="post">
                    <input type="hidden" name="_token" value="{{ csrf_token('checkout_pay') }}">
                    <button type="submit" class="btn-pay" id="btn-stripe-pay"
                            onclick="this.disabled=true; this.innerHTML='<span class=\'spinner-border spinner-border-sm\' role=\'status\'></span> Redirection…'; this.form.submit();">
                        <i class="bi bi-lock-fill"></i>
                        Payer par carte
                        <span>{{ total|number_format(2, ',', ' ') }} €</span>
                    </button>
                </form>
            </div>
        </div>

        <!-- ══ WALLET METHOD ══ -->
        <div id="method-wallet" class="alt-panel">
            <div class="pm-panel">
                <p style="font-size:.85rem;color:var(--muted);margin-bottom:20px;line-height:1.6;">
                    Payez en un clic avec votre portefeuille numérique. Aucune saisie de carte requise.
                </p>

                <button class="wallet-btn apple" onclick="handleWalletPay('Apple Pay')">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                    </svg>
                    Payer avec Apple Pay
                </button>

                <button class="wallet-btn google" onclick="handleWalletPay('Google Pay')">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.47 2.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    Payer avec Google Pay
                </button>

                <button class="wallet-btn paypal" onclick="handleWalletPay('PayPal')">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="#009cde">
                        <path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516a.56.56 0 0 0 .554.647h3.882c.46 0 .85-.334.922-.788.06-.26.76-4.852.816-5.09a.932.932 0 0 1 .923-.788h.58c3.76 0 6.705-1.528 7.565-5.946.36-1.847.174-3.388-.777-4.471z"/>
                    </svg>
                    Payer avec PayPal
                </button>

                <div class="divider-or">ou utiliser une carte</div>
                <button class="wallet-btn" onclick="switchMethod('card', document.querySelector('[data-method=card]'))">
                    <i class="bi bi-credit-card-fill"></i>
                    Payer par carte bancaire
                </button>
            </div>
        </div>

        <!-- ══ TRANSFER METHOD ══ -->
        <div id="method-transfer" class="alt-panel">
            <div class="pm-panel">
                <p style="font-size:.85rem;color:var(--muted);margin-bottom:22px;line-height:1.6;">
                    Effectuez un virement bancaire. Votre commande sera validée dès réception du paiement (1–2 jours ouvrés).
                </p>

                <div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:20px;">
                    <div style="margin-bottom:14px;">
                        <div class="form-label" style="margin-bottom:4px;">IBAN</div>
                        <div style="font-family:var(--mono);font-size:.9rem;color:var(--text);letter-spacing:1px;">
                            FR76 3000 6000 0112 3456 7890 189
                            <button onclick="copyIBAN()" style="background:none;border:none;color:var(--green);cursor:pointer;margin-left:8px;font-size:.8rem;">
                                <i class="bi bi-clipboard" id="copy-icon"></i>
                            </button>
                        </div>
                    </div>
                    <div style="margin-bottom:14px;">
                        <div class="form-label" style="margin-bottom:4px;">BIC / SWIFT</div>
                        <div style="font-family:var(--mono);font-size:.9rem;color:var(--text);">AGRIFRPP</div>
                    </div>
                    <div>
                        <div class="form-label" style="margin-bottom:4px;">Référence à indiquer</div>
                        <div style="font-family:var(--mono);font-size:.9rem;color:var(--green);">
                            SB-{{ 'now'|date('YmdHis') }}
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-start gap-3 mt-3"
                     style="background:rgba(52,209,138,.05);border:1px solid rgba(52,209,138,.15);border-radius:10px;padding:14px 16px;">
                    <i class="bi bi-info-circle-fill" style="color:var(--green);margin-top:2px;flex-shrink:0;"></i>
                    <p style="font-size:.8rem;color:var(--muted);margin:0;line-height:1.5;">
                        Votre commande sera réservée pendant <strong style="color:var(--text);">72 heures</strong>.
                        Passé ce délai, elle sera automatiquement annulée si le paiement n'est pas reçu.
                    </p>
                </div>

                {#
                    Bank transfer posts to checkout_confirm_post (non-Stripe route)
                    which sets order status to "paid" immediately for manual processing.
                #}
                <form action="{{ path('checkout_confirm_post') }}" method="post" style="margin-top:20px;">
                    <input type="hidden" name="_token" value="{{ csrf_token('checkout_pay') }}">
                    <button type="submit" class="btn-pay">
                        <i class="bi bi-bank2"></i>
                        Confirmer la commande par virement
                    </button>
                </form>
            </div>
        </div>

        <!-- Security strip -->
        <div class="security-strip mt-3">
            <div class="security-item"><i class="bi bi-shield-check-fill"></i> SSL 256-bit</div>
            <div class="security-item"><i class="bi bi-patch-check-fill"></i> 3D Secure</div>
            <div class="security-item"><i class="bi bi-lock-fill"></i> PCI DSS</div>
            <div class="security-item"><i class="bi bi-stripe" style="color:#635bff;"></i> Powered by Stripe</div>
        </div>
    </div>

    <!-- ═══ RIGHT COLUMN — Order summary ═══ -->
    <div class="pm-right">
        <div class="summary-box">
            <div class="summary-header">
                <i class="bi bi-bag-check-fill" style="color:var(--green);"></i>
                Votre commande
            </div>
            <div class="summary-body">
                {% for item in cart.items %}
                <div class="summary-item">
                    <div>
                        <div class="summary-item-name">{{ item.product.designation }}</div>
                        <div class="summary-item-qty">Qté : {{ item.quantity }}</div>
                    </div>
                    <div class="summary-item-price">{{ item.subtotal|number_format(2, ',', ' ') }} €</div>
                </div>
                {% endfor %}

                <hr class="summary-divider">

                <div class="summary-row">
                    <span>Sous-total</span>
                    <span>{{ total|number_format(2, ',', ' ') }} €</span>
                </div>
                <div class="summary-row">
                    <span>Livraison</span>
                    <span style="color:var(--green);">Gratuite</span>
                </div>
                <div class="summary-row">
                    <span>TVA (20%)</span>
                    <span>incluse</span>
                </div>

                <div class="summary-total">
                    <span class="summary-total-label">Total</span>
                    <span class="summary-total-amount">{{ total|number_format(2, ',', ' ') }} €</span>
                </div>

                <div class="badge-secure">
                    <i class="bi bi-shield-lock-fill"></i>
                    Paiement 100% sécurisé
                </div>
            </div>
        </div>

        <!-- Back link -->
        <div class="text-center mt-3">
            <a href="{{ path('checkout_confirm') }}"
               style="font-size:.8rem;color:var(--muted);text-decoration:none;display:inline-flex;align-items:center;gap:5px;">
                <i class="bi bi-arrow-left"></i> Modifier ma commande
            </a>
        </div>
    </div>

</div>

<script>
// ── Method switcher ──
function switchMethod(method, btn) {
    document.querySelectorAll('.method-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.alt-panel').forEach(p => p.classList.remove('active'));

    document.querySelector('[data-method=' + method + ']').classList.add('active');
    document.getElementById('method-' + method).classList.add('active');
}

// ── Wallet pay placeholder ──
function handleWalletPay(method) {
    alert(method + ' : intégration disponible via Stripe Elements ou le SDK natif.');
}

// ── Copy IBAN ──
function copyIBAN() {
    navigator.clipboard.writeText('FR7630006000011234567890189').then(() => {
        const icon = document.getElementById('copy-icon');
        icon.className = 'bi bi-clipboard-check';
        icon.style.color = 'var(--green)';
        setTimeout(() => { icon.className = 'bi bi-clipboard'; icon.style.color = ''; }, 2000);
    });
}
</script>

{% endblock %}
