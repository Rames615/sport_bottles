{% extends 'base.html.twig' %}

{% block title %}Validation de la commande - Sports Bottles{% endblock %}

{% block body %}
<div class="cart-container container" style="margin-top: 100px; margin-bottom: 50px;">
    <div class="cart-header">
        <h1><i class="bi bi-check-circle"></i> Validation de la commande</h1>
    </div>

    <div class="row">
        <div class="col-lg-8 col-md-12 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-list-check"></i> Récapitulatif de votre commande</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Produit</th>
                                    <th class="text-center">Quantité</th>
                                    <th class="text-end">Prix unitaire</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in cart.items %}
                                    <tr>
                                        <td>
                                            <strong>{{ item.product.designation }}</strong>
                                            {% if item.product.capacity %}
                                                <br><small class="text-muted">{{ item.product.capacity }}</small>
                                            {% endif %}
                                        </td>
                                        <td class="text-center"><span class="badge bg-secondary">{{ item.quantity }}</span></td>
                                        <td class="text-end">{{ item.unitPrice|number_format(2, ',', ' ') }} €</td>
                                        <td class="text-end fw-bold">{{ item.subtotal|number_format(2, ',', ' ') }} €</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 col-md-12">
            <div class="cart-summary">
                <div class="summary-card">
                    <h4 class="mb-3"><i class="bi bi-calculator"></i> Total</h4>
                    <hr>
                    
                    <div class="summary-row">
                        <span>Sous-total</span>
                        <span class="fw-bold">{{ total|number_format(2, ',', ' ') }} €</span>
                    </div>
                    
                    <div class="summary-row">
                        <span>Livraison</span>
                        <span class="text-success fw-bold">Gratuite</span>
                    </div>
                    
                    <hr>
                    
                    <div class="summary-total">
                        <span>Total</span>
                        <span>{{ total|number_format(2, ',', ' ') }} €</span>
                    </div>
                    
                    <div class="alert alert-info mt-3">
                        <i class="bi bi-info-circle"></i> <small>Le paiement sera disponible prochainement</small>
                    </div>
                    
                    <a href="{{ path('app_cartindex') }}" class="btn btn-outline-primary w-100">
                        <i class="bi bi-arrow-left"></i> Retour au panier
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap Icons CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
{% endblock %}
