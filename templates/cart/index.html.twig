{% extends 'base.html.twig' %}

{% block title %}Mon panier - Sports Bottles{% endblock %}

{% block body %}
<div class="container cart-container" style="margin-top: 100px; margin-bottom: 50px;">

    <div class="cart-header mb-4">
        <h1><i class="bi bi-cart3"></i> Mon panier</h1>
    </div>

    {# Composant réutilisable #}
    {% include 'components/_flash_messages.html.twig' %}

    {# Message après validation de commande #}
    {% if app.session.get('order_success') %}
        <div class="alert alert-success text-center shadow-sm">
            <h5 class="mb-2">✅ Merci d’avoir passé commande sur le site Sports Bottles.</h5>
            <a href="{{ path('app_home') }}" class="btn btn-primary mt-2">
                Retour à l’accueil
            </a>
        </div>
    {% endif %}

    {% if cart.items|length == 0 %}
        <div class="text-center py-5">
            <p class="fs-4">🛒 Votre panier est vide</p>
            <a href="{{ path('app_product') }}" class="btn btn-primary">
                Continuer vos achats
            </a>
        </div>
    {% else %}

        <div class="row g-4">

            {# =========================
               COLONNE PRODUITS
            ========================== #}
            <div class="col-lg-8">

                {% for item in cart.items %}
                    <div class="card mb-3 shadow-sm">
                        <div class="card-body">

                            <div class="row align-items-center">

                                <div class="col-md-3 text-center">
                                    {% set categorySlug = item.product.category ? item.product.category.slug : null %}
                                    {% set hasNestedImagePath = item.product.imgPath and ('/' in item.product.imgPath) %}
                                    {% set imagePath = item.product.imgPath
                                        ? (hasNestedImagePath
                                            ? 'products_images/' ~ item.product.imgPath
                                            : (categorySlug
                                                ? 'products_images/' ~ categorySlug ~ '/' ~ item.product.imgPath
                                                : 'products_images/' ~ item.product.imgPath))
                                        : 'logo.png'
                                    %}

                                    <img src="{{ asset(imagePath) }}"
                                         alt="{{ item.product.designation }}"
                                         class="img-fluid rounded"
                                         style="max-height:100px;object-fit:contain;"
                                         onerror="this.onerror=null; this.src='{{ asset('logo.png') }}';">
                                </div>

                                <div class="col-md-4">
                                    <h5>{{ item.product.designation }}</h5>

                                    {% if item.product.capacity %}
                                        <small class="text-muted">
                                            Capacité : {{ item.product.capacity }}
                                        </small>
                                    {% endif %}

                                    <p class="fw-bold text-primary mt-2">
                                        {{ (item.unitPrice|default(item.product.price))|number_format(2, ',', ' ') }} €
                                    </p>
                                </div>

                                <div class="col-md-3 text-center">

                                    <div class="input-group justify-content-center" style="max-width:140px;margin:auto;">

                                        <form method="post" action="{{ path('app_cartupdate', {itemId: item.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('cart_update') }}">
                                            <input type="hidden" name="quantity" value="{{ item.quantity - 1 }}">
                                            <button class="btn btn-outline-secondary"
                                                {{ item.quantity <= 1 ? 'disabled' : '' }}>
                                                <i class="bi bi-dash"></i>
                                            </button>
                                        </form>

                                        <input type="text"
                                               class="form-control text-center"
                                               value="{{ item.quantity }}"
                                               readonly>

                                        <form method="post" action="{{ path('app_cartupdate', {itemId: item.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('cart_update') }}">
                                            <input type="hidden" name="quantity" value="{{ item.quantity + 1 }}">
                                            <button class="btn btn-outline-secondary">
                                                <i class="bi bi-plus"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>

                                <div class="col-md-2 text-end">
                                    <p class="fw-bold">
                                        {{ item.subtotal|number_format(2, ',', ' ') }} €
                                    </p>

                                    <form method="post" action="{{ path('app_cartremove', {itemId: item.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('cart_remove') }}">
                                        <button class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>

                            </div>
                        </div>
                    </div>
                {% endfor %}

            </div>

            {# =========================
               COLONNE RÉSUMÉ
            ========================== #}
            <div class="col-lg-4">
                <div class="card shadow-sm p-4">

                    <h4>Résumé de la commande</h4>
                    <hr>

                    <div class="d-flex justify-content-between mb-2">
                        <span>
                            Sous-total ({{ cart.items|length }} article{{ cart.items|length > 1 ? 's' : '' }})
                        </span>
                        <span class="fw-bold">
                            {{ total|number_format(2, ',', ' ') }} €
                        </span>
                    </div>

                    <div class="d-flex justify-content-between mb-3">
                        <span>Livraison</span>
                        <span class="text-success fw-bold">Gratuite</span>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between fs-5 fw-bold mb-3">
                        <span>Total</span>
                        <span>{{ total|number_format(2, ',', ' ') }} €</span>
                    </div>

                    <a href="{{ path('checkout_shipping') }}" class="btn btn-success w-100 mb-2">
                        <i class="bi bi-lock-fill"></i> Procéder au paiement
                    </a>

                    <a href="{{ path('app_product') }}" class="btn btn-outline-primary w-100 mb-2">
                        <i class="bi bi-arrow-left"></i> Continuer mes achats
                    </a>

                    <form method="post" action="{{ path('app_cartclear') }}" class="d-inline-block w-100">
                        <input type="hidden" name="_token" value="{{ csrf_token('cart_clear') }}">
                        <button type="submit" class="btn btn-outline-danger w-100" onclick="return confirm('Êtes-vous sûr de vouloir vider votre panier ?')">
                            <i class="bi bi-trash"></i> Vider le panier
                        </button>
                    </form>

                </div>
            </div>

        </div>

    {% endif %}
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
{% endblock %}