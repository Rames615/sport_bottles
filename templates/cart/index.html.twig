{% extends 'base.html.twig' %}

{% block title %}Mon panier - Sports Bottles
{% endblock %}

{% block body %}
	<div class="max-w-5xl mx-auto px-4 sm:px-6 mt-24 mb-12">

		<h1 class="text-2xl font-semibold font-display text-gray-900 mb-6 flex items-center gap-2">
			<i class="bi bi-cart3"></i>
			Mon panier
		</h1>

		{# Composant réutilisable #}
		{% include 'components/_flash_messages.html.twig' %}

		{# Message après validation de commande #}
		{% if app.session.get('order_success') %}
			<div class="p-4 bg-green-50 border border-green-200 text-green-700 rounded-lg text-center mb-4">
				<h5 class="text-base font-semibold mb-2">✅ Merci d'avoir passé commande sur le site Sports Bottles.</h5>
				<a href="{{ path('app_home') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-md hover:bg-green-dark transition-colors mt-2">
					Retour à l’accueil
				</a>
			</div>
		{% endif %}

		{% if cart.items|length == 0 %}
			<div class="text-center py-16">
				<p class="text-xl text-gray-600">🛒 Votre panier est vide</p>
				<a href="{{ path('app_product') }}" class="inline-flex items-center px-4 py-2 bg-primary text-white text-sm font-medium rounded-md hover:bg-green-dark transition-colors mt-4">
					Continuer vos achats
				</a>
			</div>
		{% else %}

			<div
				class="flex flex-col lg:flex-row gap-6">

				{# clone produit #}
				<div class="w-full lg:w-2/3">

					{% for item in cart.items %}
						<div class="bg-white rounded-xl border border-gray-100 shadow-sm mb-3">
							<div class="p-4">

								<div class="flex flex-col sm:flex-row items-center gap-4">

									<div class="w-full sm:w-1/5 text-center shrink-0">
										{% set imageFileName = item.product.imgPath ? (item.product.imgPath|split('/')|last) : null %}
										{% set imagePath = imageFileName ? 'products_images/' ~ imageFileName : 'logo.png' %}

										<img src="{{ asset(imagePath) }}" alt="{{ item.product.designation }}" class="w-full max-h-24 object-contain rounded" onerror="this.onerror=null; this.src='{{ asset('logo.png') }}';">
									</div>

									<div class="flex-1 min-w-0">
										<h5 class="text-base font-semibold text-gray-900 mb-1">{{ item.product.designation }}</h5>

										{% if item.product.capacity %}
											<small class="text-sm text-gray-500">
												Capacité :
												{{ item.product.capacity }}
											</small>
										{% endif %}

										<p class="font-semibold text-primary mt-2">
											{{ (item.unitPrice|default(item.product.price))|number_format(2, ',', ' ') }}
											€
										</p>
									</div>

									<div class="w-full sm:w-auto flex items-center justify-center">

										<div class="flex items-center max-w-[140px] mx-auto">

											<form method="post" action="{{ path('app_cartupdate', {itemId: item.id}) }}">
												<input type="hidden" name="_token" value="{{ csrf_token('cart_update') }}">
												<input type="hidden" name="quantity" value="{{ item.quantity - 1 }}">
												<button</i class="flex items-center justify-center w-8 h-8 border border-gray-300 text-gray-700 rounded-l hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed" {{ item.quantity <= 1 ? 'disabled' : '' }}> <i class="bi bi-dash"></i> </button> </form> <input type="text" class="w-10 h-8 border-y border-gray-300 text-center text-sm font-medium bg-white" value="{{ item.quantity }}" readonly> <form method="post" action="{{ path('app_cartupdate', {itemId: item.id}) }}"> <input type="hidden" name="_token" value="{{ csrf_token('cart_update') }}"> <input type="hidden" name="quantity" value="{{ item.quantity + 1 }}"> <button class="flex items-center justify-center w-8 h-8 border border-gray-300 text-gray-700 rounded-r hover:bg-gray-50"> <i class="bi bi-plus"></i> </button> </form> </div> </div> <div class="w-full sm:w-auto text-right"> <p class="font-semibold text-gray-900 mb-2"> {{ item.subtotal|number_format(2, ',', ' ') }} € </p> <form method="post" action="{{ path('app_cartremove', {itemId: item.id}) }}"> <input type="hidden" name="_token" value="{{ csrf_token('cart_remove') }}"> <button class="inline-flex items-center justify-center w-8 h-8 border border-red-200 text-red-600 rounded hover:bg-red-50 transition-colors"> <i class="bi bi-trash">></button>
											</form>
										</div>

									</div>
								</div>
							</div>
						{% endfor %}

					</div>

					{# clone résumé #}
					<div class="w-full lg:w-1/3">
						<div class="bg-white rounded-xl border border-gray-100 shadow-sm p-5">

							<h4 class="text-lg font-semibold font-display text-gray-900 mb-4">Résumé de la commande</h4>
							<hr class="border-t border-gray-100 my-3">

							<div class="flex justify-between text-sm mb-2">
								<span>
									Sous-total ({{ cart.items|length }}
									article{{ cart.items|length > 1 ? 's' : '' }})
								</span>
								<span class="font-semibold">
									{{ total|number_format(2, ',', ' ') }}
									€
								</span>
							</div>

							<div class="flex justify-between text-sm mb-3">
								<span>Livraison</span>
								<span class="text-green-600 font-semibold">Gratuite</span>
							</div>

							<hr class="border-t border-gray-100 my-3">

							<div class="flex justify-between text-base font-bold mb-4">
								<span>Total</span>
								<span>{{ total|number_format(2, ',', ' ') }}
									€</span>
							</div>

							<a href="{{ path('checkout_shipping') }}" class="flex w-full justify-center items-center gap-2 py-2.5 bg-green-600 text-white text-sm font-medium rounded-md hover:bg-green-700 transition-colors mb-2">
								<i class="bi bi-lock-fill"></i>
								Procéder au paiement
							</a>

							<a href="{{ path('app_product') }}" class="flex w-full justify-center items-center gap-2 py-2.5 border border-primary text-primary text-sm font-medium rounded-md hover:bg-primary/5 transition-colors mb-2">
								<i class="bi bi-arrow-left"></i>
								Continuer mes achats
							</a>

							<form method="post" action="{{ path('app_cartclear') }}" class="block w-full">
								<input type="hidden" name="_token" value="{{ csrf_token('cart_clear') }}">
								<button type="submit" class="flex w-full justify-center items-center gap-2 py-2.5 border border-red-300 text-red-600 text-sm font-medium rounded-md hover:bg-red-50 transition-colors" onclick="return confirm('Êtes-vous sûr de vouloir vider votre panier ?')">
									<i class="bi bi-trash"></i>
									Vider le panier
								</button>
							</form>

						</div>
					</div>

				</div>

			{% endif %}
		</div>
	{% endblock %}
