{% extends 'base.html.twig' %}

{% block title %}Mon Panier - Sports Bottles{% endblock %}

{% block body %}
<div class="cart-container container-fluid container-lg" style="margin-top: 100px; margin-bottom: 50px;">
    <div class="cart-header">
        <h1><i class="bi bi-cart3"></i> Mon Panier</h1>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    {% if cart.items|length == 0 %}
        <div class="empty-cart-message">
            <p>🛒 Votre panier est vide</p>
            <a href="{{ path('app_product') }}" class="btn btn-primary">Continuer vos achats</a>
        </div>
    {% else %}
        <div class="row g-3 g-lg-4">
            <!-- Cart Items Column -->
            <div class="col-12 col-lg-8">
                <div class="cart-items">
                    {% for item in cart.items %}
                        <div class="cart-item card mb-3 shadow-sm">
                            <div class="card-body p-2 p-sm-3 p-md-4">
                                <!-- Mobile Layout: Stacked -->
                                <div class="d-lg-none">
                                    <div class="d-flex gap-2 mb-3">
                                        <!-- Product Image -->
                                        <div class="flex-shrink-0">
                                            {% if item.product %}
                                                {% set imagePath = item.product.imgPath ? 'products_images/' ~ item.product.category.slug ~ '/' ~ item.product.imgPath : 'logo.png' %}
                                                <img src="{{ asset(imagePath) }}" 
                                                     alt="{{ item.product.designation }}" 
                                                     class="img-fluid rounded"
                                                     style="max-height: 100px; max-width: 100px; width: auto; height: auto; object-fit: contain;"
                                                     onerror="this.onerror=null; this.src='{{ asset('logo.png') }}';">
                                            {% else %}
                                                <img src="{{ asset('logo.png') }}" 
                                                     alt="Produit" 
                                                     class="img-fluid rounded"
                                                     style="max-height: 100px; max-width: 100px; width: auto; height: auto; object-fit: contain;">
                                            {% endif %}
                                        </div>
                                        
                                        <!-- Product Details -->
                                        <div class="flex-grow-1">
                                            <h5 class="mb-1 fs-6">{{ item.product.designation }}</h5>
                                            {% if item.product.capacity %}
                                                <p class="text-muted mb-1" style="font-size: 0.85rem;">
                                                    Capacité: {{ item.product.capacity }}
                                                </p>
                                            {% endif %}
                                            <p class="text-primary fw-bold mb-0">
                                                {{ (item.unitPrice|default(item.product.price))|number_format(2, ',', ' ') }} €
                                            </p>
                                        </div>
                                    </div>
                                    
                                    <!-- Mobile Quantity & Subtotal -->
                                    <div class="row g-2 align-items-center">
                                        <div class="col-6">
                                            <label class="form-label d-block mb-2"><small>Quantité</small></label>
                                            <div class="input-group input-group-sm">
                                                <form method="post" action="{{ path('app_cartupdate', {itemId: item.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_update') }}">
                                                    <input type="hidden" name="quantity" value="{{ item.quantity - 1 }}">
                                                    <button class="btn btn-outline-secondary btn-sm" type="submit" {{ item.quantity <= 1 ? 'disabled' : '' }}>
                                                        <i class="bi bi-dash"></i>
                                                    </button>
                                                </form>
                                                <input type="text" class="form-control form-control-sm text-center" value="{{ item.quantity }}" readonly style="max-width: 50px;">
                                                <form method="post" action="{{ path('app_cartupdate', {itemId: item.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_update') }}">
                                                    <input type="hidden" name="quantity" value="{{ item.quantity + 1 }}">
                                                    <button class="btn btn-outline-secondary btn-sm" type="submit">
                                                        <i class="bi bi-plus"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                        <div class="col-6 text-end">
                                            <div class="mb-2">
                                                <p class="fw-bold mb-1" style="font-size: 1rem;">
                                                    {{ item.subtotal|number_format(2, ',', ' ') }} €
                                                </p>
                                            </div>
                                            <form method="post" action="{{ path('app_cartremove', {itemId: item.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('cart_remove') }}">
                                                <button class="btn btn-sm btn-outline-danger" type="submit" title="Supprimer cet article">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Desktop Layout: Table-like Grid -->
                                <div class="d-none d-lg-block">
                                    <div class="row align-items-center g-2">
                                        <!-- Product Image -->
                                        <div class="col-2 text-center">
                                            {% if item.product %}
                                                {% set imagePath = item.product.imgPath ? 'products_images/' ~ item.product.category.slug ~ '/' ~ item.product.imgPath : 'logo.png' %}
                                                <img src="{{ asset(imagePath) }}" 
                                                     alt="{{ item.product.designation }}" 
                                                     class="img-fluid rounded"
                                                     style="max-height: 100px; max-width: 100px; width: auto; height: auto; object-fit: contain;"
                                                     onerror="this.onerror=null; this.src='{{ asset('logo.png') }}';">
                                            {% else %}
                                                <img src="{{ asset('logo.png') }}" 
                                                     alt="Produit" 
                                                     class="img-fluid rounded"
                                                     style="max-height: 100px; max-width: 100px; width: auto; height: auto; object-fit: contain;">
                                            {% endif %}
                                        </div>

                                        <!-- Product Details -->
                                        <div class="col-4">
                                            <h5 class="mb-1">{{ item.product.designation }}</h5>
                                            <p class="text-muted mb-0" style="font-size: 0.9rem;">
                                                {% if item.product.capacity %}
                                                    Capacité: {{ item.product.capacity }}
                                                {% endif %}
                                            </p>
                                            <p class="text-primary fw-bold mb-0">
                                                {{ (item.unitPrice|default(item.product.price))|number_format(2, ',', ' ') }} €
                                            </p>
                                        </div>

                                        <!-- Quantity Controls -->
                                        <div class="col-3 text-center">
                                            <label class="form-label d-block mb-2"><small>Quantité</small></label>
                                            <div class="input-group input-group-sm d-flex justify-content-center" style="max-width: 140px; margin: 0 auto;">
                                                <form method="post" action="{{ path('app_cartupdate', {itemId: item.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_update') }}">
                                                    <input type="hidden" name="quantity" value="{{ item.quantity - 1 }}">
                                                    <button class="btn btn-outline-secondary" type="submit" {{ item.quantity <= 1 ? 'disabled' : '' }}>
                                                        <i class="bi bi-dash"></i>
                                                    </button>
                                                </form>
                                                <input type="text" class="form-control text-center" value="{{ item.quantity }}" readonly style="max-width: 60px; min-width: 50px;">
                                                <form method="post" action="{{ path('app_cartupdate', {itemId: item.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_update') }}">
                                                    <input type="hidden" name="quantity" value="{{ item.quantity + 1 }}">
                                                    <button class="btn btn-outline-secondary" type="submit">
                                                        <i class="bi bi-plus"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>

                                        <!-- Subtotal & Remove -->
                                        <div class="col-3 text-end">
                                            <p class="fw-bold mb-2" style="font-size: 1.1rem;">
                                                {{ item.subtotal|number_format(2, ',', ' ') }} €
                                            </p>
                                            <form method="post" action="{{ path('app_cartremove', {itemId: item.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('cart_remove') }}">
                                                <button class="btn btn-sm btn-outline-danger" type="submit" title="Supprimer cet article">
                                                    <i class="bi bi-trash"></i> <span class="d-none d-md-inline">Supprimer</span>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <!-- Cart Summary -->
            <div class="col-12 col-lg-4">
                <div class="cart-summary">
                    <div class="summary-card">
                        <h4 class="mb-3">Résumé de la commande</h4>
                        <hr>
                        
                        <div class="summary-row">
                            <span>Sous-total ({{ cart.items|length }} article{{ cart.items|length > 1 ? 's' : '' }})</span>
                            <span class="fw-bold">{{ total|number_format(2, ',', ' ') }} €</span>
                        </div>
                        
                        <div class="summary-row">
                            <span>Livraison</span>
                            <span class="text-success fw-bold">Gratuite</span>
                        </div>
                        
                        <hr>
                        
                        <div class="summary-total">
                            <span>Total</span>
                            <span>{{ total|number_format(2, ',', ' ') }} €</span>
                        </div>
                        
                        <a href="{{ path('app_cartcheckout') }}" class="btn btn-checkout w-100 mb-2">
                            <i class="bi bi-lock-fill"></i> Procéder au paiement
                        </a>
                        
                        <a href="{{ path('app_product') }}" class="btn btn-outline-primary w-100">
                            <i class="bi bi-arrow-left"></i> Continuer mes achats
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>

<!-- Bootstrap Icons CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
{% endblock %}
