{% extends 'base.html.twig' %}

{% block title %}Commande confirmée — Sports Bottles{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="min-h-screen bg-[#f0f4f8] flex items-center justify-center py-10 px-4">
    <div class="bg-white rounded-3xl max-w-[560px] w-full px-12 py-14 shadow-[0_8px_48px_rgba(0,0,0,0.1)] text-center relative overflow-hidden max-[480px]:px-6 max-[480px]:py-10">

        <!-- Top accent bar -->
        <div class="absolute top-0 left-0 right-0 h-[5px] bg-gradient-to-r from-[#1a8a5a] to-[#34d18a]"></div>

        <!-- Confetti -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden" id="confetti"></div>

        <!-- Check icon -->
        <div class="animate-bounce w-[88px] h-[88px] rounded-full bg-gradient-to-br from-[#1a8a5a] to-[#34d18a] flex items-center justify-center mx-auto mb-8 shadow-[0_12px_32px_rgba(26,138,90,0.3)]">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
                <path d="M10 20L17 27L30 13" stroke="white" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>

        <h1 class="text-[2.6rem] tracking-[1px] text-[#0f1923] mb-[10px] font-bold">Commande confirmée!</h1>
        <p class="text-[#6b7a8d] text-base mb-9 leading-[1.6]">
            Votre paiement a été accepté et votre commande est en cours de préparation.<br>
            Vous recevrez une confirmation par e-mail.
        </p>

        <!-- Order Details -->
        <div class="bg-[#f7f9fb] rounded-[14px] p-6 mb-8 text-left border border-[#e8edf2]">
            <div class="flex justify-between items-center py-2 border-b border-[#e8edf2] text-[.95rem]">
                <span class="text-[#6b7a8d] font-medium"><i class="bi bi-hash"></i> Référence</span>
                <span class="text-[#0f1923] font-semibold">Commande #{{ order.id }}</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-[#e8edf2] text-[.95rem]">
                <span class="text-[#6b7a8d] font-medium"><i class="bi bi-calendar3"></i> Date</span>
                <span class="text-[#0f1923] font-semibold">{{ order.createdAt|date('d/m/Y à H:i') }}</span>
            </div>
            <div class="flex justify-between items-center py-2 border-b border-[#e8edf2] text-[.95rem]">
                <span class="text-[#6b7a8d] font-medium"><i class="bi bi-credit-card"></i> Statut paiement</span>
                <span class="bg-[#e6f9f1] text-[#1a8a5a] rounded-full px-3 py-1 text-[.82rem] font-semibold tracking-[.5px] uppercase"><i class="bi bi-check-circle-fill"></i> Payé</span>
            </div>
            <div class="flex justify-between items-center pt-[14px] border-b-0 font-semibold text-[1.05rem]">
                <span class="text-[#0f1923] font-bold">Total payé</span>
                <span class="text-[#1a8a5a] font-bold">{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €</span>
            </div>
        </div>

        <!-- Actions -->
        <a href="{{ path('app_home') }}"
           class="inline-flex items-center justify-center gap-2 w-full rounded-xl py-[14px] px-8 font-semibold text-base text-white no-underline transition-all duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(26,138,90,0.35)] mb-3 shadow-[0_4px_16px_rgba(26,138,90,0.25)]"
           style="background:linear-gradient(135deg,#1a8a5a,#34d18a);">
            <i class="bi bi-house-fill"></i> Retour à l'accueil
        </a>
        {# Uncomment if you have an orders history route:
        <a href="{{ path('app_orders') }}"
           class="fade-up inline-flex items-center justify-center gap-2 w-full rounded-xl py-[13px] px-8 font-semibold text-base text-[#1a8a5a] no-underline border-2 border-[#1a8a5a] bg-transparent transition-colors duration-200 hover:bg-[#1a8a5a] hover:text-white"
           style="animation-delay:.55s;">
            <i class="bi bi-bag-check"></i> Voir mes commandes
        </a>
        #}
    </div>
</div>

<script>
    // Confetti burst on load
    (function() {
        const colors = ['#1a8a5a', '#34d18a', '#fbbf24', '#60a5fa', '#f472b6', '#a78bfa'];
        const container = document.getElementById('confetti');
        const count = 30;

        for (let i = 0; i < count; i++) {
            const dot = document.createElement('div');
            dot.className = 'absolute rounded-full animate-ping';
            const size = Math.random() * 8 + 5;
            dot.style.cssText = `
                width: ${size}px;
                height: ${size}px;
                background: ${colors[Math.floor(Math.random() * colors.length)]};
                left: ${Math.random() * 100}%;
                top: ${Math.random() * 30}%;
                animation-duration: ${Math.random() * 1.5 + 0.8}s;
                animation-delay: ${Math.random() * 0.6}s;
            `;
            container.appendChild(dot);
        }
    })();
</script>
{% endblock %}
