{% extends 'base.html.twig' %}

{% block title %}Paiement annulé — Sports Bottles{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<style>
    @keyframes popIn {
        0%   { transform: scale(0); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }
    @keyframes fadeUp {
        0%   { opacity: 0; transform: translateY(16px); }
        100% { opacity: 1; transform: translateY(0); }
    }
    .pop-in  { animation: popIn  .5s cubic-bezier(.175,.885,.32,1.275) both; }
    .fade-up { animation: fadeUp .4s ease both; }
    .delay-1 { animation-delay: .15s; }
    .delay-2 { animation-delay: .25s; }
    .delay-3 { animation-delay: .35s; }
</style>

<div class="container d-flex justify-content-center align-items-center"
     style="min-height:100vh;padding-top:80px;padding-bottom:60px;">
    <div class="col-12 col-md-8 col-lg-5">

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

            <!-- Accent bar (orange/warning) -->
            <div style="height:5px;background:linear-gradient(90deg,#f59e0b,#fbbf24);"></div>

            <div class="card-body p-4 p-md-5 text-center">

                <!-- Icon -->
                <div class="pop-in rounded-circle d-inline-flex align-items-center justify-content-center mb-3 shadow-sm"
                     style="width:88px;height:88px;background:linear-gradient(135deg,#f59e0b,#fbbf24);">
                    <i class="bi bi-x-lg text-white" style="font-size:2rem;"></i>
                </div>

                <h1 class="fw-bold h3 mb-1 fade-up delay-1" style="color:#0f1923;">Paiement annulé</h1>
                <p class="text-muted mb-4 fade-up delay-2">
                    Votre commande n'a pas été passée.<br>
                    Votre panier est toujours disponible.
                </p>

                <!-- Info box -->
                <div class="rounded-3 text-start mb-4 fade-up delay-2"
                     style="background:#fffbeb;border:1px solid #fde68a;padding:18px 22px;">
                    <div class="d-flex align-items-start gap-3">
                        <i class="bi bi-info-circle-fill text-warning mt-1"></i>
                        <p class="mb-0 small" style="color:#78350f;">
                            Aucun montant n'a été débité de votre compte. Vous pouvez retourner à votre panier
                            et recommencer le paiement quand vous le souhaitez.
                        </p>
                    </div>
                </div>

                <!-- Actions -->
                <div class="fade-up delay-3 d-grid gap-2">
                    <a href="{{ path('app_cartindex') }}"
                       class="btn fw-semibold rounded-3 py-3 text-white"
                       style="background:linear-gradient(135deg,#f59e0b,#fbbf24);border:none;">
                        <i class="bi bi-cart3 me-2"></i>Retourner au panier
                    </a>
                    <a href="{{ path('app_home') }}"
                       class="btn btn-outline-secondary rounded-3 py-2 fw-semibold">
                        <i class="bi bi-house me-2"></i>Retour à l'accueil
                    </a>
                </div>

            </div>
        </div>

        <div class="text-center mt-3 text-muted small">
            <i class="bi bi-shield-lock-fill text-success me-1"></i>
            Paiement sécurisé par <strong>Stripe</strong>
        </div>
    </div>
</div>

{% endblock %}
