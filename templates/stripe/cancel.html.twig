{% extends 'base.html.twig' %}

{% block title %}Paiement annulé — Sports Bottles
{% endblock %}

{% block body %}
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

	<div class="min-h-screen flex justify-center items-center pt-20 pb-[60px] px-4">
		<div class="w-full max-w-md">

			<div
				class="bg-white shadow-sm rounded-2xl overflow-hidden">

				<!-- Accent bar (orange/warning) -->
				<div class="h-[5px] bg-gradient-to-r from-[#f59e0b] to-[#fbbf24]"></div>
				<div
					class="p-6 md:p-10 text-center">

					<!-- Icon -->
					<div class="animate-bounce rounded-full inline-flex items-center justify-center mb-3 shadow-sm" style="width:88px;height:88px;background:linear-gradient(135deg,#f59e0b,#fbbf24);">
						<i class="bi bi-x-lg text-white text-[2rem]"></i>
					</div>

					<h1 class="font-bold text-2xl mb-1 text-[#0f1923]">Paiement annulé</h1>
					<p class="text-gray-500 mb-4">
						Votre commande n'a pas été passée.<br>
						Votre panier est toujours disponible.
					</p>

					<!-- Info box -->
					<div class="rounded-xl text-left mb-4 bg-[#fffbeb] border border-[#fde68a] px-[22px] py-[18px]">
						<div class="flex items-start gap-3">
							<i class="bi bi-info-circle-fill text-amber-500 mt-1"></i>
							<p class="mb-0 text-sm text-[#78350f]">
								Aucun montant n'a été débité de votre compte. Vous pouvez retourner à votre panier
								                            et recommencer le paiement quand vous le souhaitez.
							</p>
						</div>
					</div>

					<!-- Actions -->
					<div class="grid gap-2">
						<a href="{{ path('app_cartindex') }}" class="inline-flex items-center justify-center gap-2 font-semibold rounded-xl py-3 text-white no-underline transition-all duration-200 hover:opacity-90 hover:-translate-y-0.5" style="background:linear-gradient(135deg,#f59e0b,#fbbf24);">
							<i class="bi bi-cart3"></i>Retourner au panier
						</a>
						<a href="{{ path('app_home') }}" class="inline-flex items-center justify-center gap-2 rounded-xl py-2 font-semibold border border-gray-300 text-gray-600 no-underline transition-colors hover:bg-gray-50 hover:text-gray-800">
							<i class="bi bi-house"></i>Retour à l'accueil
						</a>
					</div>

				</div>
			</div>

			<div class="text-center mt-3 text-gray-500 text-sm">
				<i class="bi bi-shield-lock-fill text-green-600 mr-1"></i>
				Paiement sécurisé par
				<strong>Stripe</strong>
			</div>
		</div>
	</div>

{% endblock %}
