{% extends 'base.html.twig' %}

{% block title %}Paiement en cours — Sports Bottles{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="container d-flex justify-content-center align-items-center" style="min-height:100vh;padding-top:80px;padding-bottom:60px;">
    <div class="col-12 col-md-8 col-lg-6">

        <!-- Status card -->
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

            <!-- Top accent bar -->
            <div style="height:5px;background:linear-gradient(90deg,#1a8a5a,#34d18a);"></div>

            <div class="card-body p-4 p-md-5">

                <!-- Animated spinner / check area -->
                <div class="text-center mb-4">
                    <div id="status-icon"
                         class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                         style="width:80px;height:80px;background:#e8f5e9;">
                        <div class="spinner-border text-success" role="status" style="width:2rem;height:2rem;">
                            <span class="visually-hidden">Chargement...</span>
                        </div>
                    </div>
                    <h2 class="fw-bold h4 mb-1" style="color:#0f1923;">Vérification du paiement</h2>
                    <p class="text-muted small mb-0">Veuillez patienter, nous confirmons votre paiement…</p>
                </div>

                <!-- Order details -->
                <div class="rounded-3 p-3 mb-4" style="background:#f7f9fb;border:1px solid #e8edf2;">
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted small">Référence</span>
                        <span class="fw-semibold small">Commande #{{ order.id }}</span>
                    </div>
                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <span class="text-muted small">Montant</span>
                        <span class="fw-semibold small">{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center py-2">
                        <span class="text-muted small">Statut</span>
                        <span id="order-status"
                              class="badge rounded-pill {% if order.status == 'paid' %}bg-success{% else %}bg-warning text-dark{% endif %}"
                              style="font-size:.8rem;">
                            {{ order.status }}
                        </span>
                    </div>
                </div>

                <!-- Success message (hidden until paid) -->
                <div id="validation-message" class="alert alert-success rounded-3 d-flex align-items-center gap-2 mb-4"
                     style="display:none!important;">
                    <i class="bi bi-check-circle-fill fs-5"></i>
                    <span>Paiement confirmé ! Redirection en cours…</span>
                </div>

                <!-- Timeout message (shown after max attempts) -->
                <div id="timeout-message" class="alert alert-warning rounded-3 d-flex align-items-center gap-2 mb-4"
                     style="display:none!important;">
                    <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    <span>La confirmation prend du temps. Vérifiez vos e-mails ou <a href="{{ path('app_home') }}">retournez à l'accueil</a>.</span>
                </div>

                <!-- Back link -->
                <div class="text-center">
                    <a href="{{ path('app_home') }}" class="text-muted small text-decoration-none">
                        <i class="bi bi-house me-1"></i>Retour à l'accueil
                    </a>
                </div>
            </div>
        </div>

        <!-- Stripe badge -->
        <div class="text-center mt-3 text-muted small">
            <i class="bi bi-shield-lock-fill text-success me-1"></i>
            Paiement sécurisé par <strong>Stripe</strong>
        </div>
    </div>
</div>

<script>
(function () {
    const sessionId  = '{{ sessionId }}';
    const orderId    = {{ order.id }};
    const statusEl   = document.getElementById('order-status');
    const iconEl     = document.getElementById('status-icon');
    const messageEl  = document.getElementById('validation-message');
    const timeoutEl  = document.getElementById('timeout-message');

    function markPaid() {
        // Swap spinner for check icon
        iconEl.style.background = '#e8f5e9';
        iconEl.innerHTML = '<i class="bi bi-check-circle-fill text-success" style="font-size:2.2rem;"></i>';

        statusEl.textContent = 'paid';
        statusEl.classList.remove('bg-warning', 'text-dark');
        statusEl.classList.add('bg-success');

        messageEl.style.setProperty('display', 'flex', 'important');

        setTimeout(() => {
            window.location.href = '/payment/complete/' + orderId;
        }, 1800);
    }

    // Already paid on page load
    if (statusEl.textContent.trim() === 'paid') {
        markPaid();
        return;
    }

    // Poll every 3s, max 20 attempts (~1 minute)
    let attempts = 0;
    const maxAttempts = 20;

    const pollTimer = setInterval(async () => {
        attempts++;

        try {
            const res  = await fetch('/payment/order-status/' + encodeURIComponent(sessionId));
            if (!res.ok) return;
            const data = await res.json();

            if (data.ok && data.status === 'paid') {
                clearInterval(pollTimer);
                markPaid();
            }
        } catch (e) {
            // Network error — continue polling
        }

        if (attempts >= maxAttempts) {
            clearInterval(pollTimer);
            // Replace spinner with warning icon
            iconEl.style.background = '#fff8e1';
            iconEl.innerHTML = '<i class="bi bi-exclamation-triangle-fill text-warning" style="font-size:2rem;"></i>';
            timeoutEl.style.setProperty('display', 'flex', 'important');
        }
    }, 3000);
})();
</script>

{% endblock %}
