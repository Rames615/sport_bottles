{% extends 'base.html.twig' %}

{% block title %}Paiement en cours — Sports Bottles{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="min-h-screen flex justify-center items-center pt-20 pb-[60px] px-4">
    <div class="w-full max-w-lg">

        <!-- Status card -->
        <div class="bg-white shadow-sm rounded-2xl overflow-hidden">

            <!-- Top accent bar -->
            <div class="h-[5px] bg-gradient-to-r from-[#1a8a5a] to-[#34d18a]"></div>

            <div class="p-6 md:p-10">

                <!-- Animated spinner / check area -->
                <div class="text-center mb-4">
                    <div id="status-icon"
                         class="rounded-full inline-flex items-center justify-center mb-3"
                         style="width:80px;height:80px;background:#e8f5e9;">
                        <div class="w-8 h-8 border-[3px] border-green-200 border-t-green-600 rounded-full animate-spin" role="status">
                            <span class="sr-only">Chargement...</span>
                        </div>
                    </div>
                    <h2 class="font-bold text-xl mb-1 text-[#0f1923]">Vérification du paiement</h2>
                    <p class="text-gray-500 text-sm mb-0">Veuillez patienter, nous confirmons votre paiement…</p>
                </div>

                <!-- Order details -->
                <div class="rounded-xl p-4 mb-4 bg-[#f7f9fb] border border-[#e8edf2]">
                    <div class="flex justify-between py-2 border-b border-[#e8edf2]">
                        <span class="text-gray-500 text-sm">Référence</span>
                        <span class="font-semibold text-sm">Commande #{{ order.id }}</span>
                    </div>
                    <div class="flex justify-between py-2 border-b border-[#e8edf2]">
                        <span class="text-gray-500 text-sm">Montant</span>
                        <span class="font-semibold text-sm">{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <div class="flex justify-between items-center py-2">
                        <span class="text-gray-500 text-sm">Statut</span>
                        <span id="order-status"
                              class="inline-flex items-center rounded-full px-3 py-0.5 text-[.8rem] font-semibold {% if order.status == 'paid' %}bg-green-100 text-green-700{% else %}bg-yellow-100 text-yellow-800{% endif %}">
                            {{ order.status }}
                        </span>
                    </div>
                </div>

                <!-- Success message (hidden until paid) -->
                <div id="validation-message" class="flex items-center gap-2 mb-4 p-4 bg-green-50 border border-green-200 text-green-700 rounded-xl"
                     style="display:none!important;">
                    <i class="bi bi-check-circle-fill text-lg"></i>
                    <span>Paiement confirmé ! Redirection en cours…</span>
                </div>

                <!-- Timeout message (shown after max attempts) -->
                <div id="timeout-message" class="flex items-center gap-2 mb-4 p-4 bg-amber-50 border border-amber-200 text-amber-700 rounded-xl"
                     style="display:none!important;">
                    <i class="bi bi-exclamation-triangle-fill text-lg"></i>
                    <span>La confirmation prend du temps. Vérifiez vos e-mails ou <a href="{{ path('app_home') }}" class="underline font-semibold">retournez à l'accueil</a>.</span>
                </div>

                <!-- Back link -->
                <div class="text-center">
                    <a href="{{ path('app_home') }}" class="text-gray-500 text-sm no-underline hover:text-gray-700 transition-colors">
                        <i class="bi bi-house mr-1"></i>Retour à l'accueil
                    </a>
                </div>
            </div>
        </div>

        <!-- Stripe badge -->
        <div class="text-center mt-3 text-gray-500 text-sm">
            <i class="bi bi-shield-lock-fill text-green-600 mr-1"></i>
            Paiement sécurisé par <strong>Stripe</strong>
        </div>
    </div>
</div>

<script>
(function () {
    const sessionId  = '{{ sessionId }}';
    const orderId    = {{ order.id }};
    const statusEl   = document.getElementById('order-status');
    const iconEl     = document.getElementById('status-icon');
    const messageEl  = document.getElementById('validation-message');
    const timeoutEl  = document.getElementById('timeout-message');

    function markPaid() {
        // Swap spinner for check icon
        iconEl.style.background = '#e8f5e9';
        iconEl.innerHTML = '<i class="bi bi-check-circle-fill text-green-600" style="font-size:2.2rem;"></i>';

        statusEl.textContent = 'paid';
        statusEl.classList.remove('bg-yellow-100', 'text-yellow-800');
        statusEl.classList.add('bg-green-100', 'text-green-700');

        messageEl.style.setProperty('display', 'flex', 'important');

        setTimeout(() => {
            window.location.href = '/payment/complete/' + orderId;
        }, 1800);
    }

    // Already paid on page load
    if (statusEl.textContent.trim() === 'paid') {
        markPaid();
        return;
    }

    // Poll every 3s, max 20 attempts (~1 minute)
    let attempts = 0;
    const maxAttempts = 20;

    const pollTimer = setInterval(async () => {
        attempts++;

        try {
            const res  = await fetch('/payment/order-status/' + encodeURIComponent(sessionId));
            if (!res.ok) return;
            const data = await res.json();

            if (data.ok && data.status === 'paid') {
                clearInterval(pollTimer);
                markPaid();
            }
        } catch (e) {
            // Network error — continue polling
        }

        if (attempts >= maxAttempts) {
            clearInterval(pollTimer);
            // Replace spinner with warning icon
            iconEl.style.background = '#fff8e1';
            iconEl.innerHTML = '<i class="bi bi-exclamation-triangle-fill text-amber-500" style="font-size:2rem;"></i>';
            timeoutEl.style.setProperty('display', 'flex', 'important');
        }
    }, 3000);
})();
</script>

{% endblock %}
