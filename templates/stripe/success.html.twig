{% extends 'base.html.twig' %}

{% block title %}Paiement terminé — Sports Bottles{% endblock %}

{% block body %}
<div class="container" style="margin-top:100px;">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <!-- Success Alert -->
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <h4 class="alert-heading"><i class="bi bi-check-circle"></i> Merci pour votre commande!</h4>
                <p>Votre commande a été créée et le paiement est en cours de traitement.</p>
            </div>

            <!-- Order Details Card -->
            <div class="card p-4 mt-3">
                <h5><i class="bi bi-info-circle"></i> Détails de votre commande</h5>
                <hr>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <p><strong>Référence:</strong></p>
                        <p class="text-muted">Commande #{{ order.id }}</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Montant:</strong></p>
                        <p class="text-muted">{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €</p>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Statut:</strong></p>
                        <p><span id="order-status" class="badge bg-warning">{{ order.status }}</span></p>
                    </div>
                </div>

                <!-- Validation Message (shown when paid) -->
                <div id="validation-message" style="display:none;" class="alert alert-success mt-3">
                    <i class="bi bi-check-circle-fill"></i> Paiement confirmé! Votre commande est validée.
                </div>

                <!-- Action Buttons -->
                <div class="mt-4">
                    <a href="{{ path('app_home') }}" class="btn btn-primary">
                        <i class="bi bi-house"></i> Retour à l'accueil
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        const sessionId = '{{ sessionId }}';
        const orderId = {{ order.id }};
        const statusEl = document.getElementById('order-status');
        const messageEl = document.getElementById('validation-message');

        // If order already paid, redirect immediately
        if (statusEl && statusEl.textContent.trim() === 'paid') {
            statusEl.classList.remove('bg-warning');
            statusEl.classList.add('bg-success');
            messageEl.style.display = 'block';
            // Redirect to payment complete route after 2 seconds
            setTimeout(() => {
                window.location.href = `/stripe/payment-complete/${orderId}`;
            }, 2000);
            return;
        }

        // Poll endpoint every 3 seconds for up to 20 times (~1 minute)
        let attempts = 0;
        const maxAttempts = 20;
        const interval = 3000;

        async function pollStatus() {
            if (!sessionId) return;
            try {
                const res = await fetch(`/stripe/order-status/${encodeURIComponent(sessionId)}`);
                if (!res.ok) return;
                const data = await res.json();
                if (data.ok && data.status) {
                    statusEl.textContent = data.status;
                    if (data.status === 'paid') {
                        statusEl.classList.remove('bg-warning');
                        statusEl.classList.add('bg-success');
                        messageEl.style.display = 'block';
                        clearInterval(pollTimer);
                        // Redirect to payment complete route
                        setTimeout(() => {
                            window.location.href = `/stripe/payment-complete/${orderId}`;
                        }, 1500);
                    }
                }
            } catch (e) {
                // ignore and continue polling
            }
            attempts++;
            if (attempts >= maxAttempts) {
                clearInterval(pollTimer);
            }
        }

        const pollTimer = setInterval(pollStatus, interval);
    })();
</script>

<!-- Bootstrap Icons CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
{% endblock %}
