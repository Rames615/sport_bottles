{% extends 'base.html.twig' %}

{% block title %}Paiement terminé — Sports Bottles{% endblock %}

{% block body %}
<div class="container" style="margin-top:100px;">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card p-4">
                <h3>Merci pour votre commande</h3>

                <p>Référence commande: <strong>{{ order.id }}</strong></p>
                <p>Statut actuel: <span id="order-status">{{ order.status }}</span></p>
                <p>Montant: <strong>{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }} €</strong></p>

                <div id="validation-message" style="display:none;" class="alert alert-success mt-3">Votre commande a été validée et payée. Merci !</div>

                <a href="{{ path('app_home') }}" class="btn btn-primary mt-3">Retour à l'accueil</a>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        const sessionId = '{{ sessionId }}';
        const statusEl = document.getElementById('order-status');
        const messageEl = document.getElementById('validation-message');

        // If order already paid, show popup immediately
        if (statusEl && statusEl.textContent.trim() === 'paid') {
            messageEl.style.display = 'block';
            // small popup using Bootstrap modal-like alert (or use toast)
            alert('Merci — votre commande est validée et payée.');
        }

        // Poll endpoint every 3 seconds for up to 20 times (~1 minute)
        let attempts = 0;
        const maxAttempts = 20;
        const interval = 3000;

        async function pollStatus() {
            if (!sessionId) return;
            try {
                const res = await fetch(`/stripe/order-status/${encodeURIComponent(sessionId)}`);
                if (!res.ok) return;
                const data = await res.json();
                if (data.ok && data.status) {
                    statusEl.textContent = data.status;
                    if (data.status === 'paid') {
                        messageEl.style.display = 'block';
                        alert('Merci — votre commande est confirmée et payée.');
                        clearInterval(pollTimer);
                    }
                }
            } catch (e) {
                // ignore and continue polling
            }
            attempts++;
            if (attempts >= maxAttempts) {
                clearInterval(pollTimer);
            }
        }

        const pollTimer = setInterval(pollStatus, interval);
    })();
</script>

{% endblock %}
