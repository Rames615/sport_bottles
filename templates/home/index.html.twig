{% extends 'base.html.twig' %}

{% block title %}Sports Bottles - Bouteilles Durables
{% endblock %}

{% block body %}
	<!-- Hero Section -->
	<section class="hero-section-full">
		<div class="hero-image-container">
			<img src="/heroNew.png" alt="Hero image" class="hero-main-image">
			<div class="hero-overlay"></div>
		</div>
		<div class="hero-content-wrapper">
			<h1 class="hero-title-main">
				<span class="hero-highlight">Des bouteilles durables</span>
				<span class="hero-rest">pour un mode de vie actif</span>
			</h1>

			<p class="hero-subtitle animate-fade-in">
				Sans BPA • Écologiques • Livraison 24–48h
			</p>

			<div class="hero-cta-group">
				<a href="{{ path('app_product') }}" class="btn-cta-primary pulse-primary">
					DÉCOUVRIR NOS PRODUITS
				</a>

				<a href="#products" class="btn-cta-secondary pulse-secondary">
					VOIR PLUS
				</a>
			</div>

		</div>

		<a href="#products" class="scroll-down-btn" aria-label="Scroll down">
			<svg width="24" height="24" viewbox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M7 10L12 15L17 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</a>
	</section>

	<!-- Promotions Section -->
	<section class="bestsellers-section" id="products">
		<div class="container-main">
			<h2 class="section-title">🔥 Nos promotions du moment</h2>
			<div class="products-grid">
				{% for product in bottles %}
					<div class="product-card">
						<div class="product-badge text-center">En promotion</div>
						<div class="product-image-wrapper">
							{% if product.imgPath %}
								<img src="{{ asset('products_images/' ~ product.category.slug ~ '/' ~ product.imgPath) }}" alt="{{ product.designation }}" class="product-image" onerror="this.src='{{ asset('images/placeholder.png') }}'">
							{% else %}
								<img src="{{ asset('images/placeholder.png') }}" alt="{{ product.designation }}" class="product-image">
							{% endif %}
						</div>
						<div class="product-info">
							<h3 class="product-name">{{ product.designation }}</h3>
							<div class="product-rating">
								<span class="stars">⭐⭐⭐⭐⭐</span>
								<span class="rating-text">(4.8)</span>
							</div>
							<p class="product-price">{{ product.price }}€</p>
							<button class="btn-add-cart" data-product-id="{{ product.id }}">Ajouter</button>
						</div>
					</div>
				{% endfor %}
			</div>
		</div>
	</section>

	<!-- Reassurance Section -->
	<section class="reassurance-section">
		<h2 class="section-title">Nos garanties</h2>
		<div class="reassurance-container">
			<div class="reassurance-card">
				<div class="reassurance-icon">🚚</div>
				<h3 class="reassurance-title">Livraison rapide</h3>
			</div>
			<div class="reassurance-card">
				<div class="reassurance-icon">🔄</div>
				<h3 class="reassurance-title">Retours faciles</h3>
			</div>
			<div class="reassurance-card">
				<div class="reassurance-icon">🔒</div>
				<h3 class="reassurance-title">Paiement sécurisé</h3>
			</div>
			<div class="reassurance-card">
				<div class="reassurance-icon">🌱</div>
				<h3 class="reassurance-title">Écoresponsable</h3>
			</div>
		</div>
	</section>
{% endblock %}
