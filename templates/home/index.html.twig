{% extends 'base.html.twig' %}

{% block title %}Sports Bottles - Bouteilles Durables
{% endblock %}

{% block body %}

	{# ── HERO ── #}
	<section class="relative min-h-[calc(100vh-70px)] flex items-center justify-center lg:flex-col mt-[70px] overflow-hidden">
		<div class="absolute inset-0 z-[1]">
			<img src="/hero.png" alt="Hero image" class="w-full h-full object-cover block">
			<div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(0,0,0,.55) 0%, rgba(0,0,0,.35) 40%, rgba(0,0,0,.65) 100%);"></div>
		</div>
		<div class="relative z-[3] text-center px-5 max-w-[900px] flex flex-col items-center animate-float-hero lg:flex-1 lg:justify-center">
			<h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold leading-[1.1] tracking-[-1px] text-white backdrop-blur-sm bg-black/10 rounded-xl sm:rounded-2xl px-5 sm:px-8 py-3 sm:py-4">
				<span class="block" style="background: linear-gradient(90deg, #00ff99, #00d4ff); background-clip: text; -webkit-text-fill-color: transparent;">Des bouteilles durables</span>
				<span class="block mt-2.5 font-semibold opacity-90">pour un mode de vie actif</span>
			</h1>
			<div
				class="flex flex-wrap justify-center gap-4 mt-7 mb-10 lg:mb-0">

				{# Badge 1 — Sans BPA #}
				<div class="group flex items-center border border-white/[.5] rounded-2xl overflow-hidden cursor-default backdrop-blur-sm bg-white/[.07] hover:bg-white/10 hover:border-white/20 hover:-translate-y-0.5 transition-all duration-300">
					<div class="bg-emerald-400/15 group-hover:bg-emerald-400/20 px-3 py-3 sm:px-4 sm:py-4 flex items-center justify-center shrink-0 transition-colors duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
						</svg>
					</div>
					<div class="w-px self-stretch bg-white/5 group-hover:bg-white/15 transition-colors duration-300"></div>
					<div class="px-3 py-2 sm:px-4 sm:py-3 text-left">
						<p class="text-[.5rem] sm:text-[.6rem] font-semibold uppercase tracking-widest text-emerald-300 leading-none mb-1">Santé</p>
						<p class="text-white font-bold text-[.75rem] sm:text-[.9rem] leading-none whitespace-nowrap">Sans BPA</p>
					</div>
				</div>

				{# Badge 2 — Écologiques #}
				<div class="group flex items-center border border-white/[.5] rounded-2xl overflow-hidden cursor-default backdrop-blur-sm bg-white/[.07] hover:bg-white/10 hover:border-white/20 hover:-translate-y-0.5 transition-all duration-300">
					<div class="bg-sky-400/15 group-hover:bg-sky-400/20 px-3 py-3 sm:px-4 sm:py-4 flex items-center justify-center shrink-0 transition-colors duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-sky-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
						</svg>
					</div>
					<div class="w-px self-stretch bg-white/5 group-hover:bg-white/15 transition-colors duration-300"></div>
					<div class="px-3 py-2 sm:px-4 sm:py-3 text-left">
						<p class="text-[.5rem] sm:text-[.6rem] font-semibold uppercase tracking-widest text-sky-300 leading-none mb-1">Planète</p>
						<p class="text-white font-bold text-[.75rem] sm:text-[.9rem] leading-none whitespace-nowrap">Écologiques</p>
					</div>
				</div>

				{# Badge 3 — Livraison 24–48h #}
				<div class="group flex items-center border border-white/[.5] rounded-2xl overflow-hidden cursor-default backdrop-blur-sm bg-white/[.07] hover:bg-white/10 hover:border-white/20 hover:-translate-y-0.5 transition-all duration-300">
					<div class="bg-amber-400/15 group-hover:bg-amber-400/20 px-3 py-3 sm:px-4 sm:py-4 flex items-center justify-center shrink-0 transition-colors duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-amber-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414A1 1 0 0121 11.414V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0 2 2 0 00-4 0zm11 0a2 2 0 104 0 2 2 0 00-4 0z"/>
						</svg>
					</div>
					<div class="w-px self-stretch bg-white/5 group-hover:bg-white/15 transition-colors duration-300"></div>
					<div class="px-3 py-2 sm:px-4 sm:py-3 text-left">
						<p class="text-[.5rem] sm:text-[.6rem] font-semibold uppercase tracking-widest text-amber-300 leading-none mb-1">Rapidité</p>
						<p class="text-white font-bold text-[.75rem] sm:text-[.9rem] leading-none whitespace-nowrap">Livraison 24–48h</p>
					</div>
				</div>

			</div>
			<div class="flex justify-center gap-5 flex-wrap lg:absolute lg:bottom-[50px] lg:left-1/2 lg:-translate-x-1/2">
				<a href="{{ path('app_product') }}" class="px-5 py-3 sm:px-[30px] sm:py-[14px] rounded-full text-xs sm:text-[.9rem] font-semibold tracking-[.5px] transition-all duration-[350ms] backdrop-blur hover:-translate-y-1 no-underline shadow-cta hover:shadow-cta-hover" style="background: linear-gradient(135deg, #00ff99, #00d4ff); color: #000;">
					DÉCOUVRIR NOS PRODUITS
				</a>
				<a href="#products" class="px-5 py-3 sm:px-[30px] sm:py-[14px] rounded-full text-xs sm:text-[.9rem] font-semibold tracking-[.5px] transition-all duration-[350ms] backdrop-blur border hover:-translate-y-1 no-underline" style="background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.4); color: #fff;">
					VOIR PLUS
				</a>
			</div>
		</div>
	</section>

	{# ── PROMOTIONS ── #}
	<section class="relative w-full overflow-hidden py-10 px-2.5" id="products" style="background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);">
		<div class="absolute pointer-events-none rounded-full" style="top:-50%; right:-10%; width:500px; height:500px; background: radial-gradient(circle, rgba(31,122,99,.08) 0%, transparent 70%);"></div>
		<div class="absolute top-0 left-0 right-0 h-px z-[2]" style="background: linear-gradient(90deg, transparent, rgba(31,122,99,.1), transparent);"></div>
		<div class="max-w-[1200px] mx-auto relative z-[1] mt-8">
			<h2 class="flex items-center gap-[25px] text-[2.2rem] font-bold text-main tracking-[-0.5px] mb-2 font-display">
				<span class="text-[2.8rem] inline-block animate-pulse-icon">🔥</span>
				Nos promotions du moment
			</h2>
			<p class="text-base text-muted mb-10 max-w-[600px] font-normal leading-relaxed">
				Découvrez nos meilleures offres avec des réductions exceptionnelles
			</p>

			{% if promotions is empty %}
				<div class="text-center py-[60px] px-5 text-lg text-muted bg-white rounded-xl shadow-sm">
					<p>Aucune promotion active pour le moment. Consultez notre
						<a href="{{ path('app_product') }}" class="font-semibold no-underline hover:underline text-primary">catalogue complet</a>.
					</p>
				</div>
			{% else %}
				<div class="grid gap-[24px]" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));">
					{% for promotion in promotions %}
						{% set product = promotion.getProduct() %}
						{% if product %}
							<div
								class="group bg-white rounded-2xl overflow-hidden shadow-[0_2px_12px_rgba(0,0,0,.06)] transition-all duration-[400ms] relative flex flex-col h-full border border-primary/[.08] hover:-translate-y-[9px] hover:shadow-[0_16px_40px_rgba(31,122,99,.12)] hover:border-primary/20">

								{# Badge bar #}
								<div class="absolute top-0 left-0 right-0 flex items-center gap-1.5 px-2.5 py-[9px] backdrop-blur-[10px] z-10 border-b border-primary/10 shadow-[0_2px_8px_rgba(0,0,0,.04)]" style="background: linear-gradient(135deg, rgba(255,255,255,.96) 0%, rgba(255,255,255,.92) 100%);">
									{% if promotion.getDiscountType() == 'percentage' %}
										<span class="px-2.5 py-1.5 rounded-lg font-bold text-[.75rem] uppercase tracking-[.5px] text-white font-display shadow-[0_4px_12px_rgba(220,38,38,.3)]" style="background: linear-gradient(135deg, #dc2626, #bb1c27);">-{{ promotion.getDiscountValue() }}%</span>
									{% else %}
										<span class="px-2.5 py-1.5 rounded-lg font-bold text-[.75rem] uppercase tracking-[.5px] text-white font-display shadow-[0_4px_12px_rgba(245,158,11,.3)]" style="background: linear-gradient(135deg, #f59e0b, #d97706);">-{{ promotion.getDiscountValue() }}€</span>
									{% endif %}
									<span class="ml-auto px-2 py-1 bg-primary text-white text-[.55rem] font-bold uppercase tracking-[.5px] rounded-md font-display">En promotion</span>
								</div>

								{# Product image #}
								<div class="relative w-full h-[200px] flex items-center justify-center overflow-hidden mt-[37px]" style="background: linear-gradient(135deg, #f8f9fa 0%, #eff2f5 100%);">
									{% set promotionImageFile = promotion.imgPath ? (promotion.imgPath|split('/')|last) : null %}
									{% set productImageFile = product.imgPath ? (product.imgPath|split('/')|last) : null %}
									{% if promotionImageFile %}
										<img src="{{ asset('products_images/promotion/' ~ promotionImageFile) }}" alt="{{ product.designation }}" class="w-full h-full object-contain px-5 py-7 transition-transform duration-[400ms] group-hover:scale-[1.08]" onerror="this.src='{{ asset('images/placeholder.png') }}'">
									{% elseif productImageFile %}
										<img src="{{ asset('products_images/' ~ productImageFile) }}" alt="{{ product.designation }}" class="w-full h-full object-contain px-5 py-7 transition-transform duration-[400ms] group-hover:scale-[1.08]" onerror="this.src='{{ asset('images/placeholder.png') }}'">
									{% else %}
										<img src="{{ asset('images/placeholder.png') }}" alt="{{ product.designation }}" class="w-full h-full object-contain px-5 py-7">
									{% endif %}
								</div>

								{# Card content #}
								<div class="px-5 py-4 flex-1 flex flex-col">
									<h3 class="text-[1rem] font-bold text-main mb-2 leading-[1.3] tracking-[-0.5px] font-display">{{ product.designation }}</h3>
									{# Product Description (shared component) #}
									{% include 'components/_product_description.html.twig' with { product: product, descClass: 'text-[.75rem] text-muted' } only %}

									<div class="flex flex-col gap-[3px] my-1.5 text-[.75rem]" style="color: #666;">
										<span class="flex items-center gap-1.5">
											<span>📅</span>
											Du
											<strong>{{ promotion.getStartAt() | date('d/m/Y') }}</strong>
											au
											<strong>{{ promotion.getEndAt() | date('d/m/Y') }}</strong>
										</span>
										{% set daysLeft = (promotion.getEndAt().getTimestamp() - date().getTimestamp()) / 86400 %}
										{% if daysLeft > 0 %}
											<span class="inline-block self-start bg-[#fff3cd] text-[#856404] border border-[#ffc107] rounded-[20px] px-2 py-px font-semibold text-[.7rem] mt-px">
												⏳ Plus que
												{{ daysLeft | round(0, 'ceil') }}
												jour
												{% if daysLeft > 1 %}s
												{% endif %}
											</span>
										{% endif %}
									</div>

									<div class="flex gap-1.5 mb-3 flex-wrap">
										{% if product.capacity %}
											<span class="inline-flex items-center gap-[3px] text-[.7rem] text-muted font-medium px-2 py-1 rounded-[5px] border border-primary/10 bg-primary/[.08] group-hover:bg-primary/[.12] group-hover:border-primary/20 transition-all">
												<span>📦</span>
												{{ product.capacity }}
											</span>
										{% endif %}
										{% if product.temperature %}
											<span class="inline-flex items-center gap-[3px] text-[.7rem] text-muted font-medium px-2 py-1 rounded-[5px] border border-primary/10 bg-primary/[.08] group-hover:bg-primary/[.12] group-hover:border-primary/20 transition-all">
												<span>🌡️</span>
												{{ product.temperature }}
											</span>
										{% endif %}
									</div>

									<div class="mb-3 p-[9px] rounded-lg border border-primary/[.12]" style="background: linear-gradient(135deg, rgba(31,122,99,.06) 0%, rgba(31,122,99,.02) 100%);">
										<div class="flex items-center gap-2 mb-1">
											<span class="text-[.8rem] text-muted font-medium line-through [text-decoration-thickness:2px]">{{ product.price }}€</span>
											<span class="text-[1.4rem] font-bold text-primary tracking-[-0.5px] font-display">{{ product.getFinalPrice() | number_format(2, ',', ' ') }}€</span>
										</div>
										<div class="text-[.7rem] text-muted font-medium flex gap-[3px]">
											Économisez:
											{% if promotion.getDiscountType() == 'percentage' %}
												<strong class="text-[.75rem] font-semibold text-red-500">{{ (product.price - product.getFinalPrice()) | number_format(2, ',', ' ') }}€</strong>
											{% else %}
												<strong class="text-[.75rem] font-semibold text-red-500">{{ promotion.getDiscountValue() }}€</strong>
											{% endif %}
										</div>
									</div>

									<div class="flex gap-2.5 mt-auto items-stretch">
										<form method="post" action="{{ path('app_cartadd', {id: product.id}) }}" class="flex-none add-to-cart-form-promo">
											<input type="hidden" name="_token" value="{{ csrf_token('cart_add') }}">
											<button type="submit" class="flex items-center justify-center gap-1.5 px-3.5 py-2 border-0 rounded-[10px] font-semibold text-[.75rem] uppercase tracking-[.4px] cursor-pointer transition-all duration-300 text-white shadow-green-sm hover:-translate-y-0.5 hover:shadow-green-md hover:brightness-110 whitespace-nowrap font-display" style="background: linear-gradient(135deg, #1F7A63, #1a5c4a);" data-product-id="{{ product.id }}" title="Ajouter {{ product.designation }} au panier">
												<span>🛒</span>
												Ajouter
											</button>
										</form>
										<a href="{{ path('app_product_show', {id: product.id}) }}" class="flex flex-1 items-center justify-center gap-1.5 px-3.5 py-2 rounded-[10px] font-semibold text-[.75rem] uppercase tracking-[.4px] transition-all duration-300 text-white shadow-green-sm no-underline hover:-translate-y-0.5 hover:shadow-green-md hover:brightness-110 whitespace-nowrap font-display" style="background: linear-gradient(135deg, #1F7A63, #1a5c4a);" title="Voir la description complète">
											<span>👁️</span>
											Voir le produit
										</a>
									</div>
								</div>
							</div>
						{% endif %}
					{% endfor %}
				</div>
			{% endif %}
		</div>
	</section>
	{# ── REASSURANCE ── #}
	<section class="w-full pt-8 pb-10 px-5 relative overflow-hidden border-t border-[#e2ede9]">
		<div class="absolute top-0 -right-[100px] w-[300px] h-[300px] pointer-events-none rounded-full"></div>
		<h2 class="text-[1.5rem] font-bold text-main tracking-[-0.5px] mb-8 text-center relative z-[1] font-display">Nos garanties</h2>
		<div class="max-w-[1200px] mx-auto relative z-[1]" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;">
			<div class="group flex flex-col items-center text-center px-6 py-7 bg-white rounded-xl border border-[#e2ede9] shadow-[0_2px_8px_rgba(0,0,0,.04)] transition-all duration-[250ms] overflow-hidden relative hover:-translate-y-1 hover:shadow-[0_8px_20px_rgba(31,122,99,.12)] hover:border-primary/30">
				<span class="text-[2rem] leading-none mb-4 inline-flex items-center justify-center w-10 h-10 rounded-[10px] transition-all duration-[250ms] group-hover:scale-[1.08]" style="background: linear-gradient(135deg, #e8f5f1 0%, #f0f8f6 100%);">🚚</span>
				<div>
					<p class="text-base font-semibold text-main tracking-[-0.3px] leading-[1.4] transition-colors duration-[250ms] group-hover:text-primary m-0 font-display">Livraison rapide</p>
					<p class="text-[.72rem] text-[#6b8c7d] leading-[1.4] m-0">Expédié sous 24 h</p>
				</div>
			</div>
			<div class="group flex flex-col items-center text-center px-6 py-7 bg-white rounded-xl border border-[#e2ede9] shadow-[0_2px_8px_rgba(0,0,0,.04)] transition-all duration-[250ms] overflow-hidden relative hover:-translate-y-1 hover:shadow-[0_8px_20px_rgba(31,122,99,.12)] hover:border-primary/30">
				<span class="text-[2rem] leading-none mb-4 inline-flex items-center justify-center w-10 h-10 rounded-[10px] transition-all duration-[250ms] group-hover:scale-[1.08]" style="background: linear-gradient(135deg, #e8f5f1 0%, #f0f8f6 100%);">🔄</span>
				<div>
					<p class="text-base font-semibold text-main tracking-[-0.3px] leading-[1.4] transition-colors duration-[250ms] group-hover:text-primary m-0 font-display">Retours faciles</p>
					<p class="text-[.72rem] text-[#6b8c7d] leading-[1.4] m-0">30 jours offerts</p>
				</div>
			</div>
			<div class="group flex flex-col items-center text-center px-6 py-7 bg-white rounded-xl border border-[#e2ede9] shadow-[0_2px_8px_rgba(0,0,0,.04)] transition-all duration-[250ms] overflow-hidden relative hover:-translate-y-1 hover:shadow-[0_8px_20px_rgba(31,122,99,.12)] hover:border-primary/30">
				<span class="text-[2rem] leading-none mb-4 inline-flex items-center justify-center w-10 h-10 rounded-[10px] transition-all duration-[250ms] group-hover:scale-[1.08]" style="background: linear-gradient(135deg, #e8f5f1 0%, #f0f8f6 100%);">🔒</span>
				<div>
					<p class="text-base font-semibold text-main tracking-[-0.3px] leading-[1.4] transition-colors duration-[250ms] group-hover:text-primary m-0 font-display">Paiement sécurisé</p>
					<p class="text-[.72rem] text-[#6b8c7d] leading-[1.4] m-0">Transactions sécurisées</p>
				</div>
			</div>
			<div class="group flex flex-col items-center text-center px-6 py-7 bg-white rounded-xl border border-[#e2ede9] shadow-[0_2px_8px_rgba(0,0,0,.04)] transition-all duration-[250ms] overflow-hidden relative hover:-translate-y-1 hover:shadow-[0_8px_20px_rgba(31,122,99,.12)] hover:border-primary/30">
				<span class="text-[2rem] leading-none mb-4 inline-flex items-center justify-center w-10 h-10 rounded-[10px] transition-all duration-[250ms] group-hover:scale-[1.08]" style="background: linear-gradient(135deg, #e8f5f1 0%, #f0f8f6 100%);">🌱</span>
				<div>
					<p class="text-base font-semibold text-main tracking-[-0.3px] leading-[1.4] transition-colors duration-[250ms] group-hover:text-primary m-0 font-display">Écoresponsable</p>
					<p class="text-[.72rem] text-[#6b8c7d] leading-[1.4] m-0">Emballages recyclés</p>
				</div>
			</div>
		</div>
	</section>

	{% block javascripts %}
		<script src="{{ asset('scripts/hero.js') }}"></script>
	{% endblock %}

{% endblock %}
