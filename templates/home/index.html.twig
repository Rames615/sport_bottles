{% extends 'base.html.twig' %}

{% block title %}Sports Bottles - Bouteilles Durables
{% endblock %}

{% block body %}
	<!-- Hero Section -->
	<section class="hero-section-full">
		<div class="hero-image-container">
			<img src="/heroNew.png" alt="Hero image" class="hero-main-image">
			<div class="hero-overlay"></div>
		</div>
		<div class="hero-content-wrapper">
			<h1 class="hero-title-main">
				<span class="hero-highlight">Des bouteilles durables</span>
				<span class="hero-rest">pour un mode de vie actif</span>
			</h1>

			<p class="hero-subtitle animate-fade-in">
				Sans BPA • Écologiques • Livraison 24–48h
			</p>

			<div class="hero-cta-group">
				<a href="{{ path('app_product') }}" class="btn-cta-primary pulse-primary">
					DÉCOUVRIR NOS PRODUITS
				</a>

				<a href="#products" class="btn-cta-secondary pulse-secondary">
					VOIR PLUS
				</a>
			</div>

		</div>

		<a href="#products" class="scroll-down-btn" aria-label="Scroll down">
			<svg width="24" height="24" viewbox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M7 10L12 15L17 10" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</a>
	</section>

	<!-- Promotions Section -->
	<section class="promotions-section" id="products">
		<div class="container-main">
			<h2 class="section-title">
				<span class="title-icon">🔥</span>
				Nos promotions du moment
			</h2>
			<p class="section-subtitle">Découvrez nos meilleures offres avec des réductions exceptionnelles</p>

			{% if promotions is empty %}
				<div class="no-promotions-message">
					<p>Aucune promotion active pour le moment. Consultez notre
						<a href="{{ path('app_product') }}">catalogue complet</a>.</p>
				</div>
			{% else %}
				<div class="promotions-grid">
					{% for promotion in promotions %}
						{% set product = promotion.getProduct() %}
						{% if product %}
							<div class="promotion-card">
								<div class="promotion-badge-container">
									{% if promotion.getDiscountType() == 'percentage' %}
										<div class="promotion-badge percentage">-{{ promotion.getDiscountValue() }}%</div>
									{% else %}
										<div class="promotion-badge fixed">-{{ promotion.getDiscountValue() }}€</div>
									{% endif %}
									<div class="promotion-label">En promotion</div>
								</div>

								<div
									class="promotion-image-wrapper">
									{# ✅ Utilise promotion.imgPath en priorité, sinon product.imgPath #}
									{% set imgSrc = promotion.imgPath ?? product.imgPath %}
									{% if imgSrc %}
										<img src="{{ asset('products_images/promotion/' ~ imgSrc) }}" alt="{{ product.designation }}" class="promotion-image" onerror="this.src='{{ asset('images/placeholder.png') }}'">
									{% else %}
										<img src="{{ asset('images/placeholder.png') }}" alt="{{ product.designation }}" class="promotion-image">
									{% endif %}
								</div>

								<div class="promotion-content">
									<h3 class="promotion-title">{{ product.designation }}</h3>

									{% if promotion.getDescription() %}
										<p class="promotion-description">{{ promotion.getDescription() }}</p>
									{% endif %}

									{# ✅ Dates de la promotion #}
									<div class="promotion-dates">
										<span class="date-item">
											<span class="date-icon">📅</span>
											Du
											<strong>{{ promotion.getStartAt() | date('d/m/Y') }}</strong>
											au
											<strong>{{ promotion.getEndAt() | date('d/m/Y') }}</strong>
										</span>
										{# Calcul des jours restants #}
										{% set daysLeft = (promotion.getEndAt().getTimestamp() - date().getTimestamp()) / 86400 %}
										{% if daysLeft > 0 %}
											<span class="days-left">
												⏳ Plus que
												{{ daysLeft | round(0, 'ceil') }}
												jour
												{% if daysLeft > 1 %}s
												{% endif %}
											</span>
										{% endif %}
									</div>

									<div class="promotion-specs">
										{% if product.capacity %}
											<span class="spec-item">
												<span class="spec-icon">📦</span>
												{{ product.capacity }}
											</span>
										{% endif %}
										{% if product.temperature %}
											<span class="spec-item">
												<span class="spec-icon">🌡️</span>
												{{ product.temperature }}
											</span>
										{% endif %}
									</div>

									<div class="promotion-pricing">
										<div class="price-container">
											<span class="original-price">{{ product.price }}€</span>
											<span class="final-price">{{ product.getFinalPrice() | number_format(2, ',', ' ') }}€</span>
										</div>
										<div class="savings">
											Économisez:
											{% if promotion.getDiscountType() == 'percentage' %}
												<strong>{{ (product.price - product.getFinalPrice()) | number_format(2, ',', ' ') }}€</strong>
											{% else %}
												<strong>{{ promotion.getDiscountValue() }}€</strong>
											{% endif %}
										</div>
									</div>

									<form method="post" action="{{ path('app_cartadd', {id: product.id}) }}" class="add-to-cart-form-promo">
										<input type="hidden" name="_token" value="{{ csrf_token('cart_add') }}">
										<button type="submit" class="btn-add-promotion" data-product-id="{{ product.id }}" title="Ajouter {{ product.designation }} au panier">
											<span class="btn-icon">🛒</span>
											Ajouter au panier
										</button>
									</form>
								</div>
							</div>
						{% endif %}
					{% endfor %}
				</div>
			{% endif %}
		</div>
	</section>
	<!-- Reassurance Section -->
	<section class="reassurance-section">
		<h2 class="section-title">Nos garanties</h2>
		<div class="reassurance-container">
			<div class="reassurance-card">
				<div class="reassurance-icon">🚚</div>
				<h3 class="reassurance-title">Livraison rapide</h3>
			</div>
			<div class="reassurance-card">
				<div class="reassurance-icon">🔄</div>
				<h3 class="reassurance-title">Retours faciles</h3>
			</div>
			<div class="reassurance-card">
				<div class="reassurance-icon">🔒</div>
				<h3 class="reassurance-title">Paiement sécurisé</h3>
			</div>
			<div class="reassurance-card">
				<div class="reassurance-icon">🌱</div>
				<h3 class="reassurance-title">Écoresponsable</h3>
			</div>
		</div>
	</section>

	{# Ajouter lien JS depuis le hero.js pour fait ajouter le produits de la section promotion' #}
	{% block javascripts %}
        <script src="{{ asset('scripts/hero.js') }}"></script>
    {% endblock %}

{% endblock %}
