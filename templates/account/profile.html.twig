{% extends 'base.html.twig' %}

{% block title %}Mon Profil
{% endblock %}

{% block body %}
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-24 mb-16">
		<div class="flex justify-center">
			<div class="w-full max-w-2xl">

				<h1 class="flex items-center gap-2 text-2xl font-bold text-gray-900 mb-6">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
						<path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.029 10 8 10c-2.029 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
					</svg>
					Mon Profil
				</h1>

				{# data-bs-dismiss="alert" requires Bootstrap JS; dismiss button is non-functional until replaced #}
				{% for message in app.flashes('success') %}
					<div class="flex items-start gap-3 p-4 mb-4 bg-green-50 border border-green-200 text-green-700 rounded-lg" role="alert">
						<strong>Succès :</strong>
						{{ message }}
						<button type="button" class="ml-auto text-green-500 hover:text-green-700" data-bs-dismiss="alert" aria-label="Fermer">✕</button>
					</div>
				{% endfor %}

				{% for message in app.flashes('error') %}
					<div class="flex items-start gap-3 p-4 mb-4 bg-red-50 border border-red-200 text-red-700 rounded-lg" role="alert">
						<strong>Erreur :</strong>
						{{ message }}
						<button type="button" class="ml-auto text-red-500 hover:text-red-700" data-bs-dismiss="alert" aria-label="Fermer">✕</button>
					</div>
				{% endfor %}

				{# ── Account info ── #}
				<div class="bg-white rounded-xl border border-gray-100 shadow-sm mb-4">
					<div class="flex items-center justify-between px-6 py-4 bg-gray-900 rounded-t-xl">
						<h5 class="text-base font-semibold text-white m-0">Informations du compte</h5>
						<a href="{{ path('app_profile_edit') }}" class="inline-flex items-center gap-1 px-3 py-1.5 bg-white text-gray-900 text-xs font-medium rounded-md hover:bg-gray-100 transition-colors" aria-label="Éditer les informations du profil">
							<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
								<path d="M12.146.854a.5.5 0 0 1 .708 0l2.292 2.292a.5.5 0 0 1 0 .708l-10.5 10.5A.5.5 0 0 1 3.5 14.5h-3a.5.5 0 0 1-.5-.5v-3a.5.5 0 0 1 .146-.354l10.5-10.5zM11.207 2.5 13.5 4.793 2.5 15.793h-2.293v-2.293L11.207 2.5z"/>
							</svg>
							Éditer
						</a>
					</div>
					<div class="p-6 divide-y divide-gray-100">
						<div class="flex gap-4 pb-3 mb-3">
							<div class="w-1/3 text-sm font-semibold text-gray-500">E-mail</div>
							<div class="text-sm text-gray-900">{{ app.user.email }}</div>
						</div>
						<div class="flex gap-4 py-3 mb-3">
							<div class="w-1/3 text-sm font-semibold text-gray-500">Statut du compte</div>
							<div>
								{% if app.user.isVerified %}
									<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Vérifié</span>
								{% else %}
									<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">Non vérifié</span>
								{% endif %}
							</div>
						</div>
						<div class="flex gap-4 pt-3">
							<div class="w-1/3 text-sm font-semibold text-gray-500">Rôle</div>
							<div>
								{% if 'ROLE_ADMIN' in app.user.roles %}
									<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Administrateur</span>
								{% else %}
									<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">Utilisateur</span>
								{% endif %}
							</div>
						</div>
					</div>
				</div>

				{# ── Shipping addresses ── #}
				<div class="bg-white rounded-xl border border-gray-100 shadow-sm mb-4">
					<div class="px-6 py-4 bg-gray-900 rounded-t-xl">
						<h5 class="text-base font-semibold text-white m-0">Adresses de livraison</h5>
					</div>
					<div class="p-6">
						{% if app.user.shippingAddresses is not empty %}
							{% for addr in app.user.shippingAddresses %}
								<div class="{% if not loop.last %}border-b border-gray-100 pb-4 mb-4{% endif %}">
									<p class="font-semibold text-gray-900 mb-0.5">{{ addr.fullName }}</p>
									<p class="mb-0.5 text-sm text-gray-500">{{ addr.address }}</p>
									<p class="mb-0.5 text-sm text-gray-500">{{ addr.postalCode }}
										{{ addr.city }},
										{{ addr.country }}</p>
									<p class="mb-0 text-sm text-gray-500 flex items-center gap-1">
										<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
											<path d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328zM1.884.511a1.745 1.745 0 0 1 2.612.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.678.678 0 0 0 .178.643l2.457 2.457a.678.678 0 0 0 .644.178l2.189-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511z"/>
										</svg>
										{{ addr.phone }}
									</p>
								</div>
							{% endfor %}
						{% else %}
							<p class="text-sm text-gray-500 m-0">Aucune adresse de livraison enregistrée.</p>
						{% endif %}
					</div>
				</div>

				{# ── Quick links ── #}
				<div class="flex gap-3">
					<a href="{{ path('app_orders') }}" class="inline-flex items-center gap-1.5 px-4 py-2 border border-gray-900 text-gray-900 text-sm font-medium rounded-md hover:bg-gray-50 transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
							<path d="M0 2.5A.5.5 0 0 1 .5 2H2a.5.5 0 0 1 .485.379L2.89 4H14.5a.5.5 0 0 1 .485.621l-1.5 6A.5.5 0 0 1 13 11H4a.5.5 0 0 1-.485-.379L1.61 3H.5a.5.5 0 0 1-.5-.5z"/>
						</svg>
						Mes Commandes
					</a>
					<a href="{{ path('app_product') }}" class="inline-flex items-center px-4 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-md hover:bg-gray-50 transition-colors">
						Continuer mes achats
					</a>
				</div>

			</div>
		</div>
	</div>
{% endblock %}
