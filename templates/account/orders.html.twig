{% extends 'base.html.twig' %}

{% block title %}Mes Commandes
{% endblock %}

{% block body %}
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-24 mb-16">
		<div class="flex justify-center">
			<div class="w-full max-w-4xl">

				<h1 class="flex items-center gap-2 text-2xl font-bold text-gray-900 mb-6">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewbox="0 0 16 16">
						<path d="M0 2.5A.5.5 0 0 1 .5 2H2a.5.5 0 0 1 .485.379L2.89 4H14.5a.5.5 0 0 1 .485.621l-1.5 6A.5.5 0 0 1 13 11H4a.5.5 0 0 1-.485-.379L1.61 3H.5a.5.5 0 0 1-.5-.5zM3.14 5l1.25 5h8.22l1.25-5H3.14zM5 13a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0zm9-1a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm-2 1a2 2 0 1 1 4 0 2 2 0 0 1-4 0z"/>
					</svg>
					Mes Commandes
				</h1>

				{% if orders is not empty %}
					<div class="overflow-x-auto rounded-xl shadow-green-sm border border-gray-100">
						<table class="w-full text-sm">
							<thead class="bg-gray-900 text-white">
								<tr>
									<th class="px-4 py-3 text-left font-semibold">Référence</th>
									<th class="px-4 py-3 text-left font-semibold">Date</th>
									<th class="px-4 py-3 text-left font-semibold">Montant</th>
									<th class="px-4 py-3 text-left font-semibold">Adresse de livraison</th>
									<th class="px-4 py-3 text-left font-semibold">Statut</th>
								</tr>
							</thead>
							<tbody class="bg-white divide-y divide-gray-100">
								{% for order in orders %}
									<tr class="hover:bg-gray-50 transition-colors">
										<td class="px-4 py-3 font-semibold text-gray-900">{{ order.reference }}</td>
										<td class="px-4 py-3 text-gray-600">{{ order.createdAt|date('d/m/Y à H:i') }}</td>
										<td class="px-4 py-3 font-semibold text-gray-900">{{ (order.totalAmount / 100)|number_format(2, ',', ' ') }}
											€</td>
										<td class="px-4 py-3 text-gray-500 text-xs">{{ order.shippingAddress|default('—') }}</td>
										<td class="px-4 py-3">
											{% if order.status == 'paid' %}
												<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Payée</span>
											{% elseif order.status == 'pending' %}
												<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">En attente</span>
											{% elseif order.status == 'cancelled' %}
												<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Annulée</span>
											{% elseif order.status == 'refunded' %}
												<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Remboursée</span>
											{% else %}
												<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">{{ order.status|capitalize }}</span>
											{% endif %}
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				{% else %}
					<div class="bg-white rounded-xl border border-gray-100 shadow-sm">
						<div class="p-6 text-center py-12">
							<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="text-gray-400 mx-auto mb-4" viewbox="0 0 16 16">
								<path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1zm3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4h-3.5zM2 5h12v9a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5z"/>
							</svg>
							<h5 class="text-gray-500 font-semibold mb-2">Aucune commande pour le moment</h5>
							<p class="text-gray-500 mb-4">Vous n'avez pas encore passé de commande.</p>
							<a href="{{ path('app_product') }}" class="inline-flex items-center px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-md hover:bg-gray-700 transition-colors">
								Découvrir nos produits
							</a>
						</div>
					</div>
				{% endif %}

				<div class="mt-6">
					<a href="{{ path('app_profile') }}" class="inline-flex items-center gap-1.5 px-4 py-2 border border-gray-900 text-gray-900 text-sm font-medium rounded-md hover:bg-gray-50 transition-colors">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewbox="0 0 16 16">
							<path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4z"/>
						</svg>
						Retour au profil
					</a>
				</div>

			</div>
		</div>
	</div>
{% endblock %}
