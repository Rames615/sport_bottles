{% extends 'base.html.twig' %}

{% block title %}Éditer mon Profil - Sports Bottles{% endblock %}

{% block body %}
<div class="container mt-5 pt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <h1 class="mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="me-2 mb-1" viewBox="0 0 16 16">
                    <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9 3.5 9.207l6.5 6.5.207-.207zm-7.468 7.468A.5.5 0 0 1 3 13.5V11a.5.5 0 0 1 .146-.354l7.1-7.1a.5.5 0 1 1 .708.708l-7.1 7.1A.5.5 0 0 1 3 13.5v2.5a.5.5 0 0 1-.146.354l-.354.354z"/>
                </svg>
                Éditer mon Profil
            </h1>

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <strong>Succès :</strong> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Erreur :</strong> {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Modifier vos informations</h5>
                </div>

                <div class="card-body">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'needs-validation'}}) }}

                        <div class="mb-3">
                            {{ form_label(form.email, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                            {{ form_widget(form.email, {
                                'attr': {
                                    'class': 'form-control' ~ (not form.email.vars.valid ? ' is-invalid' : ''),
                                    'placeholder': 'votre@email.com',
                                }
                            }) }}
                            {% if not form.email.vars.valid %}
                                <div class="invalid-feedback d-block">
                                    {% for error in form.email.vars.errors %}
                                        {{ error.message }}<br>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-4" aria-label="Enregistrer les modifications">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1 mb-1" viewBox="0 0 16 16">
                                    <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.71l-5.223 2.207A.5.5 0 0 1 2 15.5V2zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1H4z"/>
                                </svg>
                                Enregistrer
                            </button>
                            <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary px-4" aria-label="Annuler et retourner au profil">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-1 mb-1" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14zm0 1A8 8 0 1 1 8 0a8 8 0 0 1 0 16zm.354-11.354a.5.5 0 0 0-.708.708L10.293 8 7.646 10.646a.5.5 0 1 0 .708.708L11 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L11.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L11 7.293 8.354 4.646z"/>
                                </svg>
                                Annuler
                            </a>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>

            <div class="mt-4">
                <div class="alert alert-info d-flex gap-2" role="status">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="flex-shrink-0 mt-1" viewBox="0 0 16 16">
                        <path d="m11.596 8.697-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393z"/>
                    </svg>
                    <div>
                        <strong>Info :</strong> Seul votre adresse email peut être modifiée. Pour changer votre mot de passe, veuillez utiliser la <a href="{{ path('app_forgot_password') }}" class="alert-link">réinitialisation de mot de passe</a>.
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
