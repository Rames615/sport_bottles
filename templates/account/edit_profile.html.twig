{% extends 'base.html.twig' %}

{% block title %}Éditer mon Profil - Sports Bottles{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-24 mb-16">
    <div class="flex justify-center">
        <div class="w-full max-w-lg">

            <h1 class="flex items-center gap-2 text-2xl font-bold text-gray-900 mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9 3.5 9.207l6.5 6.5.207-.207zm-7.468 7.468A.5.5 0 0 1 3 13.5V11a.5.5 0 0 1 .146-.354l7.1-7.1a.5.5 0 1 1 .708.708l-7.1 7.1A.5.5 0 0 1 3 13.5v2.5a.5.5 0 0 1-.146.354l-.354.354z"/>
                </svg>
                Éditer mon Profil
            </h1>

            {# TODO: Bootstrap JS removed — replace with Stimulus controller or Alpine.js #}
            {# data-bs-dismiss="alert" requires Bootstrap JS; dismiss button is non-functional until replaced #}
            {% for message in app.flashes('success') %}
                <div class="flex items-start gap-3 p-4 mb-4 bg-green-50 border border-green-200 text-green-700 rounded-lg" role="alert">
                    <strong>Succès :</strong> {{ message }}
                    <button type="button" class="ml-auto text-green-500 hover:text-green-700" data-bs-dismiss="alert" aria-label="Fermer">✕</button>
                </div>
            {% endfor %}

            {% for message in app.flashes('error') %}
                <div class="flex items-start gap-3 p-4 mb-4 bg-red-50 border border-red-200 text-red-700 rounded-lg" role="alert">
                    <strong>Erreur :</strong> {{ message }}
                    <button type="button" class="ml-auto text-red-500 hover:text-red-700" data-bs-dismiss="alert" aria-label="Fermer">✕</button>
                </div>
            {% endfor %}

            <div class="bg-white rounded-xl border border-gray-100 shadow-sm">
                <div class="flex items-center px-6 py-4 bg-gray-900 rounded-t-xl">
                    <h5 class="text-base font-semibold text-white m-0">Modifier vos informations</h5>
                </div>

                <div class="p-6">
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                        <div class="flex flex-col gap-1 mb-5">
                            {{ form_label(form.email, null, {'label_attr': {'class': 'text-sm font-semibold text-gray-700'}}) }}
                            {{ form_widget(form.email, {
                                'attr': {
                                    'class': 'w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-primary' ~ (not form.email.vars.valid ? ' border-red-500 focus:ring-red-500' : ' border-gray-300'),
                                    'placeholder': 'votre@email.com',
                                }
                            }) }}
                            {% if not form.email.vars.valid %}
                                <div class="text-sm text-red-600 mt-1">
                                    {% for error in form.email.vars.errors %}
                                        {{ error.message }}<br>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </div>

                        <div class="flex gap-2">
                            <button type="submit" class="inline-flex items-center gap-1.5 px-5 py-2 bg-primary text-white text-sm font-medium rounded-md hover:bg-green-dark transition-colors" aria-label="Enregistrer les modifications">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M2 2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v13.5a.5.5 0 0 1-.777.416L8 13.71l-5.223 2.207A.5.5 0 0 1 2 15.5V2zm2-1a1 1 0 0 0-1 1v12.566l4.723-2.482a.5.5 0 0 1 .554 0L13 14.566V2a1 1 0 0 0-1-1H4z"/>
                                </svg>
                                Enregistrer
                            </button>
                            <a href="{{ path('app_profile') }}" class="inline-flex items-center gap-1.5 px-5 py-2 border border-gray-300 text-gray-700 text-sm font-medium rounded-md hover:bg-gray-50 transition-colors" aria-label="Annuler et retourner au profil">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14zm0 1A8 8 0 1 1 8 0a8 8 0 0 1 0 16zm.354-11.354a.5.5 0 0 0-.708.708L10.293 8 7.646 10.646a.5.5 0 1 0 .708.708L11 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L11.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L11 7.293 8.354 4.646z"/>
                                </svg>
                                Annuler
                            </a>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>

            <div class="mt-4">
                <div class="flex items-start gap-3 p-4 bg-blue-50 border border-blue-200 text-blue-700 rounded-lg" role="status">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="flex-shrink-0 mt-0.5" viewBox="0 0 16 16">
                        <path d="m11.596 8.697-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393z"/>
                    </svg>
                    <div>
                        <strong>Info :</strong> Seul votre adresse email peut être modifiée. Pour changer votre mot de passe, veuillez utiliser la <a href="{{ path('app_forgot_password') }}" class="font-medium underline hover:text-blue-800">réinitialisation de mot de passe</a>.
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}
