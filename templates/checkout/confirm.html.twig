{% extends 'base.html.twig' %}

{% block title %}Valider ma commande — Sports Bottles{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

<div class="container" style="margin-top: 100px; margin-bottom: 60px;">

    <!-- Progress steps -->
    <div class="d-flex align-items-center justify-content-center gap-0 mb-5">
        <!-- Step 1: Livraison (done) -->
        <div class="d-flex align-items-center gap-2">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:32px;height:32px;background:#1a8a5a;flex-shrink:0;">
                <i class="bi bi-check text-white" style="font-size:.85rem;"></i>
            </div>
            <span class="small fw-semibold d-none d-sm-inline" style="color:#1a8a5a;">Livraison</span>
        </div>
        <div style="width:48px;height:2px;background:#1a8a5a;margin:0 6px;"></div>

        <!-- Step 2: Confirmation (active) -->
        <div class="d-flex align-items-center gap-2">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:32px;height:32px;background:#1a8a5a;flex-shrink:0;">
                <span class="small fw-bold text-white">2</span>
            </div>
            <span class="small fw-bold d-none d-sm-inline" style="color:#1a8a5a;">Confirmation</span>
        </div>
        <div style="width:48px;height:2px;background:#dee2e6;margin:0 6px;"></div>

        <!-- Step 3: Paiement (upcoming) -->
        <div class="d-flex align-items-center gap-2">
            <div class="rounded-circle d-flex align-items-center justify-content-center"
                 style="width:32px;height:32px;background:#e9ecef;flex-shrink:0;">
                <span class="small fw-bold text-muted">3</span>
            </div>
            <span class="small fw-semibold text-muted d-none d-sm-inline">Paiement</span>
        </div>
    </div>

    <!-- Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="rounded-circle d-flex align-items-center justify-content-center"
             style="width:48px;height:48px;background:#e8f5e9;">
            <i class="bi bi-bag-check text-success fs-4"></i>
        </div>
        <div>
            <h1 class="h3 fw-bold mb-0" style="color:#0f1923;">Récapitulatif de la commande</h1>
            <p class="text-muted small mb-0">Vérifiez votre panier avant de choisir votre mode de paiement</p>
        </div>
    </div>

    <div class="row g-4">

        <!-- Left: Cart items -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom rounded-top-4 py-3 px-4">
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-list-check text-success me-2"></i>
                        Articles du panier
                    </h5>
                </div>
                <div class="card-body p-0">

                    {# Desktop table #}
                    <div class="d-none d-md-block">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="px-4 py-3 fw-semibold text-muted small text-uppercase">Produit</th>
                                    <th class="text-center py-3 fw-semibold text-muted small text-uppercase">Qté</th>
                                    <th class="text-end py-3 fw-semibold text-muted small text-uppercase">Prix unit.</th>
                                    <th class="text-end px-4 py-3 fw-semibold text-muted small text-uppercase">Sous-total</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in cart.items %}
                                    <tr>
                                        <td class="px-4 py-3">
                                            <div class="fw-semibold" style="color:#0f1923;">{{ item.product.designation }}</div>
                                            {% if item.product.capacity is defined and item.product.capacity %}
                                                <small class="text-muted">{{ item.product.capacity }}</small>
                                            {% endif %}
                                        </td>
                                        <td class="text-center py-3">
                                            <span class="badge rounded-pill"
                                                  style="background:#e8f5e9;color:#1a8a5a;font-size:.85rem;padding:6px 12px;">
                                                {{ item.quantity }}
                                            </span>
                                        </td>
                                        <td class="text-end py-3 text-muted">{{ item.unitPrice|number_format(2, ',', ' ') }} €</td>
                                        <td class="text-end px-4 py-3 fw-bold" style="color:#0f1923;">{{ item.subtotal|number_format(2, ',', ' ') }} €</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    {# Mobile cards #}
                    <div class="d-md-none p-3">
                        {% for item in cart.items %}
                            <div class="border rounded-3 p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div>
                                        <div class="fw-semibold" style="color:#0f1923;">{{ item.product.designation }}</div>
                                        {% if item.product.capacity is defined and item.product.capacity %}
                                            <small class="text-muted">{{ item.product.capacity }}</small>
                                        {% endif %}
                                    </div>
                                    <span class="badge rounded-pill ms-2" style="background:#e8f5e9;color:#1a8a5a;">
                                        ×{{ item.quantity }}
                                    </span>
                                </div>
                                <hr class="my-2">
                                <div class="d-flex justify-content-between">
                                    <small class="text-muted">Prix unit. : <strong>{{ item.unitPrice|number_format(2, ',', ' ') }} €</strong></small>
                                    <strong style="color:#1a8a5a;">{{ item.subtotal|number_format(2, ',', ' ') }} €</strong>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Shipping info -->
            <div class="card border-0 shadow-sm rounded-4 mt-3">
                <div class="card-body py-3 px-4 d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:#e8f5e9;flex-shrink:0;">
                        <i class="bi bi-truck text-success"></i>
                    </div>
                    <div>
                        <div class="fw-semibold small" style="color:#0f1923;">Livraison gratuite</div>
                        <div class="text-muted small">Livraison estimée sous 3–5 jours ouvrés</div>
                    </div>
                    <span class="ms-auto fw-bold text-success">Gratuite</span>
                </div>
            </div>
        </div>

        <!-- Right: Summary + CTA -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top:100px;">
                <div class="card-header bg-white border-bottom rounded-top-4 py-3 px-4">
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-receipt text-success me-2"></i>
                        Résumé
                    </h5>
                </div>
                <div class="card-body px-4 py-4">

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Sous-total</span>
                        <span class="fw-semibold">{{ total|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Livraison</span>
                        <span class="fw-semibold text-success">Gratuite</span>
                    </div>

                    <hr>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold fs-5" style="color:#0f1923;">Total</span>
                        <span class="fw-bold fs-4" style="color:#1a8a5a;">{{ total|number_format(2, ',', ' ') }} €</span>
                    </div>

                    {# ── CHANGED: now links to checkout_method instead of submitting directly ── #}
                    <a href="{{ path('checkout_method') }}"
                       class="btn w-100 fw-semibold py-3 mb-2 rounded-3 text-white text-decoration-none d-flex align-items-center justify-content-center gap-2"
                       style="background:linear-gradient(135deg,#1a8a5a,#34d18a);border:none;font-size:1rem;transition:opacity .2s;"
                       onmouseover="this.style.opacity='.9'" onmouseout="this.style.opacity='1'">
                        <i class="bi bi-credit-card"></i>
                        Choisir le paiement
                        <i class="bi bi-arrow-right"></i>
                    </a>

                    <a href="{{ path('app_cartindex') }}"
                       class="btn btn-outline-secondary w-100 rounded-3 py-2">
                        <i class="bi bi-arrow-left me-1"></i> Retour au panier
                    </a>

                    <div class="d-flex align-items-center justify-content-center gap-2 mt-3 text-muted small">
                        <i class="bi bi-shield-lock-fill text-success"></i>
                        Paiement sécurisé par Stripe
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}
