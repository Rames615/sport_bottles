{% extends 'base.html.twig' %}

{% block title %}Valider ma commande — Sports Bottles
{% endblock %}

{% block body %}

	<div
		class="max-w-5xl mx-auto px-4 sm:px-6 mt-24 mb-16">

		<!-- Progress steps -->
		<div
			class="flex items-center justify-center gap-0 mb-10">
			<!-- Step 1: Livraison (done) -->
			<div class="flex items-center gap-2">
				<div class="w-8 h-8 rounded-full flex items-center justify-center bg-[#1a8a5a] shrink-0">
					<i class="bi bi-check text-white" style="font-size:.85rem;"></i>
				</div>
				<span class="hidden sm:inline text-sm font-semibold text-[#1a8a5a]">Livraison</span>
			</div>
			<div class="w-12 h-0.5 bg-[#1a8a5a] mx-1.5"></div>

			<!-- Step 2: Confirmation (active) -->
			<div class="flex items-center gap-2">
				<div class="w-8 h-8 rounded-full flex items-center justify-center bg-[#1a8a5a] shrink-0">
					<span class="text-sm font-bold text-white">2</span>
				</div>
				<span class="hidden sm:inline text-sm font-bold text-[#1a8a5a]">Confirmation</span>
			</div>
			<div class="w-12 h-0.5 bg-gray-200 mx-1.5"></div>

			<!-- Step 3: Paiement (upcoming) -->
			<div class="flex items-center gap-2">
				<div class="w-8 h-8 rounded-full flex items-center justify-center bg-gray-200 shrink-0">
					<span class="text-sm font-bold text-gray-500">3</span>
				</div>
				<span class="hidden sm:inline text-sm font-semibold text-gray-500">Paiement</span>
			</div>
		</div>

		<!-- Header -->
		<div class="flex items-center gap-3 mb-6">
			<div class="w-12 h-12 rounded-full flex items-center justify-center bg-green-50 shrink-0">
				<i class="bi bi-bag-check text-green-600 text-xl"></i>
			</div>
			<div>
				<h1 class="text-2xl font-bold text-gray-900 mb-0">Récapitulatif de la commande</h1>
				<p class="text-sm text-gray-500 mb-0">Vérifiez votre panier avant de choisir votre mode de paiement</p>
			</div>
		</div>

		<div
			class="flex flex-col lg:flex-row gap-6">

			<!-- Left: Cart items -->
			<div class="w-full lg:w-2/3">
				<div class="bg-white rounded-2xl border border-gray-100 shadow-sm">
					<div class="bg-white border-b border-gray-100 rounded-t-2xl py-3 px-5">
						<h5 class="text-base font-semibold text-gray-900 m-0">
							<i class="bi bi-list-check text-green-600 mr-2"></i>
							Articles du panier
						</h5>
					</div>
					<div
						class="p-0">

						{# Desktop table #}
						<div class="hidden md:block overflow-x-auto">
							<table class="w-full text-sm">
								<thead class="bg-gray-50 border-b border-gray-100">
									<tr>
										<th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Produit</th>
										<th class="py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Qté</th>
										<th class="py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Prix unit.</th>
										<th class="px-5 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Sous-total</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-gray-50">
									{% for item in cart.items %}
										<tr class="hover:bg-gray-50 transition-colors">
											<td class="px-5 py-3">
												<div class="font-semibold text-gray-900">{{ item.product.designation }}</div>
												{% if item.product.capacity is defined and item.product.capacity %}
													<small class="text-xs text-gray-500">{{ item.product.capacity }}</small>
												{% endif %}
											</td>
											<td class="py-3 text-center">
												<span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-50 text-[#1a8a5a]">
													{{ item.quantity }}
												</span>
											</td>
											<td class="py-3 text-right text-gray-500">{{ item.unitPrice|number_format(2, ',', ' ') }}
												€</td>
											<td class="px-5 py-3 text-right font-bold text-gray-900">{{ item.subtotal|number_format(2, ',', ' ') }}
												€</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						</div>

						{# Mobile cards #}
						<div class="md:hidden p-4">
							{% for item in cart.items %}
								<div class="border border-gray-200 rounded-xl p-3 mb-3">
									<div class="flex justify-between items-start mb-2">
										<div>
											<div class="font-semibold text-gray-900">{{ item.product.designation }}</div>
											{% if item.product.capacity is defined and item.product.capacity %}
												<small class="text-xs text-gray-500">{{ item.product.capacity }}</small>
											{% endif %}
										</div>
										<span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-50 text-[#1a8a5a]">
											×{{ item.quantity }}
										</span>
									</div>
									<hr class="border-t border-gray-100 my-2">
									<div class="flex justify-between text-sm">
										<span class="text-gray-500">Prix unit. :
											<strong>{{ item.unitPrice|number_format(2, ',', ' ') }}
												€</strong>
										</span>
										<strong class="text-[#1a8a5a]">{{ item.subtotal|number_format(2, ',', ' ') }}
											€</strong>
									</div>
								</div>
							{% endfor %}
						</div>
					</div>
				</div>

				<!-- Shipping info -->
				<div class="bg-white rounded-2xl border border-gray-100 shadow-sm mt-3">
					<div class="py-3 px-5 flex items-center gap-3">
						<div class="w-10 h-10 rounded-full flex items-center justify-center bg-green-50 shrink-0">
							<i class="bi bi-truck text-green-600"></i>
						</div>
						<div>
							<div class="text-sm font-semibold text-gray-900">Livraison gratuite</div>
							<div class="text-xs text-gray-500">Livraison estimée sous 3–5 jours ouvrés</div>
						</div>
						<span class="ml-auto font-bold text-green-600">Gratuite</span>
					</div>
				</div>
			</div>

			<!-- Right: Summary + CTA -->
			<div class="w-full lg:w-1/3">
				<div class="bg-white rounded-2xl border border-gray-100 shadow-sm sticky top-24">
					<div class="bg-white border-b border-gray-100 rounded-t-2xl py-3 px-5">
						<h5 class="text-base font-semibold text-gray-900 m-0">
							<i class="bi bi-receipt text-green-600 mr-2"></i>
							Résumé
						</h5>
					</div>
					<div class="px-5 py-5">

						<div class="flex justify-between mb-2">
							<span class="text-gray-500 text-sm">Sous-total</span>
							<span class="font-semibold text-sm">{{ total|number_format(2, ',', ' ') }}
								€</span>
						</div>
						<div class="flex justify-between mb-4">
							<span class="text-gray-500 text-sm">Livraison</span>
							<span class="font-semibold text-sm text-green-600">Gratuite</span>
						</div>

						<hr class="border-t border-gray-100 my-4">

						<div class="flex justify-between items-center mb-6">
							<span class="font-bold text-lg text-gray-900">Total</span>
							<span class="font-bold text-2xl text-[#1a8a5a]">{{ total|number_format(2, ',', ' ') }}
								€</span>
						</div>

						<a href="{{ path('checkout_method') }}" class="flex w-full items-center justify-center gap-2 py-3 mb-2 rounded-xl text-white text-sm font-semibold no-underline transition-opacity hover:opacity-90" style="background:linear-gradient(135deg,#1a8a5a,#34d18a);">
							<i class="bi bi-credit-card"></i>
							Choisir le paiement
							<i class="bi bi-arrow-right"></i>
						</a>

						<a href="{{ path('app_cartindex') }}" class="flex w-full items-center justify-center gap-2 py-2.5 border border-gray-300 text-gray-700 text-sm font-medium rounded-xl hover:bg-gray-50 transition-colors">
							<i class="bi bi-arrow-left"></i>
							Retour au panier
						</a>

						<div class="flex items-center justify-center gap-2 mt-4 text-gray-400 text-xs">
							<i class="bi bi-shield-lock-fill text-green-600"></i>
							Paiement sécurisé par Stripe
						</div>
					</div>
				</div>
			</div>

		</div>
	</div>
{% endblock %}
