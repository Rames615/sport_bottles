{% extends 'base.html.twig' %}

{% block title %}Adresse de livraison - Sports Bottles
{% endblock %}

{% block body %}
	<div
		class="max-w-5xl mx-auto px-4 sm:px-6 mt-24 mb-16">

		<!-- Header -->
		<div class="flex items-center gap-3 mb-6">
			<div class="w-12 h-12 rounded-full flex items-center justify-center bg-green-50 shrink-0">
				<i class="bi bi-geo-alt text-green-600 text-xl"></i>
			</div>
			<div>
				<h1 class="text-2xl font-bold text-gray-900 mb-0">Adresse de livraison</h1>
				<p class="text-sm text-gray-500 mb-0">Saisissez les informations de livraison</p>
			</div>
		</div>

		<div
			class="flex flex-col lg:flex-row gap-6">
			<!-- Form -->
			<div class="w-full lg:w-2/3">
				<div class="bg-white rounded-2xl border border-gray-100 shadow-sm">
					<div class="bg-white border-b border-gray-100 rounded-t-2xl py-3 px-5">
						<h5 class="text-base font-semibold text-gray-900 m-0">
							<i class="bi bi-house text-green-600 mr-2"></i>
							Informations de livraison
						</h5>
					</div>
					<div class="p-6 md:p-8">

						{% include 'components/_flash_messages.html.twig' %}

						<form method="post" class="needs-validation" novalidate>
							{% if form._token is defined %}
								<input type="hidden" name="{{ form._token.vars.full_name }}" value="{{ form._token.vars.value }}">
							{% endif %}

							<div
								class="grid grid-cols-1 md:grid-cols-2 gap-4">
								<!-- Nom complet -->
								<div class="md:col-span-2">
									<label for="shipping_address_fullName" class="block text-sm font-semibold text-gray-700 mb-1">
										{{ form.fullName.vars.label }}
										<span class="text-red-500">*</span>
									</label>
									{% if form.fullName.vars.errors|length > 0 %}
										<div class="text-sm text-red-600 mb-2">
											{% for error in form.fullName.vars.errors %}
												<div>{{ error.message }}</div>
											{% endfor %}
										</div>
									{% endif %}
									<input type="text" id="shipping_address_fullName" name="{{ form.fullName.vars.full_name }}" class="w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 {{ form.fullName.vars.errors|length > 0 ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-primary' }}" value="{{ form.fullName.vars.value ?? '' }}" placeholder="Jean Dupont" required>
								</div>

								<!-- Adresse -->
								<div class="md:col-span-2">
									<label for="shipping_address_address" class="block text-sm font-semibold text-gray-700 mb-1">
										{{ form.address.vars.label }}
										<span class="text-red-500">*</span>
									</label>
									{% if form.address.vars.errors|length > 0 %}
										<div class="text-sm text-red-600 mb-2">
											{% for error in form.address.vars.errors %}
												<div>{{ error.message }}</div>
											{% endfor %}
										</div>
									{% endif %}
									<input type="text" id="shipping_address_address" name="{{ form.address.vars.full_name }}" class="w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 {{ form.address.vars.errors|length > 0 ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-primary' }}" value="{{ form.address.vars.value ?? '' }}" placeholder="123 Rue de la Paix" required>
								</div>

								<!-- Ville -->
								<div>
									<label for="shipping_address_city" class="block text-sm font-semibold text-gray-700 mb-1">
										{{ form.city.vars.label }}
										<span class="text-red-500">*</span>
									</label>
									{% if form.city.vars.errors|length > 0 %}
										<div class="text-sm text-red-600 mb-2">
											{% for error in form.city.vars.errors %}
												<div>{{ error.message }}</div>
											{% endfor %}
										</div>
									{% endif %}
									<input type="text" id="shipping_address_city" name="{{ form.city.vars.full_name }}" class="w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 {{ form.city.vars.errors|length > 0 ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-primary' }}" value="{{ form.city.vars.value ?? '' }}" placeholder="Paris" required>
								</div>

								<!-- Code postal -->
								<div>
									<label for="shipping_address_postalCode" class="block text-sm font-semibold text-gray-700 mb-1">
										{{ form.postalCode.vars.label }}
										<span class="text-red-500">*</span>
									</label>
									{% if form.postalCode.vars.errors|length > 0 %}
										<div class="text-sm text-red-600 mb-2">
											{% for error in form.postalCode.vars.errors %}
												<div>{{ error.message }}</div>
											{% endfor %}
										</div>
									{% endif %}
									<input type="text" id="shipping_address_postalCode" name="{{ form.postalCode.vars.full_name }}" class="w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 {{ form.postalCode.vars.errors|length > 0 ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-primary' }}" value="{{ form.postalCode.vars.value ?? '' }}" placeholder="75001" maxlength="5" required>
								</div>

								<!-- Pays -->
								<div>
									<label for="shipping_address_country" class="block text-sm font-semibold text-gray-700 mb-1">
										{{ form.country.vars.label }}
										<span class="text-red-500">*</span>
									</label>
									{% if form.country.vars.errors|length > 0 %}
										<div class="text-sm text-red-600 mb-2">
											{% for error in form.country.vars.errors %}
												<div>{{ error.message }}</div>
											{% endfor %}
										</div>
									{% endif %}
									<input type="text" id="shipping_address_country" name="{{ form.country.vars.full_name }}" class="w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 {{ form.country.vars.errors|length > 0 ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-primary' }}" value="{{ form.country.vars.value ?? '' }}" placeholder="France" required>
								</div>

								<!-- Téléphone -->
								<div>
									<label for="shipping_address_phone" class="block text-sm font-semibold text-gray-700 mb-1">
										{{ form.phone.vars.label }}
										<span class="text-red-500">*</span>
									</label>
									{% if form.phone.vars.errors|length > 0 %}
										<div class="text-sm text-red-600 mb-2">
											{% for error in form.phone.vars.errors %}
												<div>{{ error.message }}</div>
											{% endfor %}
										</div>
									{% endif %}
									<input type="tel" id="shipping_address_phone" name="{{ form.phone.vars.full_name }}" class="w-full px-3 py-2 border rounded-md text-sm focus:outline-none focus:ring-2 {{ form.phone.vars.errors|length > 0 ? 'border-red-500 focus:ring-red-500' : 'border-gray-300 focus:ring-primary' }}" value="{{ form.phone.vars.value ?? '' }}" placeholder="+33 6 12 34 56 78" required>
								</div>
							</div>

							<hr class="border-t border-gray-100 my-6">

							<div class="flex flex-col sm:flex-row justify-end gap-3">
								<a href="{{ path('app_cartindex') }}" class="inline-flex items-center justify-center gap-2 px-5 py-2 border border-gray-300 text-gray-700 text-sm font-semibold rounded-md hover:bg-gray-50 transition-colors">
									<i class="bi bi-arrow-left"></i>Retour au panier
								</a>
								<button type="submit" class="inline-flex items-center justify-center gap-2 px-5 py-2 bg-green-600 text-white text-sm font-semibold rounded-md hover:bg-green-700 transition-colors">
									<i class="bi bi-check-circle"></i>Continuer vers le paiement
								</button>
							</div>
						</form>

					</div>
				</div>
			</div>

			<!-- Order Summary -->
			<div class="w-full lg:w-1/3">
				<div class="bg-white rounded-2xl border border-gray-100 shadow-sm sticky top-[100px]">
					<div class="bg-white border-b border-gray-100 rounded-t-2xl py-3 px-5">
						<h5 class="text-base font-semibold text-gray-900 m-0">
							<i class="bi bi-receipt text-green-600 mr-2"></i>
							Résumé
						</h5>
					</div>
					<div class="px-5 py-5">

						{% if cart and cart.items %}
							<div class="mb-4">
								<p class="text-xs text-gray-500 mb-2">Articles ({{ cart.items|length }})</p>
								{% for item in cart.items %}
									<div class="flex justify-between text-sm mb-2">
										<span class="text-gray-700">{{ item.product.designation }}
											×{{ item.quantity }}</span>
										<span class="font-semibold">{{ item.subtotal|number_format(2, ',', ' ') }}
											€</span>
									</div>
								{% endfor %}
							</div>

							<hr class="border-t border-gray-100 my-4">

							<div class="flex justify-between mb-2">
								<span class="text-sm text-gray-500">Sous-total</span>
								<span class="text-sm font-semibold">{{ total|number_format(2, ',', ' ') }}
									€</span>
							</div>
							<div class="flex justify-between mb-4">
								<span class="text-sm text-gray-500">Livraison</span>
								<span class="text-sm font-semibold text-green-600">Gratuite</span>
							</div>

							<hr class="border-t border-gray-100 my-4">

							<div class="flex justify-between items-center">
								<span class="font-bold text-lg text-gray-900">Total</span>
								<span class="font-bold text-2xl text-[#1a8a5a]">{{ total|number_format(2, ',', ' ') }}
									€</span>
							</div>

							<div class="flex items-center justify-center gap-2 mt-4 text-gray-400 text-xs">
								<i class="bi bi-shield-lock-fill text-green-600"></i>
								Paiement sécurisé par Stripe
							</div>
						{% else %}
							<p class="text-gray-500 text-center text-sm">Votre panier est vide</p>
						{% endif %}

					</div>
				</div>
			</div>

		</div>
	</div>
{% endblock %}
