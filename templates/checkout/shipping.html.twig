{% extends 'base.html.twig' %}

{% block title %}Adresse de livraison - Sports Bottles{% endblock %}

{% block body %}
<div class="container" style="margin-top: 100px; margin-bottom: 60px;">

    <!-- Header -->
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="rounded-circle d-flex align-items-center justify-content-center"
             style="width:48px;height:48px;background:#e8f5e9;">
            <i class="bi bi-geo-alt text-success fs-4"></i>
        </div>
        <div>
            <h1 class="h3 fw-bold mb-0" style="color:#0f1923;">Adresse de livraison</h1>
            <p class="text-muted small mb-0">Saisissez les informations de livraison</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Form -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom rounded-top-4 py-3 px-4">
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-house text-success me-2"></i>
                        Informations de livraison
                    </h5>
                </div>
                <div class="card-body p-4 p-md-5">

                    {% include 'components/_flash_messages.html.twig' %}

                    <form method="post" class="needs-validation" novalidate>
                        {% if form._token is defined %}
                            <input type="hidden" name="{{ form._token.vars.full_name }}" value="{{ form._token.vars.value }}">
                        {% endif %}

                        <div class="row g-3">
                            <!-- Nom complet -->
                            <div class="col-md-12">
                                <label for="shipping_address_fullName" class="form-label fw-semibold">
                                    {{ form.fullName.vars.label }}
                                    <span class="text-danger">*</span>
                                </label>
                                {% if form.fullName.vars.errors|length > 0 %}
                                    <div class="alert alert-danger small mb-2">
                                        {% for error in form.fullName.vars.errors %}
                                            <div>{{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <input 
                                    type="text"
                                    id="shipping_address_fullName"
                                    name="{{ form.fullName.vars.full_name }}"
                                    class="form-control form-control-lg {% if form.fullName.vars.errors|length > 0 %}is-invalid{% endif %}"
                                    value="{{ form.fullName.vars.value ?? '' }}"
                                    placeholder="Jean Dupont"
                                    required
                                >
                            </div>

                            <!-- Adresse -->
                            <div class="col-md-12">
                                <label for="shipping_address_address" class="form-label fw-semibold">
                                    {{ form.address.vars.label }}
                                    <span class="text-danger">*</span>
                                </label>
                                {% if form.address.vars.errors|length > 0 %}
                                    <div class="alert alert-danger small mb-2">
                                        {% for error in form.address.vars.errors %}
                                            <div>{{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <input 
                                    type="text"
                                    id="shipping_address_address"
                                    name="{{ form.address.vars.full_name }}"
                                    class="form-control form-control-lg {% if form.address.vars.errors|length > 0 %}is-invalid{% endif %}"
                                    value="{{ form.address.vars.value ?? '' }}"
                                    placeholder="123 Rue de la Paix"
                                    required
                                >
                            </div>

                            <!-- Ville -->
                            <div class="col-md-6">
                                <label for="shipping_address_city" class="form-label fw-semibold">
                                    {{ form.city.vars.label }}
                                    <span class="text-danger">*</span>
                                </label>
                                {% if form.city.vars.errors|length > 0 %}
                                    <div class="alert alert-danger small mb-2">
                                        {% for error in form.city.vars.errors %}
                                            <div>{{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <input 
                                    type="text"
                                    id="shipping_address_city"
                                    name="{{ form.city.vars.full_name }}"
                                    class="form-control form-control-lg {% if form.city.vars.errors|length > 0 %}is-invalid{% endif %}"
                                    value="{{ form.city.vars.value ?? '' }}"
                                    placeholder="Paris"
                                    required
                                >
                            </div>

                            <!-- Code postal -->
                            <div class="col-md-6">
                                <label for="shipping_address_postalCode" class="form-label fw-semibold">
                                    {{ form.postalCode.vars.label }}
                                    <span class="text-danger">*</span>
                                </label>
                                {% if form.postalCode.vars.errors|length > 0 %}
                                    <div class="alert alert-danger small mb-2">
                                        {% for error in form.postalCode.vars.errors %}
                                            <div>{{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <input 
                                    type="text"
                                    id="shipping_address_postalCode"
                                    name="{{ form.postalCode.vars.full_name }}"
                                    class="form-control form-control-lg {% if form.postalCode.vars.errors|length > 0 %}is-invalid{% endif %}"
                                    value="{{ form.postalCode.vars.value ?? '' }}"
                                    placeholder="75001"
                                    maxlength="5"
                                    required
                                >
                            </div>

                            <!-- Pays -->
                            <div class="col-md-6">
                                <label for="shipping_address_country" class="form-label fw-semibold">
                                    {{ form.country.vars.label }}
                                    <span class="text-danger">*</span>
                                </label>
                                {% if form.country.vars.errors|length > 0 %}
                                    <div class="alert alert-danger small mb-2">
                                        {% for error in form.country.vars.errors %}
                                            <div>{{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <input 
                                    type="text"
                                    id="shipping_address_country"
                                    name="{{ form.country.vars.full_name }}"
                                    class="form-control form-control-lg {% if form.country.vars.errors|length > 0 %}is-invalid{% endif %}"
                                    value="{{ form.country.vars.value ?? '' }}"
                                    placeholder="France"
                                    required
                                >
                            </div>

                            <!-- Téléphone -->
                            <div class="col-md-6">
                                <label for="shipping_address_phone" class="form-label fw-semibold">
                                    {{ form.phone.vars.label }}
                                    <span class="text-danger">*</span>
                                </label>
                                {% if form.phone.vars.errors|length > 0 %}
                                    <div class="alert alert-danger small mb-2">
                                        {% for error in form.phone.vars.errors %}
                                            <div>{{ error.message }}</div>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                <input 
                                    type="tel"
                                    id="shipping_address_phone"
                                    name="{{ form.phone.vars.full_name }}"
                                    class="form-control form-control-lg {% if form.phone.vars.errors|length > 0 %}is-invalid{% endif %}"
                                    value="{{ form.phone.vars.value ?? '' }}"
                                    placeholder="+33 6 12 34 56 78"
                                    required
                                >
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-grid gap-2 d-md-flex gap-md-2 justify-content-md-end">
                            <a href="{{ path('app_cartindex') }}" class="btn btn-outline-secondary py-2 px-4 fw-semibold">
                                <i class="bi bi-arrow-left me-1"></i>Retour au panier
                            </a>
                            <button type="submit" class="btn btn-success py-2 px-4 fw-semibold">
                                <i class="bi bi-check-circle me-1"></i>Continuer vers le paiement
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>

        <!-- Order Summary -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top:100px;">
                <div class="card-header bg-white border-bottom rounded-top-4 py-3 px-4">
                    <h5 class="mb-0 fw-semibold">
                        <i class="bi bi-receipt text-success me-2"></i>
                        Résumé
                    </h5>
                </div>
                <div class="card-body px-4 py-4">

                    {% if cart and cart.items %}
                        <div class="mb-3">
                            <small class="text-muted d-block mb-2">Articles ({{ cart.items|length }})</small>
                            {% for item in cart.items %}
                                <div class="d-flex justify-content-between mb-2 small">
                                    <span>{{ item.product.designation }} x{{ item.quantity }}</span>
                                    <span class="fw-semibold">{{ item.subtotal|number_format(2, ',', ' ') }} €</span>
                                </div>
                            {% endfor %}
                        </div>

                        <hr>

                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Sous-total</span>
                            <span class="fw-semibold">{{ total|number_format(2, ',', ' ') }} €</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Livraison</span>
                            <span class="fw-semibold text-success">Gratuite</span>
                        </div>

                        <hr>

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold fs-5" style="color:#0f1923;">Total</span>
                            <span class="fw-bold fs-4" style="color:#1a8a5a;">{{ total|number_format(2, ',', ' ') }} €</span>
                        </div>

                        <div class="d-flex align-items-center justify-content-center gap-2 mt-3 text-muted small">
                            <i class="bi bi-shield-lock-fill text-success"></i>
                            Paiement sécurisé par Stripe
                        </div>
                    {% else %}
                        <p class="text-muted text-center">Votre panier est vide</p>
                    {% endif %}

                </div>
            </div>
        </div>

    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
{% endblock %}
