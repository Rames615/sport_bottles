{% extends "base.html.twig" %}

{% block title %}Nos Produits{% endblock %}

{% block body %}
    <div class="w-full mt-[70px]">

        {# ── STICKY FILTER BAR ── #}
        <div class="sticky top-[70px] z-[1020] bg-white/95 backdrop-blur-sm border-b border-[#e2ede9] shadow-[0_2px_8px_rgba(0,0,0,.06)] px-6 sm:px-8 py-3">
            <div class="flex justify-between items-center flex-wrap gap-3">
                <div class="flex items-baseline gap-3">
                    <h1 class="text-lg font-bold text-[#212529] m-0 whitespace-nowrap">Nos Produits</h1>
                    <span class="text-xs text-muted" id="productCount">{{ allProducts|length }} produit(s)</span>
                </div>

                <div class="flex gap-2 flex-wrap items-center" role="toolbar" aria-label="Filtres produits">
                    {# Category #}
                    <select id="categoryFilter"
                            class="filter-select text-sm border border-[#dee2e6] rounded-lg py-2 pl-3 pr-8 bg-white text-[#212529] focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary cursor-pointer appearance-none"
                            aria-label="Filtrer par catégorie"
                            style="background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 12 12%22><path fill=%22%236b7280%22 d=%22M2 4l4 4 4-4%22/></svg>');background-repeat:no-repeat;background-position:right .5rem center;">
                        <option value="">Catégorie</option>
                        {% for category in categories %}
                            <option value="{{ category.name }}">{{ category.name }}</option>
                        {% endfor %}
                    </select>

                    {# Price #}
                    <select id="priceFilter"
                            class="filter-select text-sm border border-[#dee2e6] rounded-lg py-2 pl-3 pr-8 bg-white text-[#212529] focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary cursor-pointer appearance-none"
                            aria-label="Filtrer par prix"
                            style="background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 12 12%22><path fill=%22%236b7280%22 d=%22M2 4l4 4 4-4%22/></svg>');background-repeat:no-repeat;background-position:right .5rem center;">
                        <option value="">Prix</option>
                        <option value="0-50">0 – 50 €</option>
                        <option value="50-100">50 – 100 €</option>
                        <option value="100-500">100 – 500 €</option>
                        <option value="500+">500 € +</option>
                    </select>

                    {# Sort #}
                    <select id="sortFilter"
                            class="filter-select text-sm border border-[#dee2e6] rounded-lg py-2 pl-3 pr-8 bg-white text-[#212529] focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary cursor-pointer appearance-none"
                            aria-label="Trier les produits"
                            style="background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 12 12%22><path fill=%22%236b7280%22 d=%22M2 4l4 4 4-4%22/></svg>');background-repeat:no-repeat;background-position:right .5rem center;">
                        <option value="">Trier par</option>
                        <option value="name-asc">Nom (A–Z)</option>
                        <option value="name-desc">Nom (Z–A)</option>
                        <option value="price-asc">Prix croissant</option>
                        <option value="price-desc">Prix décroissant</option>
                    </select>

                    {# Divider #}
                    <span class="hidden sm:block w-px h-6 bg-[#dee2e6]" aria-hidden="true"></span>

                    {# Promotion toggle #}
                    <button id="promo-toggle-btn"
                            type="button"
                            class="inline-flex items-center gap-1.5 text-sm border-2 rounded-lg py-[7px] px-3 cursor-pointer transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-primary/30"
                            data-active="false"
                            aria-pressed="false"
                            aria-label="Afficher uniquement les promotions">
                        <span class="text-base leading-none">🔥</span>
                        <span class="font-medium">Promos</span>
                    </button>

                    {# Reset all filters — display toggled via JS (cannot use Tailwind 'hidden' = display:none !important) #}
                    <button id="resetFilters"
                            type="button"
                            class="items-center gap-1 text-xs text-muted hover:text-[#212529] border border-[#dee2e6] rounded-lg py-2 px-2.5 cursor-pointer transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-primary/30"
                            style="display:none"
                            aria-label="Réinitialiser tous les filtres">
                        <i class="fas fa-times text-[.6rem]"></i>
                        <span>Réinitialiser</span>
                    </button>
                </div>
            </div>
        </div>

        {# Products Grid #}
        <div class="px-6 sm:px-8 py-8">
        {% if allProducts is not empty %}
            <div class="products-grid grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 p-6">
                {% for product in allProducts %}
                    {% include 'product/_card.html.twig' with {'product': product} only %}
                {% endfor %}
            </div>
        {% else %}
            <div class="no-products-message text-center py-16 px-6 bg-[#f8f9fa] border border-dashed border-[#dee2e6] rounded-md" role="alert">
                <h4 class="font-semibold text-lg mb-2 text-[#212529]">Aucun produit trouvé</h4>
                <p class="mb-0 text-muted">Veuillez vérifier les filtres appliqués et réessayer.</p>
            </div>
        {% endif %}
        </div>{# /px wrapper #}
    </div>

    {# ── PROMOTIONS RECAP SECTION ── #}
    {% if activePromotions is not empty %}
    <section id="promotions-section" class="w-full py-10 px-6 sm:px-8 border-t border-[#e2ede9]" style="background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);">
        <div class="max-w-[1400px] mx-auto">
            <h2 class="flex items-center gap-4 text-[1.6rem] font-bold text-main tracking-[-0.5px] mb-2 font-display">
                <span class="text-[2rem] inline-block animate-pulse-icon">🔥</span>
                Nos promotions en cours
            </h2>
            <p class="text-sm text-muted mb-8 max-w-[500px] leading-relaxed">
                Profitez de réductions exceptionnelles sur une sélection de produits
            </p>
            <div class="grid gap-5" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
                {% for promotion in activePromotions %}
                    {% set product = promotion.product %}
                    {% if product %}
                        {% set imageFileName = product.imgPath ? (product.imgPath|split('/')|last) : null %}
                        {% set promoImagePath = imageFileName ? asset('products_images/' ~ imageFileName) : asset('images/placeholder.png') %}
                        <div class="group bg-white rounded-xl overflow-hidden shadow-[0_2px_10px_rgba(0,0,0,.06)] transition-all duration-300 flex flex-col border border-primary/10 hover:-translate-y-1 hover:shadow-[0_8px_24px_rgba(31,122,99,.12)] hover:border-primary/25">
                            <div class="relative h-[170px] overflow-hidden" style="background: linear-gradient(135deg, #f8f9fa 0%, #eff2f5 100%);">
                                {# Discount badge #}
                                <div class="absolute top-2 left-2 z-10">
                                    {% if promotion.discountType == 'percentage' %}
                                        <span class="px-2 py-1 rounded-md font-bold text-[.7rem] uppercase tracking-[.5px] text-white shadow-sm" style="background: linear-gradient(135deg, #dc2626, #bb1c27);">-{{ promotion.discountValue }}%</span>
                                    {% else %}
                                        <span class="px-2 py-1 rounded-md font-bold text-[.7rem] uppercase tracking-[.5px] text-white shadow-sm" style="background: linear-gradient(135deg, #f59e0b, #d97706);">-{{ promotion.discountValue }}€</span>
                                    {% endif %}
                                </div>
                                <img src="{{ promoImagePath }}" alt="{{ product.designation }}" class="w-full h-full object-contain px-4 py-3 transition-transform duration-300 group-hover:scale-105" onerror="this.src='{{ asset('images/placeholder.png') }}'">
                            </div>
                            <div class="px-4 py-3 flex-1 flex flex-col">
                                <h3 class="text-[.95rem] font-bold text-main mb-1 leading-[1.3] font-display">{{ product.designation }}</h3>
                                {% if product.category %}
                                    <span class="inline-block self-start text-[.65rem] font-semibold tracking-[.05em] px-2 py-0.5 rounded-full mb-2" style="background-color:#e8f5f1; color:#1F7A63;">{{ product.category.name }}</span>
                                {% endif %}
                                <div class="flex items-baseline gap-2 mb-2">
                                    <span class="text-lg font-bold text-primary font-display">{{ product.finalPrice|number_format(2, ',', ' ') }} €</span>
                                    <span class="text-xs text-muted line-through">{{ product.price|number_format(2, ',', ' ') }} €</span>
                                </div>
                                {% set daysLeft = (promotion.endAt.timestamp - date().timestamp) / 86400 %}
                                {% if daysLeft > 0 %}
                                    <span class="inline-block self-start bg-[#fff3cd] text-[#856404] border border-[#ffc107] rounded-[20px] px-2 py-px font-semibold text-[.65rem] mb-2">
                                        ⏳ Plus que {{ daysLeft|round(0, 'ceil') }} jour{% if daysLeft > 1 %}s{% endif %}
                                    </span>
                                {% endif %}
                                <a href="{{ path('app_product_show', {id: product.id}) }}"
                                   class="mt-auto inline-flex items-center justify-center gap-2 px-3 py-2 rounded-lg font-semibold text-[.75rem] text-white no-underline transition-all duration-200 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #1F7A63, #1a5c4a);">
                                    <i class="fas fa-eye"></i> Voir le produit
                                </a>
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </section>
    {% endif %}

{% endblock %}
