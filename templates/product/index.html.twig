{% extends "base.html.twig" %}

{% block title %}Nos Produits{% endblock %}

{% block body %}
{# ajouter le margin top plus que le hauter de bar nav #}
    <div class="container-fluid mt-5 p-5">
        {# Products Header #}
        <div class="products-header mb-4">
            <div>
                <h1 class="products-title">Nos Produits</h1>
                <p class="text-muted">{{ allProducts|length }} produit(s) disponible(s)</p>
            </div>
            
            {# Filters & Sort Controls - Using Bootstrap form-select #}
            <div class="products-controls">
                {# Category Filter #}
                <div>
                    <select id="categoryFilter" class="form-select form-select-sm" aria-label="Filtrer par catégorie">
                        <option value="">Toutes les catégories</option>
                        {% for category in categories %}
                            <option value="{{ category.name }}">{{ category.name }}</option>
                        {% endfor %}
                    </select>
                </div>

                {# Price Range Filter #}
                <div>
                    <select id="priceFilter" class="form-select form-select-sm" aria-label="Filtrer par prix">
                        <option value="">Tous les prix</option>
                        <option value="0-50">0 - 50 €</option>
                        <option value="50-100">50 - 100 €</option>
                        <option value="100-500">100 - 500 €</option>
                        <option value="500+">500 € +</option>
                    </select>
                </div>

                {# Sort #}
                <div>
                    <select id="sortFilter" class="form-select form-select-sm" aria-label="Trier les produits">
                        <option value="">Trier par</option>
                        <option value="name-asc">Nom (A-Z)</option>
                        <option value="name-desc">Nom (Z-A)</option>
                        <option value="price-asc">Prix (croissant)</option>
                        <option value="price-desc">Prix (décroissant)</option>
                    </select>
                </div>
            </div>
        </div>

        {# Products Grid #}
        {% if allProducts is not empty %}
            <div class="products-grid">
                {% for product in allProducts %}
                    {% include 'product/_card.html.twig' with {'product': product} only %}
                {% endfor %}
            </div>
        {% else %}
            <div class="alert alert-info" role="alert">
                <h4 class="alert-heading">Aucun produit trouvé</h4>
                <p>Veuillez vérifier les filtres appliqués et réessayer.</p>
            </div>
        {% endif %}
    </div>

{% endblock %}
