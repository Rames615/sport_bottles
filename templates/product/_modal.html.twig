{# Produit Modal Réutilisable - Affiche les détails complets du produit #}

<div class="modal fade" id="productModal" tabindex="-1" aria-labelledby="productModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4">
            
            {# Header avec fermeture #}
            <div class="modal-header bg-light rounded-top-4 border-0 px-4 py-3">
                <h5 class="modal-title fw-bold" id="productModalLabel">Détails du produit</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>

            {# Contenu modal #}
            <div class="modal-body p-4 p-md-5">
                
                {# Image #}
                <div class="mb-4">
                    <img id="modalProductImage" src="" alt="Produit" 
                         class="img-fluid rounded-3" style="max-height: 400px; width: 100%; object-fit: contain;">
                </div>

                {# Nom du produit #}
                <h2 id="modalProductName" class="h4 fw-bold mb-3" style="color: #0f1923;"></h2>

                {# Prix #}
                <div class="d-flex align-items-baseline gap-3 mb-4">
                    <span id="modalProductPrice" class="h3 fw-bold" style="color: #1F7A63;"></span>
                    <span class="text-muted text-decoration-line-through small"></span>
                </div>

                {# Description complète #}
                <div class="mb-4 pb-4 border-bottom">
                    <h5 class="fw-bold mb-3" style="text-transform: uppercase; letter-spacing: 0.5px; color: #212529;">
                        <i class="fas fa-info-circle me-2" style="color: #1F7A63;"></i> Description
                    </h5>
                    <p id="modalProductDescription" class="text-dark" style="line-height: 1.6; text-align: justify;"></p>
                </div>

                {# Caractéristiques #}
                <div class="mb-4">
                    <h5 class="fw-bold mb-3" style="text-transform: uppercase; letter-spacing: 0.5px; color: #212529;">
                        <i class="fas fa-cogs me-2" style="color: #1F7A63;"></i> Caractéristiques
                    </h5>
                    <div id="modalProductSpecs" class="row g-3">
                        {# Sera rempli par JavaScript #}
                    </div>
                </div>
            </div>

            {# Footer avec bouton d'action #}
            <div class="modal-footer bg-light rounded-bottom-4 border-0 px-4 py-3 d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary fw-semibold" data-bs-dismiss="modal">
                    <i class="fas fa-arrow-left me-2"></i> Retour
                </button>
                <form id="modalAddToCartForm" method="post" class="w-100">
                    <input type="hidden" name="_token" id="modalCsrfToken" value="">
                    <button type="submit" class="btn w-100 fw-semibold" 
                            style="background: linear-gradient(135deg, #1F7A63 0%, #1a5c4a 100%); color: white; border: none; padding: 0.625rem 1rem;">
                        <i class="fas fa-shopping-cart me-2"></i> Ajouter au panier
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
