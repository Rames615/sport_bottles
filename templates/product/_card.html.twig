<div class="product-card" 
     data-product-id="{{ product.id }}"
     data-category="{{ product.category ? product.category.name : 'Uncategorized' }}" 
     data-price="{{ product.price }}" 
     data-capacity="{{ product.capacity }}" 
     data-temperature="{{ product.temperature }}">

    {# ============================================
       IMAGE SECTION
       ============================================ #}
    <div class="product-image-wrapper">
        {% if product.imgPath %}
            <img src="{{ asset('products_images/' ~ product.category.slug ~ '/' ~ product.imgPath) }}" 
                 alt="{{ product.designation }}" 
                 class="product-image" 
                 onerror="this.src='{{ asset('images/placeholder.png') }}'">
        {% else %}
            <img src="{{ asset('images/placeholder.png') }}" 
                 alt="Image placeholder pour {{ product.designation }}" 
                 class="product-image">
        {% endif %}
    </div>

    {# ============================================
       INFO SECTION
       ============================================ #}
    <div class="product-info">
        
        {# Product Name #}
        <h3 class="product-name">{{ product.designation }}</h3>

        {# Product Specs Summary #}
        <div class="product-specs">
            {% if product.capacity %}
                <div class="product-spec-item">
                    <strong>Capacité:</strong>
                    <span>{{ product.capacity }}</span>
                </div>
            {% endif %}
            
            {% if product.temperature %}
                <div class="product-spec-item">
                    <strong>Température:</strong>
                    <span>{{ product.temperature }}</span>
                </div>
            {% endif %}
            
            {% if product.category %}
                <div class="product-spec-item">
                    <strong>Catégorie:</strong>
                    <span>{{ product.category.name }}</span>
                </div>
            {% endif %}
        </div>

        {# Product Price #}
        <p class="product-price mb-3">
            {{ product.price|number_format(2, ',', ' ') }} €
        </p>

        {# ============================================
           ACTIONS BUTTONS
           ============================================ #}
        <div class="product-actions">
            {# Show More Button - Opens Modal #}
            <button type="button"
                    class="btn btn-show-more btn-info w-100" 
                    data-product-id="{{ product.id }}"
                    data-product-name="{{ product.designation }}"
                    data-product-price="{{ product.price }}"
                    data-product-description="{{ product.description }}"
                    data-product-capacity="{{ product.capacity }}"
                    data-product-temperature="{{ product.temperature }}"
                    data-product-category="{{ product.category ? product.category.name : '' }}"
                    data-product-image="{% if product.imgPath %}{{ asset('products_images/' ~ product.category.slug ~ '/' ~ product.imgPath) }}{% else %}{{ asset('images/placeholder.png') }}{% endif %}"
                    data-csrf-token="{{ csrf_token('cart_add') }}"
                    data-cart-url="{{ path('app_cartadd', { id: product.id }) }}"
                    data-bs-toggle="modal" 
                    data-bs-target="#productModal"
                    title="Afficher plus de détails sur {{ product.designation }}">
                <i class="fas fa-chevron-down"></i> Voir plus
            </button>
        </div>
    </div>
</div>
