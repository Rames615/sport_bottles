<div class="product-card group flex flex-col h-full bg-white border border-[#dee2e6] rounded-md shadow-[0_2px_4px_rgba(0,0,0,.075)] transition-all duration-300 overflow-hidden hover:shadow-[0_8px_16px_rgba(0,0,0,.15)] hover:-translate-y-1"
     data-product-id="{{ product.id }}"
     data-category="{{ product.category ? product.category.name : 'Uncategorized' }}"
     data-price="{{ product.price }}"
     data-capacity="{{ product.capacity }}"
     data-temperature="{{ product.temperature }}">

    {% set imageFileName = product.imgPath ? (product.imgPath|split('/')|last) : null %}
    {% set productImagePath = imageFileName ? asset('products_images/' ~ imageFileName) : asset('images/placeholder.png') %}

    {# ============================================
       IMAGE SECTION
       ============================================ #}
    <div class="relative w-full h-[200px] overflow-hidden bg-[#f8f9fa] shrink-0">
        {% if product.imgPath %}
            <img src="{{ productImagePath }}"
                 alt="{{ product.designation }}"
                 class="w-full h-full object-contain transition-transform duration-300 group-hover:scale-105"
                 onerror="this.onerror=null; this.src='{{ asset('images/placeholder.png') }}'">
        {% else %}
            <img src="{{ asset('images/placeholder.png') }}"
                 alt="Image placeholder pour {{ product.designation }}"
                 class="w-full h-full object-contain">
        {% endif %}
    </div>

    {# ============================================
       INFO SECTION
       ============================================ #}
    <div class="grow flex flex-col px-5 py-5">

        {# Product Name #}
        <h3 class="product-name text-[1.1rem] font-semibold text-[#212529] mb-3 leading-[1.3] line-clamp-2">{{ product.designation }}</h3>

        {# Product Specs Summary #}
        <div class="flex flex-col gap-2 mb-4 py-3 border-t border-b border-[#dee2e6] text-sm">
            {% if product.capacity %}
                <div class="flex justify-between flex-wrap gap-2 text-[#555]">
                    <strong class="font-semibold text-[#212529]">Capacité:</strong>
                    <span class="text-[#007bff] font-medium">{{ product.capacity }}</span>
                </div>
            {% endif %}
            {% if product.temperature %}
                <div class="flex justify-between flex-wrap gap-2 text-[#555]">
                    <strong class="font-semibold text-[#212529]">Température:</strong>
                    <span class="text-[#007bff] font-medium">{{ product.temperature }}</span>
                </div>
            {% endif %}
            {% if product.category %}
                <div class="flex justify-between flex-wrap gap-2 text-[#555]">
                    <strong class="font-semibold text-[#212529]">Catégorie:</strong>
                    <span class="text-[#007bff] font-medium">{{ product.category.name }}</span>
                </div>
            {% endif %}
        </div>

        {# Product Price #}
        <p class="text-2xl font-bold text-[#28a745] mt-3 mb-3">
            {{ product.price|number_format(2, ',', ' ') }} €
        </p>

        {# Actions #}
        <div class="flex gap-3 mt-auto">
            <a href="{{ path('app_product_show', {id: product.id}) }}"
               class="flex flex-1 items-center justify-center gap-2 px-4 py-2 bg-[#17a2b8] text-white text-sm font-semibold rounded no-underline transition-colors duration-200 hover:bg-[#138496]"
               title="Afficher plus de détails sur {{ product.designation }}">
                <i class="fas fa-eye"></i> Voir plus
            </a>
        </div>
    </div>
</div>
