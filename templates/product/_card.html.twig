<div class="product-card" 
     data-product-id="{{ product.id }}"
     data-category="{{ product.category ? product.category.name : 'Uncategorized' }}" 
     data-price="{{ product.price }}" 
     data-capacity="{{ product.capacity }}" 
     data-temperature="{{ product.temperature }}">

    {% set imageFileName = product.imgPath ? (product.imgPath|split('/')|last) : null %}
    {% set productImagePath = imageFileName ? asset('products_images/' ~ imageFileName) : asset('images/placeholder.png') %}

    {# ============================================
       IMAGE SECTION
       ============================================ #}
    <div class="product-image-wrapper">
        {% if product.imgPath %}
            <img src="{{ productImagePath }}" 
                 alt="{{ product.designation }}" 
                 class="product-image" 
                 onerror="this.onerror=null; this.src='{{ asset('images/placeholder.png') }}'">
        {% else %}
            <img src="{{ asset('images/placeholder.png') }}" 
                 alt="Image placeholder pour {{ product.designation }}" 
                 class="product-image">
        {% endif %}
    </div>

    {# ============================================
       INFO SECTION
       ============================================ #}
    <div class="product-info">
        
        {# Product Name #}
        <h3 class="product-name">{{ product.designation }}</h3>

        {# Product Specs Summary #}
        <div class="product-specs">
            {% if product.capacity %}
                <div class="product-spec-item">
                    <strong>Capacité:</strong>
                    <span>{{ product.capacity }}</span>
                </div>
            {% endif %}
            
            {% if product.temperature %}
                <div class="product-spec-item">
                    <strong>Température:</strong>
                    <span>{{ product.temperature }}</span>
                </div>
            {% endif %}
            
            {% if product.category %}
                <div class="product-spec-item">
                    <strong>Catégorie:</strong>
                    <span>{{ product.category.name }}</span>
                </div>
            {% endif %}
        </div>

        {# Product Price #}
        <p class="product-price mb-3">
            {{ product.price|number_format(2, ',', ' ') }} €
        </p>

        {# ============================================
           ACTIONS BUTTONS
           ============================================ #}
        <div class="product-actions">
            {# Link to dedicated product detail page #}
            <a href="{{ path('app_product_show', {id: product.id}) }}"
               class="btn btn-show-more btn-info w-100"
               title="Afficher plus de détails sur {{ product.designation }}">
                <i class="fas fa-eye"></i> Voir plus
            </a>
        </div>
    </div>
</div>
