# Stripe Configuration
# ==================
# Get these from https://dashboard.stripe.com/apikeys (Test mode)
# DO NOT commit real keys to the repository!

# Public key for Stripe.js frontend
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Secret key for backend API calls (KEEP PRIVATE)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret from Stripe CLI:
# Get via: stripe listen --forward-to http://localhost:8000/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

