# Auto-detect text files and normalize line endings to LF in the repository
* text=auto eol=lf

# PHP, Twig, JS, CSS, JSON, YAML — always LF
*.php text eol=lf
*.twig text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf
*.env.* text eol=lf

# Windows scripts — keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
